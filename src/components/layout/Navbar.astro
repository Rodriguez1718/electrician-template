---
import Button from "../ui/Button.astro";

const navLinks = [
  { label: "Home", href: "/" },
  { label: "About", href: "/about" },
  { label: "Contact", href: "/contact" },
  { label: "Service Areas", href: "/service-area" },
];

const currentPath = Astro.url.pathname;
---

<nav class="fixed top-0 left-0 right-0 z-50 transition-all duration-500" id="navbar">
  <!-- Desktop navbar (1024px+) -->
  <div class="hidden lg:block px-6 py-4 relative">
    <div class="flex items-center justify-between max-w-7xl mx-auto">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 text-xl font-asap-condensed font-bold text-white no-underline transition-all duration-500 ease-out relative z-20" id="navbar-logo">
        <img src="/voltbully1.webp" alt="VoltBully Logo" class="w-10 h-10 object-contain" fetchpriority="high" />
        VOLTBULLY
      </a>

      <!-- Center container -->
      <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 flex items-center bg-white/80 backdrop-blur-md rounded-full px-6 py-2 shadow-lg border border-white/20 transition-all duration-500 ease-out" id="nav-container">
        <div class="flex items-center">
          {navLinks.map((link) => {
            if (link.label === "Service Areas") {
              return (
                <div class="relative inline-block" id="desktop-service-areas-wrapper">
                  <a 
                    href={link.href}
                    class:list={[
                      "flex items-center gap-1 px-4 py-2 text-sm font-medium no-underline transition-colors rounded-full",
                      { 
                        "text-[var(--color-accent)] bg-blue-50": currentPath === link.href,
                        "text-gray-700 hover:text-gray-900 hover:bg-gray-50": currentPath !== link.href
                      }
                    ]}
                    aria-expanded="false" 
                    aria-haspopup="true"
                    id="desktop-service-areas-btn"
                  >
                    {link.label}
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="transition-transform duration-200">
                      <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                </div>
              );
            } else {
              return (
                <a
                  href={link.href}
                  class:list={[
                    "px-4 py-2 text-sm font-medium no-underline transition-colors rounded-full",
                    { 
                      "text-[var(--color-accent)] bg-blue-50": currentPath === link.href,
                      "text-gray-700 hover:text-gray-900 hover:bg-gray-50": currentPath !== link.href
                    }
                  ]}
                >
                  {link.label}
                </a>
              );
            }
          })}
        </div>
      </div>

      <!-- CTA Button -->
      <Button href="/contact" variant="primary" id="navbar-cta" class="transition-all duration-500 ease-out relative z-20">
        Book Now
      </Button>
    </div>

    <!-- Service areas dropdown -->
    <div 
      class="fixed bg-white rounded-lg shadow-xl py-2 min-w-[160px] opacity-0 invisible transition-all duration-200 z-[999]" 
      role="menu"
      id="desktop-service-areas-menu"
    >
      <a href="/serviceAreas/denver" class="block px-4 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline transition-colors" role="menuitem">
        Denver
      </a>
    </div>
  </div>

  <!-- Tablet navbar (768px-1024px) -->
  <div class="hidden md:block lg:hidden px-4 py-4">
    <div class="flex items-center justify-between max-w-5xl mx-auto">
      <a href="/" class="flex items-center gap-2 text-lg font-asap-condensed font-bold text-white no-underline">
        <img src="/voltbully1.webp" alt="VoltBully Logo" class="w-7 h-7 object-contain" fetchpriority="high" />
        VOLTBULLY
      </a>

      <div class="flex items-center bg-white/80 backdrop-blur-md rounded-full px-4 py-2 shadow-lg border border-white/20">
        {navLinks.map((link) => {
          if (link.label === "Service Areas") {
            return (
              <div class="relative inline-block" id="tablet-service-areas-wrapper">
                <a 
                  href={link.href}
                  class:list={[
                    "flex items-center gap-1 px-3 py-1.5 text-sm font-medium no-underline transition-colors rounded-full",
                    { 
                      "text-[var(--color-accent)] bg-blue-50": currentPath === link.href,
                      "text-gray-700 hover:text-gray-900 hover:bg-gray-50": currentPath !== link.href
                    }
                  ]}
                  aria-expanded="false" 
                  aria-haspopup="true"
                  id="tablet-service-areas-btn"
                >
                  {link.label}
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="transition-transform duration-200">
                    <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              </div>
            );
          } else {
            return (
              <a
                href={link.href}
                class:list={[
                  "px-3 py-1.5 text-sm font-medium no-underline transition-colors rounded-full",
                  { 
                    "text-[var(--color-accent)] bg-blue-50": currentPath === link.href,
                    "text-gray-700 hover:text-gray-900 hover:bg-gray-50": currentPath !== link.href
                  }
                ]}
              >
                {link.label}
              </a>
            );
          }
        })}
      </div>

      <Button href="/contact" variant="primary" size="sm">
        Book Now
      </Button>
    </div>

    <div 
      class="fixed bg-white rounded-lg shadow-xl py-2 min-w-[160px] opacity-0 invisible transition-all duration-200 z-[999]" 
      role="menu"
      id="tablet-service-areas-menu"
    >
      <a href="/serviceAreas/denver" class="block px-4 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline transition-colors" role="menuitem">
        Denver
      </a>
    </div>
  </div>

  <!-- Tablet Services dropdown (768px-1024px) -->
  <div class="hidden md:block lg:hidden px-4 pb-4 transition-all duration-300 z-10" id="tablet-services-layer">
    <div class="max-w-5xl mx-auto flex justify-center gap-2">
      <div class="relative inline-block">
        <a 
          href="/maintenance"
          class="flex items-center gap-2 text-sm text-white/70 hover:text-white transition-colors bg-white/20 backdrop-blur-sm rounded-full px-4 py-2 border border-white/30" 
        >
          Maintenance
        </a>
      </div>
      <div class="relative inline-block">
        <button 
          class="flex items-center gap-2 text-sm text-white/70 hover:text-white transition-colors bg-white/20 backdrop-blur-sm rounded-full px-4 py-2 border border-white/30" 
          aria-expanded="false" 
          aria-haspopup="true"
          id="tablet-service-btn"
        >
          Services
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="transition-transform duration-200">
            <path d="M3 5L7 9L11 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div 
          class="absolute top-full left-1/2 -translate-x-1/2 mt-2 bg-white rounded-2xl shadow-xl py-4 min-w-[600px] opacity-0 invisible transition-all duration-200 z-50" 
          role="menu"
          id="tablet-dropdown-menu"
        >
          <div class="grid grid-cols-2 gap-4 p-4">
            <div>
              <a href="/commercial" class="flex items-center gap-2 mb-3 no-underline group">
                <div class="w-6 h-6 bg-brand-secondary/20 rounded-full flex items-center justify-center group-hover:bg-brand-secondary/30 transition-colors duration-300">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" class="text-brand-secondary">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2" stroke="currentColor" stroke-width="2"/>
                    <circle cx="9" cy="9" r="2" stroke="currentColor" stroke-width="2"/>
                  </svg>
                </div>
                <h4 class="text-xs font-asap-condensed uppercase tracking-wide font-bold text-gray-900 group-hover:text-brand-secondary transition-colors duration-300">Commercial</h4>
              </a>
              <div class="space-y-1 mb-4">
                <a href="/services/ground-up-construction" class="block px-2 py-1.5 text-xs text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">Ground-up Construction</a>
                <a href="/services/emergency-standby-power" class="block px-2 py-1.5 text-xs text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">Emergency & Standby Power</a>
                <a href="/services/commercial-hvac-electrical" class="block px-2 py-1.5 text-xs text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">Commercial HVAC</a>
              </div>
              
              <a href="/services/residential" class="flex items-center gap-2 mb-3 no-underline group">
                <div class="w-6 h-6 bg-brand-primary/20 rounded-full flex items-center justify-center group-hover:bg-brand-primary/30 transition-colors duration-300">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" class="text-brand-primary">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" stroke="currentColor" stroke-width="2"/>
                    <polyline points="9,22 9,12 15,12 15,22" stroke="currentColor" stroke-width="2"/>
                  </svg>
                </div>
                <h4 class="text-xs font-asap-condensed uppercase tracking-wide font-bold text-gray-900 group-hover:text-brand-primary transition-colors duration-300">Residential</h4>
              </a>
              <div class="space-y-1">
                <a href="/services/car-charging-stations" class="block px-2 py-1.5 text-xs text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">EV Charging Stations</a>
                <a href="/services/ceiling-fan" class="block px-2 py-1.5 text-xs text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">Ceiling Fan Installation</a>
                <a href="/services/gfci-outlets" class="block px-2 py-1.5 text-xs text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">GFCI Outlets</a>
              </div>
            </div>

            <div>
              <a href="/services/specialty" class="flex items-center gap-2 mb-3 no-underline group">
                <div class="w-6 h-6 bg-brand-accent/20 rounded-full flex items-center justify-center group-hover:bg-brand-accent/30 transition-colors duration-300">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" class="text-brand-accent">
                    <path d="M12 2L13.09 8.26L20 9L13.09 9.74L12 16L10.91 9.74L4 9L10.91 8.26L12 2Z" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <h4 class="text-xs font-asap-condensed uppercase tracking-wide font-bold text-gray-900 group-hover:text-brand-accent transition-colors duration-300">Specialty</h4>
              </a>
              <div class="space-y-1 mb-4">
                <a href="/services/holiday-lighting" class="block px-2 py-1.5 text-xs text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">Holiday Lighting</a>
                <a href="/services/landscape-lighting" class="block px-2 py-1.5 text-xs text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">Landscape Lighting</a>
                <a href="/services/pool-spa-electrical" class="block px-2 py-1.5 text-xs text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">Pool & Spa Electrical</a>
              </div>
              
              <a href="/services/emergency" class="flex items-center gap-2 mb-3 no-underline group">
                <div class="w-6 h-6 bg-red-500/20 rounded-full flex items-center justify-center group-hover:bg-red-500/30 transition-colors duration-300">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" class="text-red-600">
                    <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <h4 class="text-xs font-asap-condensed uppercase tracking-wide font-bold text-gray-900 group-hover:text-red-600 transition-colors duration-300">Emergency</h4>
              </a>
              <div class="space-y-1">
                <a href="/services/24-hour-emergency" class="block px-2 py-1.5 text-xs text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">24-hour Emergency</a>
                <a href="/services/hvac-emergency" class="block px-2 py-1.5 text-xs text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">HVAC Emergency</a>
                <a href="/services/water-heater-emergency" class="block px-2 py-1.5 text-xs text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">Water Heater Emergency</a>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="relative inline-block">
        <a 
          href="/financing"
          class="flex items-center gap-2 text-sm text-white/70 hover:text-white transition-colors bg-white/20 backdrop-blur-sm rounded-full px-4 py-2 border border-white/30" 
        >
          Financing
        </a>
      </div>
    </div>
  </div>

  <!-- Mobile navbar (below 768px) -->
  <div class="md:hidden px-4 py-4 transition-all duration-300" id="mobile-navbar">
    <div class="flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 text-lg font-asap-condensed font-bold text-white no-underline transition-colors duration-300" id="mobile-logo">
        <img src="/voltbully1.webp" alt="VoltBully Logo" class="w-7 h-7 object-contain" fetchpriority="high" />
        VOLTBULLY
      </a>

      <button 
        class="p-2 text-white hover:text-gray-300 transition-colors duration-300" 
        id="mobile-menu-btn"
        aria-label="Toggle mobile menu"
        aria-expanded="false"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" id="burger-icon">
          <path d="M3 12h18M3 6h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="hidden" id="close-icon">
          <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Desktop Services dropdown (1024px+) -->
  <div class="hidden lg:block px-6 pb-4 transition-all duration-300 z-10" id="services-layer">
    <div class="max-w-7xl mx-auto flex justify-center gap-2">
      <div class="relative inline-block">
        <a 
          href="/maintenance"
          class="flex items-center gap-2 text-sm text-white/70 hover:text-white transition-colors bg-white/20 backdrop-blur-sm rounded-full px-4 py-2 border border-white/30" 
        >
          Maintenance
        </a>
      </div>
      <div class="relative inline-block">
        <button 
          class="flex items-center gap-2 text-sm text-white/70 hover:text-white transition-colors bg-white/20 backdrop-blur-sm rounded-full px-4 py-2 border border-white/30" 
          aria-expanded="false" 
          aria-haspopup="true"
          id="service-btn"
        >
          Services
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="transition-transform duration-200">
            <path d="M3 5L7 9L11 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div 
          class="absolute top-full left-1/2 -translate-x-1/2 mt-2 bg-white rounded-2xl shadow-xl py-6 min-w-[800px] opacity-0 invisible transition-all duration-200 z-50" 
          role="menu"
          id="dropdown-menu"
        >
          <div class="grid grid-cols-4 gap-6 p-6">
            <div>
              <a href="/commercial" class="flex items-center gap-2 mb-4 no-underline group">
                <div class="w-8 h-8 bg-brand-secondary/20 rounded-full flex items-center justify-center group-hover:bg-brand-secondary/30 transition-colors duration-300">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="text-brand-secondary">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2" stroke="currentColor" stroke-width="2"/>
                    <circle cx="9" cy="9" r="2" stroke="currentColor" stroke-width="2"/>
                  </svg>
                </div>
                <h4 class="text-sm font-asap-condensed uppercase tracking-wide font-bold text-gray-900 group-hover:text-[#2d7c6f] transition-colors duration-300">Commercial</h4>
              </a>
              <div class="space-y-2">
                <a href="/services/ground-up-construction" class="block px-3 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">Ground-up Construction</a>
                <a href="/services/emergency-standby-power" class="block px-3 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">Emergency & Standby Power</a>
                <a href="/services/commercial-hvac-electrical" class="block px-3 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">Commercial HVAC</a>
                <a href="/services/commercial-electrical-panels" class="block px-3 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">Electrical Panels</a>
              </div>
            </div>

            <div>
              <a href="/services/residential" class="flex items-center gap-2 mb-4 no-underline group">
                <div class="w-8 h-8 bg-brand-primary/20 rounded-full flex items-center justify-center group-hover:bg-brand-primary/30 transition-colors duration-300">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="text-brand-primary">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" stroke="currentColor" stroke-width="2"/>
                    <polyline points="9,22 9,12 15,12 15,22" stroke="currentColor" stroke-width="2"/>
                  </svg>
                </div>
                <h4 class="text-sm font-asap-condensed uppercase tracking-wide font-bold text-gray-900 group-hover:text-[#98d9a1] transition-colors duration-300">Residential</h4>
              </a>
              <div class="space-y-2">
                <a href="/services/car-charging-stations" class="block px-3 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">EV Charging Stations</a>
                <a href="/services/ceiling-fan" class="block px-3 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">Ceiling Fan Installation</a>
                <a href="/services/gfci-outlets" class="block px-3 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">GFCI Outlets</a>
                <a href="/services/backup-generators" class="block px-3 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">Backup Generators</a>
              </div>
            </div>

            <div>
              <a href="/services/specialty" class="flex items-center gap-2 mb-4 no-underline group">
                <div class="w-8 h-8 bg-brand-accent/20 rounded-full flex items-center justify-center group-hover:bg-brand-accent/30 transition-colors duration-300">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="text-brand-accent">
                    <path d="M12 2L13.09 8.26L20 9L13.09 9.74L12 16L10.91 9.74L4 9L10.91 8.26L12 2Z" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <h4 class="text-sm font-asap-condensed uppercase tracking-wide font-bold text-gray-900 group-hover:text-[#61c4c5] transition-colors duration-300">Specialty</h4>
              </a>
              <div class="space-y-2">
                <a href="/services/holiday-lighting" class="block px-3 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">Holiday Lighting</a>
                <a href="/services/landscape-lighting" class="block px-3 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">Landscape Lighting</a>
                <a href="/services/pool-spa-electrical" class="block px-3 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">Pool & Spa Electrical</a>
                <a href="/services/property-management" class="block px-3 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">Property Management</a>
              </div>
            </div>

            <div>
              <a href="/services/emergency" class="flex items-center gap-2 mb-4 no-underline group">
                <div class="w-8 h-8 bg-red-500/20 rounded-full flex items-center justify-center group-hover:bg-red-500/30 transition-colors duration-300">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="text-red-600">
                    <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <h4 class="text-sm font-asap-condensed uppercase tracking-wide font-bold text-gray-900 group-hover:text-red-600 transition-colors duration-300">Emergency</h4>
              </a>
              <div class="space-y-2">
                <a href="/services/24-hour-emergency" class="block px-3 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">24-hour Emergency</a>
                <a href="/services/hvac-emergency" class="block px-3 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">HVAC Emergency</a>
                <a href="/services/heating-emergency" class="block px-3 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">Heating Emergency</a>
                <a href="/services/water-heater-emergency" class="block px-3 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">Water Heater Emergency</a>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="relative inline-block">
        <a 
          href="/financing"
          class="flex items-center gap-2 text-sm text-white/70 hover:text-white transition-colors bg-white/20 backdrop-blur-sm rounded-full px-4 py-2 border border-white/30" 
        >
          Financing
        </a>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="md:hidden bg-white/95 backdrop-blur-md border-t border-white/20 opacity-0 invisible transition-all duration-300 absolute top-full left-0 right-0 max-h-[calc(100vh-80px)] overflow-y-auto" id="mobile-menu">
    <div class="px-6 py-4 space-y-2">
      {navLinks.filter(link => link.label !== "Service Areas").map((link) => (
