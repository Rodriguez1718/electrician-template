  // Navbar scroll behavior
  function updateNavbar() {
    var scrollY = window.scrollY;

    if (window.innerWidth >= 1024) {
      var servicesLayer = document.getElementById("services-layer");
      var navbarLogo = document.getElementById("navbar-logo");
      var navbarCta = document.getElementById("navbar-cta");
      var navContainer = document.getElementById("nav-container");

      if (scrollY > 50) {
        navContainer.style.paddingLeft = "10rem";
        navContainer.style.paddingRight = "10rem";
        navbarLogo.style.transform = window.innerWidth >= 1440 ? "translateX(340px)" : "translateX(220px)";
        navbarCta.style.transform = window.innerWidth >= 1440 ? "translateX(-340px)" : "translateX(-220px)";
        navbarLogo.style.color = "#1f2937";
        navbarLogo.style.fontSize = "1rem";
      } else {
        navContainer.style.paddingLeft = "1.5rem";
        navContainer.style.paddingRight = "1.5rem";
        navbarLogo.style.transform = "translateX(0)";
        navbarLogo.style.color = "#ffffff";
        navbarLogo.style.fontSize = "1.25rem";
        navbarCta.style.transform = "translateX(0)";
      }
    } else {
      var mobileNavbar = document.getElementById("mobile-navbar");
      var mobileLogo = document.getElementById("mobile-logo");
      var mobileBtn = document.getElementById("mobile-menu-btn");

      if (scrollY > 50) {
        mobileNavbar.style.backgroundColor = "rgba(255, 255, 255, 0.95)";
        mobileNavbar.style.backdropFilter = "blur(12px)";
        mobileNavbar.style.borderBottom = "1px solid rgba(0, 0, 0, 0.1)";
        if (mobileLogo) mobileLogo.style.color = "#000000";
        if (mobileBtn) mobileBtn.style.color = "#000000";
      } else {
        mobileNavbar.style.backgroundColor = "transparent";
        mobileNavbar.style.backdropFilter = "none";
        mobileNavbar.style.borderBottom = "none";
        if (mobileLogo) mobileLogo.style.color = "#ffffff";
        if (mobileBtn) mobileBtn.style.color = "#ffffff";
      }
    }
  }

  updateNavbar();
  window.addEventListener("scroll", updateNavbar, { passive: true });

  // Debounced resize listener
  var resizeTimer;
  window.addEventListener("resize", function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function() {
      var navbarLogo = document.getElementById("navbar-logo");
      var navbarCta = document.getElementById("navbar-cta");
      var navContainer = document.getElementById("nav-container");
      var mobileNavbar = document.getElementById("mobile-navbar");
      var mobileLogo = document.getElementById("mobile-logo");
      var mobileBtn = document.getElementById("mobile-menu-btn");

      if (window.innerWidth < 1024) {
        if (navbarLogo) { navbarLogo.style.transform = "translateX(0)"; navbarLogo.style.color = "#ffffff"; navbarLogo.style.fontSize = "1.25rem"; }
        if (navbarCta) navbarCta.style.transform = "translateX(0)";
        if (navContainer) { navContainer.style.paddingLeft = "1.5rem"; navContainer.style.paddingRight = "1.5rem"; }
      } else {
        if (mobileNavbar) { mobileNavbar.style.backgroundColor = "transparent"; mobileNavbar.style.backdropFilter = "none"; mobileNavbar.style.borderBottom = "none"; }
        if (mobileLogo) mobileLogo.style.color = "#ffffff";
        if (mobileBtn) mobileBtn.style.color = "#ffffff";
      }

      updateNavbar();
    }, 100);
  });
</script>

