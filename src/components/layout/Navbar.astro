---
import Button from "../ui/Button.astro";
import { getCollection } from 'astro:content';

const navLinks = [
  { label: "Home", href: "/" },
  { label: "About", href: "/about" },
  { label: "Contact", href: "/contact" },
  { label: "Service Areas", href: "/service-area" },
];

const currentPath = Astro.url.pathname;

// Fetch service areas for dropdown with error handling
let primaryServiceAreas: Awaited<ReturnType<typeof getCollection<'service-areas'>>> = [];
try {
  const serviceAreas = await getCollection('service-areas');
  primaryServiceAreas = serviceAreas
    .filter(area => area.data.tier === 'primary')
    .slice(0, 4); // Show top 4 in navbar
} catch (error) {
  console.error('Error loading service areas:', error);
  // Fallback to empty array if collection doesn't exist yet
}
---

<nav class="fixed top-0 left-0 right-0 z-50 transition-all duration-500" id="navbar">
  <!-- Desktop navbar (1024px+) -->
  <div class="hidden lg:block px-6 py-4 relative">
    <div class="flex items-center justify-between max-w-7xl mx-auto">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 text-xl font-asap-condensed font-bold text-white no-underline transition-all duration-500 ease-out relative z-20" id="navbar-logo">
        <img src="/voltbully1.webp" alt="VoltBully Logo" class="w-10 h-10 object-contain" fetchpriority="high" />
        VOLTBULLY
      </a>

      <!-- Center container -->
      <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 flex items-center bg-white/80 backdrop-blur-md rounded-full px-6 py-2 shadow-lg border border-white/20 transition-all duration-500 ease-out" id="nav-container">
        <div class="flex items-center">
          {navLinks.map((link) => {
            if (link.label === "Service Areas") {
              return (
                <div class="relative inline-block" id="desktop-service-areas-wrapper">
                  <a 
                    href={link.href}
                    class:list={[
                      "flex items-center gap-1 px-4 py-2 text-sm font-medium no-underline transition-colors rounded-full",
                      { 
                        "text-[var(--color-accent)] bg-blue-50": currentPath === link.href,
                        "text-gray-700 hover:text-gray-900 hover:bg-gray-50": currentPath !== link.href
                      }
                    ]}
                    aria-expanded="false" 
                    aria-haspopup="true"
                    id="desktop-service-areas-btn"
                  >
                    {link.label}
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="transition-transform duration-200">
                      <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                </div>
              );
            } else {
              return (
                <a
                  href={link.href}
                  class:list={[
                    "px-4 py-2 text-sm font-medium no-underline transition-colors rounded-full",
                    { 
                      "text-[var(--color-accent)] bg-blue-50": currentPath === link.href,
                      "text-gray-700 hover:text-gray-900 hover:bg-gray-50": currentPath !== link.href
                    }
                  ]}
                >
                  {link.label}
                </a>
              );
            }
          })}
        </div>
      </div>

      <!-- CTA Button -->
      <div class="z-60">
        <Button href="/contact" variant="tertiary" id="navbar-cta" class="transition-all duration-500 ease-out relative z-20">
          BOOK NOW
        </Button>
      </div>
    </div>

    <!-- Service areas dropdown -->
    <div 
      class="fixed bg-white rounded-lg shadow-xl py-2 min-w-[160px] opacity-0 invisible transition-all duration-200 z-[999]" 
      role="menu"
      id="desktop-service-areas-menu"
    >
      {primaryServiceAreas.map((area) => (
        <a 
          href={`/service-areas/${area.id}`}
          class="block px-4 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline transition-colors" 
          role="menuitem"
        >
          {area.data.city}
        </a>
      ))}
    </div>
  </div>

  <!-- Tablet navbar (768px-1024px) -->
  <div class="hidden md:block lg:hidden px-4 py-4">
    <div class="flex items-center justify-between max-w-5xl mx-auto">
      <a href="/" class="flex items-center gap-2 text-lg font-asap-condensed font-bold text-white no-underline">
        <img src="/voltbully1.webp" alt="VoltBully Logo" class="w-7 h-7 object-contain" fetchpriority="high" />
        VOLTBULLY
      </a>

      <div class="flex items-center bg-white/80 backdrop-blur-md rounded-full px-4 py-2 shadow-lg border border-white/20">
        {navLinks.map((link) => {
          if (link.label === "Service Areas") {
            return (
