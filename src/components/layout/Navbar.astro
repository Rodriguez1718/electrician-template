          <div>
            <a href="/services/emergency" class="flex items-center gap-2 mb-2 no-underline group">
              <div class="w-5 h-5 bg-red-500/20 rounded-full flex items-center justify-center">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" class="text-red-600">
                  <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <h4 class="text-xs font-asap-condensed uppercase tracking-wide font-bold text-gray-900">Emergency</h4>
            </a>
            <div class="space-y-1">
              <a href="/services/24-hour-emergency" class="block px-2 py-1.5 text-xs text-gray-600 hover:text-gray-900 no-underline rounded-lg hover:bg-gray-50 transition-colors font-helvetica">24-hour Emergency Service</a>
              <a href="/services/hvac-emergency" class="block px-2 py-1.5 text-xs text-gray-600 hover:text-gray-900 no-underline rounded-lg hover:bg-gray-50 transition-colors font-helvetica">HVAC</a>
              <a href="/services/heating-emergency" class="block px-2 py-1.5 text-xs text-gray-600 hover:text-gray-900 no-underline rounded-lg hover:bg-gray-50 transition-colors font-helvetica">Heating</a>
              <a href="/services/water-heater-emergency" class="block px-2 py-1.5 text-xs text-gray-600 hover:text-gray-900 no-underline rounded-lg hover:bg-gray-50 transition-colors font-helvetica">Water Heater</a>
            </div>
          </div>
        </div>
      </div>
      
      <Button href="/contact" variant="primary" id="navbar-cta" class="transition-all duration-500 ease-out relative z-20">
        Book Now
      </Button>
    </div>
  </div>
</nav>

<script is:inline>
  // Desktop Services dropdown - hover
  var serviceBtn = document.getElementById("service-btn");
  var dropdownMenu = document.getElementById("dropdown-menu");
  var servicesContainer = serviceBtn && serviceBtn.parentElement;
  var svg = serviceBtn && serviceBtn.querySelector("svg");
  var hoverTimeout;

  if (servicesContainer) {
    servicesContainer.addEventListener("mouseenter", function() {
      clearTimeout(hoverTimeout);
      dropdownMenu.classList.remove("opacity-0", "invisible");
      dropdownMenu.classList.add("opacity-100", "visible");
      svg.classList.add("rotate-180");
      serviceBtn.setAttribute("aria-expanded", "true");
    });
    servicesContainer.addEventListener("mouseleave", function() {
      hoverTimeout = setTimeout(function() {
        dropdownMenu.classList.remove("opacity-100", "visible");
        dropdownMenu.classList.add("opacity-0", "invisible");
        svg.classList.remove("rotate-180");
        serviceBtn.setAttribute("aria-expanded", "false");
      }, 150);
    });
  }

  if (dropdownMenu) {
    dropdownMenu.addEventListener("mouseenter", function() { clearTimeout(hoverTimeout); });
    dropdownMenu.addEventListener("mouseleave", function() {
      hoverTimeout = setTimeout(function() {
        dropdownMenu.classList.remove("opacity-100", "visible");
        dropdownMenu.classList.add("opacity-0", "invisible");
        svg.classList.remove("rotate-180");
        serviceBtn.setAttribute("aria-expanded", "false");
      }, 150);
    });
  }

  // Tablet Services dropdown - hover
  var tabletServiceBtn = document.getElementById("tablet-service-btn");
  var tabletDropdownMenu = document.getElementById("tablet-dropdown-menu");
  var tabletServicesContainer = tabletServiceBtn && tabletServiceBtn.parentElement;
  var tabletSvg = tabletServiceBtn && tabletServiceBtn.querySelector("svg");
  var tabletHoverTimeout;

  if (tabletServicesContainer) {
    tabletServicesContainer.addEventListener("mouseenter", function() {
      clearTimeout(tabletHoverTimeout);
      tabletDropdownMenu.classList.remove("opacity-0", "invisible");
      tabletDropdownMenu.classList.add("opacity-100", "visible");
      tabletSvg.classList.add("rotate-180");
      tabletServiceBtn.setAttribute("aria-expanded", "true");
    });
    tabletServicesContainer.addEventListener("mouseleave", function() {
      tabletHoverTimeout = setTimeout(function() {
        tabletDropdownMenu.classList.remove("opacity-100", "visible");
        tabletDropdownMenu.classList.add("opacity-0", "invisible");
        tabletSvg.classList.remove("rotate-180");
        tabletServiceBtn.setAttribute("aria-expanded", "false");
      }, 150);
    });
  }

  if (tabletDropdownMenu) {
    tabletDropdownMenu.addEventListener("mouseenter", function() { clearTimeout(tabletHoverTimeout); });
    tabletDropdownMenu.addEventListener("mouseleave", function() {
      tabletHoverTimeout = setTimeout(function() {
        tabletDropdownMenu.classList.remove("opacity-100", "visible");
        tabletDropdownMenu.classList.add("opacity-0", "invisible");
        tabletSvg.classList.remove("rotate-180");
        tabletServiceBtn.setAttribute("aria-expanded", "false");
      }, 150);
    });
  }

  // Mobile menu
  var mobileMenuBtn = document.getElementById("mobile-menu-btn");
  var mobileMenu = document.getElementById("mobile-menu");
  var burgerIcon = document.getElementById("burger-icon");
  var closeIcon = document.getElementById("close-icon");

  if (mobileMenuBtn) {
    mobileMenuBtn.addEventListener("click", function() {
      var isOpen = mobileMenu.classList.contains("opacity-100");
      if (isOpen) {
        mobileMenu.classList.remove("opacity-100", "visible");
        mobileMenu.classList.add("opacity-0", "invisible");
        burgerIcon.classList.remove("hidden");
        closeIcon.classList.add("hidden");
        mobileMenuBtn.setAttribute("aria-expanded", "false");
      } else {
        mobileMenu.classList.remove("opacity-0", "invisible");
        mobileMenu.classList.add("opacity-100", "visible");
        burgerIcon.classList.add("hidden");
        closeIcon.classList.remove("hidden");
        mobileMenuBtn.setAttribute("aria-expanded", "true");
      }
    });
  }

  // Mobile services dropdown
  var mobileServiceBtn = document.getElementById("mobile-service-btn");
  var mobileServicesDropdown = document.getElementById("mobile-services-dropdown");
  var mobileServiceSvg = mobileServiceBtn && mobileServiceBtn.querySelector("svg");

  if (mobileServiceBtn) {
    mobileServiceBtn.addEventListener("click", function() {
      var isOpen = mobileServicesDropdown.classList.contains("opacity-100");
      if (isOpen) {
        mobileServicesDropdown.style.maxHeight = "0px";
        mobileServicesDropdown.classList.remove("opacity-100", "visible");
        mobileServicesDropdown.classList.add("opacity-0", "invisible", "max-h-0");
        mobileServiceSvg.classList.remove("rotate-180");
      } else {
        mobileServicesDropdown.classList.remove("opacity-0", "invisible", "max-h-0");
        mobileServicesDropdown.classList.add("opacity-100", "visible");
        mobileServicesDropdown.style.maxHeight = mobileServicesDropdown.scrollHeight + "px";
        mobileServiceSvg.classList.add("rotate-180");
      }
    });
  }

  // Mobile service areas dropdown
  var mobileServiceAreasBtn = document.getElementById("mobile-service-areas-btn");
  var mobileServiceAreasDropdown = document.getElementById("mobile-service-areas-dropdown");
  var mobileServiceAreasSvg = mobileServiceAreasBtn && mobileServiceAreasBtn.querySelector("svg");

  if (mobileServiceAreasBtn) {
    mobileServiceAreasBtn.addEventListener("click", function() {
      var isOpen = mobileServiceAreasDropdown.classList.contains("opacity-100");
      if (isOpen) {
        mobileServiceAreasDropdown.style.maxHeight = "0px";
        mobileServiceAreasDropdown.classList.remove("opacity-100", "visible");
        mobileServiceAreasDropdown.classList.add("opacity-0", "invisible", "max-h-0");
        mobileServiceAreasSvg.classList.remove("rotate-180");
      } else {
        mobileServiceAreasDropdown.classList.remove("opacity-0", "invisible", "max-h-0");
        mobileServiceAreasDropdown.classList.add("opacity-100", "visible");
        mobileServiceAreasDropdown.style.maxHeight = mobileServiceAreasDropdown.scrollHeight + "px";
        mobileServiceAreasSvg.classList.add("rotate-180");
      }
    });
  }

  // Desktop Service Areas dropdown - hover
  var desktopServiceAreasBtn = document.getElementById("desktop-service-areas-btn");
  var desktopServiceAreasMenu = document.getElementById("desktop-service-areas-menu");
  var desktopServiceAreasSvg = desktopServiceAreasBtn && desktopServiceAreasBtn.querySelector("svg");
  var desktopServiceAreasContainer = desktopServiceAreasBtn && desktopServiceAreasBtn.parentElement;
  var desktopServiceAreasTimeout;

  function positionDesktopServiceAreasDropdown() {
    if (desktopServiceAreasBtn && desktopServiceAreasMenu) {
      var buttonRect = desktopServiceAreasBtn.getBoundingClientRect();
      desktopServiceAreasMenu.style.left = (buttonRect.left + buttonRect.width / 2) + "px";
      desktopServiceAreasMenu.style.top = (buttonRect.bottom + 8) + "px";
      desktopServiceAreasMenu.style.transform = "translateX(-50%)";
    }
  }

  function showDesktopServiceAreasDropdown() {
    clearTimeout(desktopServiceAreasTimeout);
    positionDesktopServiceAreasDropdown();
    desktopServiceAreasMenu.classList.remove("opacity-0", "invisible");
    desktopServiceAreasMenu.classList.add("opacity-100", "visible");
    desktopServiceAreasSvg.classList.add("rotate-180");
    desktopServiceAreasBtn.setAttribute("aria-expanded", "true");
  }

  function hideDesktopServiceAreasDropdown() {
    desktopServiceAreasTimeout = setTimeout(function() {
      desktopServiceAreasMenu.classList.remove("opacity-100", "visible");
      desktopServiceAreasMenu.classList.add("opacity-0", "invisible");
      desktopServiceAreasSvg.classList.remove("rotate-180");
      desktopServiceAreasBtn.setAttribute("aria-expanded", "false");
    }, 150);
  }

  if (desktopServiceAreasContainer) {
    desktopServiceAreasContainer.addEventListener("mouseenter", showDesktopServiceAreasDropdown);
    desktopServiceAreasContainer.addEventListener("mouseleave", hideDesktopServiceAreasDropdown);
  }
  if (desktopServiceAreasMenu) {
    desktopServiceAreasMenu.addEventListener("mouseenter", function() { clearTimeout(desktopServiceAreasTimeout); });
    desktopServiceAreasMenu.addEventListener("mouseleave", hideDesktopServiceAreasDropdown);
  }

  // Tablet Service Areas dropdown - hover
  var tabletServiceAreasBtn = document.getElementById("tablet-service-areas-btn");
  var tabletServiceAreasMenu = document.getElementById("tablet-service-areas-menu");
  var tabletServiceAreasSvg = tabletServiceAreasBtn && tabletServiceAreasBtn.querySelector("svg");
  var tabletServiceAreasContainer = tabletServiceAreasBtn && tabletServiceAreasBtn.parentElement;
  var tabletServiceAreasTimeout;

  function positionTabletServiceAreasDropdown() {
    if (tabletServiceAreasBtn && tabletServiceAreasMenu) {
      var buttonRect = tabletServiceAreasBtn.getBoundingClientRect();
      tabletServiceAreasMenu.style.left = (buttonRect.left + buttonRect.width / 2) + "px";
      tabletServiceAreasMenu.style.top = (buttonRect.bottom + 8) + "px";
      tabletServiceAreasMenu.style.transform = "translateX(-50%)";
    }
  }

  function showTabletServiceAreasDropdown() {
    clearTimeout(tabletServiceAreasTimeout);
    positionTabletServiceAreasDropdown();
    tabletServiceAreasMenu.classList.remove("opacity-0", "invisible");
    tabletServiceAreasMenu.classList.add("opacity-100", "visible");
    tabletServiceAreasSvg.classList.add("rotate-180");
    tabletServiceAreasBtn.setAttribute("aria-expanded", "true");
  }

  function hideTabletServiceAreasDropdown() {
    tabletServiceAreasTimeout = setTimeout(function() {
      tabletServiceAreasMenu.classList.remove("opacity-100", "visible");
      tabletServiceAreasMenu.classList.add("opacity-0", "invisible");
      tabletServiceAreasSvg.classList.remove("rotate-180");
      tabletServiceAreasBtn.setAttribute("aria-expanded", "false");
    }, 150);
  }

  if (tabletServiceAreasContainer) {
    tabletServiceAreasContainer.addEventListener("mouseenter", showTabletServiceAreasDropdown);
    tabletServiceAreasContainer.addEventListener("mouseleave", hideTabletServiceAreasDropdown);
  }
  if (tabletServiceAreasMenu) {
    tabletServiceAreasMenu.addEventListener("mouseenter", function() { clearTimeout(tabletServiceAreasTimeout); });
    tabletServiceAreasMenu.addEventListener("mouseleave", hideTabletServiceAreasDropdown);
  }

  // Navbar scroll behavior
  function updateNavbar() {
    var scrollY = window.scrollY;

    if (window.innerWidth >= 1024) {
      var servicesLayer = document.getElementById("services-layer");
      var navbarLogo = document.getElementById("navbar-logo");
      var navbarCta = document.getElementById("navbar-cta");
      var navContainer = document.getElementById("nav-container");

      if (scrollY > 50) {
        servicesLayer.classList.add("opacity-0", "invisible", "h-0", "pb-0");
        navContainer.style.paddingLeft = "10rem";
        navContainer.style.paddingRight = "10rem";
        navbarLogo.style.transform = window.innerWidth >= 1440 ? "translateX(340px)" : "translateX(220px)";
        navbarCta.style.transform = window.innerWidth >= 1440 ? "translateX(-340px)" : "translateX(-220px)";
        navbarLogo.style.color = "#1f2937";
        navbarLogo.style.fontSize = "1rem";
      } else {
        servicesLayer.classList.remove("opacity-0", "invisible", "h-0", "pb-0");
        navContainer.style.paddingLeft = "1.5rem";
        navContainer.style.paddingRight = "1.5rem";
        navbarLogo.style.transform = "translateX(0)";
        navbarLogo.style.color = "#ffffff";
        navbarLogo.style.fontSize = "1.25rem";
        navbarCta.style.transform = "translateX(0)";
      }
    } else {
      var mobileNavbar = document.getElementById("mobile-navbar");
      var mobileLogo = document.getElementById("mobile-logo");
      var mobileBtn = document.getElementById("mobile-menu-btn");

      if (scrollY > 50) {
        mobileNavbar.style.backgroundColor = "rgba(255, 255, 255, 0.95)";
        mobileNavbar.style.backdropFilter = "blur(12px)";
        mobileNavbar.style.borderBottom = "1px solid rgba(0, 0, 0, 0.1)";
        if (mobileLogo) mobileLogo.style.color = "#000000";
        if (mobileBtn) mobileBtn.style.color = "#000000";
      } else {
        mobileNavbar.style.backgroundColor = "transparent";
        mobileNavbar.style.backdropFilter = "none";
        mobileNavbar.style.borderBottom = "none";
        if (mobileLogo) mobileLogo.style.color = "#ffffff";
        if (mobileBtn) mobileBtn.style.color = "#ffffff";
      }
    }
  }

  updateNavbar();
  window.addEventListener("scroll", updateNavbar, { passive: true });

  // Debounced resize listener
  var resizeTimer;
  window.addEventListener("resize", function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function() {
      var navbarLogo = document.getElementById("navbar-logo");
      var navbarCta = document.getElementById("navbar-cta");
      var navContainer = document.getElementById("nav-container");
      var mobileNavbar = document.getElementById("mobile-navbar");
      var mobileLogo = document.getElementById("mobile-logo");
      var mobileBtn = document.getElementById("mobile-menu-btn");

      if (window.innerWidth < 1024) {
        if (navbarLogo) { navbarLogo.style.transform = "translateX(0)"; navbarLogo.style.color = "#ffffff"; navbarLogo.style.fontSize = "1.25rem"; }
        if (navbarCta) navbarCta.style.transform = "translateX(0)";
        if (navContainer) { navContainer.style.paddingLeft = "1.5rem"; navContainer.style.paddingRight = "1.5rem"; }
      } else {
        if (mobileNavbar) { mobileNavbar.style.backgroundColor = "transparent"; mobileNavbar.style.backdropFilter = "none"; mobileNavbar.style.borderBottom = "none"; }
        if (mobileLogo) mobileLogo.style.color = "#ffffff";
        if (mobileBtn) mobileBtn.style.color = "#ffffff";
      }

      updateNavbar();
    }, 100);
  });
</script>

<style>
  nav a,
  nav button {
    cursor: none;
  }
</style>