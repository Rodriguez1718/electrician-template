                </svg>
              </div>
              <h4 class="text-xs font-asap-condensed uppercase tracking-wide font-bold text-gray-900">Commercial</h4>
            </a>
            <div class="space-y-1">
              <a href="/services/ground-up-construction" class="block px-2 py-1.5 text-xs text-gray-600 hover:text-gray-900 no-underline rounded-lg hover:bg-gray-50 transition-colors font-helvetica">Ground-up Electrical Construction</a>
              <a href="/services/emergency-standby-power" class="block px-2 py-1.5 text-xs text-gray-600 hover:text-gray-900 no-underline rounded-lg hover:bg-gray-50 transition-colors font-helvetica">Emergency & Standby Power Systems</a>
              <a href="/services/commercial-hvac-electrical" class="block px-2 py-1.5 text-xs text-gray-600 hover:text-gray-900 no-underline rounded-lg hover:bg-gray-50 transition-colors font-helvetica">Commercial HVAC Electrical</a>
              <a href="/services/commercial-electrical-panels" class="block px-2 py-1.5 text-xs text-gray-600 hover:text-gray-900 no-underline rounded-lg hover:bg-gray-50 transition-colors font-helvetica">Commercial Electrical Panels</a>
            </div>
          </div>

          <div class="mb-4">
            <a href="/services/residential" class="flex items-center gap-2 mb-2 no-underline group">
              <div class="w-5 h-5 bg-brand-primary/20 rounded-full flex items-center justify-center">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" class="text-brand-primary">
                  <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" stroke="currentColor" stroke-width="2"/>
                  <polyline points="9,22 9,12 15,12 15,22" stroke="currentColor" stroke-width="2"/>
