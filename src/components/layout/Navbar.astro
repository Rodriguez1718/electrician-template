            <!-- Emergency -->
            <div>
              <a href="/services/emergency" class="flex items-center gap-2 mb-4 no-underline group">
                <div class="w-8 h-8 bg-red-500/20 rounded-full flex items-center justify-center group-hover:bg-red-500/30 transition-colors duration-300">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="text-red-600">
                    <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <h3 class="text-sm font-asap-condensed uppercase tracking-wide font-bold text-gray-900 group-hover:text-red-600 transition-colors duration-300">Emergency</h3>
              </a>
              <div class="space-y-2">
                <a href="/services/24-hour-emergency" class="block px-3 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">
                  24-hour Emergency
                </a>
                <a href="/services/hvac-emergency" class="block px-3 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">
                  HVAC Emergency
                </a>
                <a href="/services/heating-emergency" class="block px-3 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">
                  Heating Emergency
                </a>
                <a href="/services/water-heater-emergency" class="block px-3 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline rounded-lg transition-colors font-helvetica" role="menuitem">
                  Water Heater Emergency
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="md:hidden bg-white/95 backdrop-blur-md border-t border-white/20 opacity-0 invisible transition-all duration-300 absolute top-full left-0 right-0" id="mobile-menu">
    <div class="px-6 py-4 space-y-2">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "block px-4 py-3 text-base font-medium no-underline transition-colors rounded-lg",
            { 
              "text-blue-600 bg-blue-50": currentPath === link.href,
              "text-gray-700 hover:text-gray-900 hover:bg-gray-50": currentPath !== link.href
            }
          ]}
        >
          {link.label}
        </a>
      ))}
      
      <!-- Services in mobile menu -->
      <div class="pt-2 border-t border-gray-200">
        <button 
          class="flex items-center justify-between w-full px-4 py-3 text-base font-medium text-gray-700 hover:text-gray-900 hover:bg-gray-50 rounded-lg transition-colors" 
          id="mobile-service-btn"
        >
          Services
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="transition-transform duration-200">
            <path d="M3 5L7 9L11 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="pl-4 opacity-0 invisible transition-all duration-200" id="mobile-services-dropdown">
          <!-- Commercial Electrical Services -->
          <div class="mb-4">
            <a href="/commercial" class="flex items-center gap-2 mb-2 no-underline group">
              <div class="w-5 h-5 bg-brand-secondary/20 rounded-full flex items-center justify-center group-hover:bg-brand-secondary/30 transition-colors duration-300">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" class="text-brand-secondary">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2" stroke="currentColor" stroke-width="2"/>
                  <circle cx="9" cy="9" r="2" stroke="currentColor" stroke-width="2"/>
                </svg>
              </div>
              <h4 class="text-xs font-asap-condensed uppercase tracking-wide font-bold text-gray-900 group-hover:text-brand-secondary transition-colors duration-300">Commercial</h4>
            </a>
            <div class="space-y-1">
              <a href="/services/ground-up-construction" class="block px-2 py-1.5 text-xs text-gray-600 hover:text-gray-900 no-underline rounded-lg hover:bg-gray-50 transition-colors font-helvetica">
                Ground-up Electrical Construction
              </a>
              <a href="/services/emergency-standby-power" class="block px-2 py-1.5 text-xs text-gray-600 hover:text-gray-900 no-underline rounded-lg hover:bg-gray-50 transition-colors font-helvetica">
                Emergency & Standby Power Systems
              </a>
              <a href="/services/commercial-hvac-electrical" class="block px-2 py-1.5 text-xs text-gray-600 hover:text-gray-900 no-underline rounded-lg hover:bg-gray-50 transition-colors font-helvetica">
                Commercial HVAC Electrical
              </a>
              <a href="/services/commercial-electrical-panels" class="block px-2 py-1.5 text-xs text-gray-600 hover:text-gray-900 no-underline rounded-lg hover:bg-gray-50 transition-colors font-helvetica">
                Commercial Electrical Panels
              </a>
            </div>
          </div>

          <!-- Residential Electrical Services -->
          <div class="mb-4">
            <a href="/services/residential" class="flex items-center gap-2 mb-2 no-underline group">
              <div class="w-5 h-5 bg-brand-primary/20 rounded-full flex items-center justify-center group-hover:bg-brand-primary/30 transition-colors duration-300">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" class="text-brand-primary">
                  <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" stroke="currentColor" stroke-width="2"/>
                  <polyline points="9,22 9,12 15,12 15,22" stroke="currentColor" stroke-width="2"/>
