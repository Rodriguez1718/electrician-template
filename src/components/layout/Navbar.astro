              <a href="/services/landscape-lighting" class="block px-2 py-1.5 text-xs text-gray-600 hover:text-gray-900 no-underline rounded-lg hover:bg-gray-50 transition-colors font-helvetica">Landscape Lighting</a>
              <a href="/services/pool-spa-electrical" class="block px-2 py-1.5 text-xs text-gray-600 hover:text-gray-900 no-underline rounded-lg hover:bg-gray-50 transition-colors font-helvetica">Pool & Spa Electrical</a>
              <a href="/services/property-management" class="block px-2 py-1.5 text-xs text-gray-600 hover:text-gray-900 no-underline rounded-lg hover:bg-gray-50 transition-colors font-helvetica">Property Management</a>
