              <a href="/services/ceiling-fan" class="block px-2 py-1.5 text-xs text-gray-600 hover:text-gray-900 no-underline rounded-lg hover:bg-gray-50 transition-colors font-helvetica">Ceiling Fan</a>
              <a href="/services/gfci-outlets" class="block px-2 py-1.5 text-xs text-gray-600 hover:text-gray-900 no-underline rounded-lg hover:bg-gray-50 transition-colors font-helvetica">GFCI Outlets</a>
              <a href="/services/backup-generators" class="block px-2 py-1.5 text-xs text-gray-600 hover:text-gray-900 no-underline rounded-lg hover:bg-gray-50 transition-colors font-helvetica">Backup Generators</a>
