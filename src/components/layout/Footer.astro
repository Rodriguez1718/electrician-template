---
const currentYear = new Date().getFullYear();

const companyLinks = [
  { label: "Home", href: "/" },
  { label: "About us", href: "/about" },
  { label: "Service area", href: "/service-area" },
  { label: "Contact", href: "/contact" },
];

const serviceLinks = [
  { label: "Ground up electrical construction", href: "/services/ground-up-construction" },
  { label: "Tenant improvements", href: "/services/tenant-improvements" },
  { label: "Panel upgrades", href: "/services/panel-upgrades" },
  { label: "Lighting installation", href: "/services/lighting-installation" },
];

const workLinks = [
  { label: "Request a quote", href: "/quote" },
  { label: "Careers", href: "/careers" },
  { label: "Licensing & insurance", href: "/licensing" },
];
---

<footer class="bg-black text-white relative overflow-hidden border-t-4 border-brand-primary">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute top-10 left-10 w-32 h-32 border border-brand-primary rounded-full"></div>
    <div class="absolute top-40 right-20 w-24 h-24 border border-brand-accent rounded-full"></div>
    <div class="absolute bottom-20 left-1/4 w-16 h-16 border border-brand-secondary rounded-full"></div>
    <div class="absolute bottom-10 right-1/3 w-20 h-20 border border-brand-primary rounded-full"></div>
  </div>

  <!-- Gradient overlay for depth -->
  <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-transparent to-black/80"></div>

  <div class="relative z-10">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-[1.8fr_1fr_1fr_1fr] gap-8 p-8 pb-6">
      <!-- Company Info -->
      <div class="md:col-span-2 lg:col-span-1">
        <a href="/" class="flex items-center gap-3 text-xl font-asap-condensed uppercase font-bold text-white no-underline mb-4">
          <img src="/voltbully1.webp" alt="VoltBully Logo" class="w-12 h-12 object-contain" />
          <span><span class="text-emerald-500">VOLT</span><span class="text-white">BULLY</span></span>
        </a>
        <p class="text-white/80 font-helvetica leading-relaxed max-w-[280px] mb-6">
          Licensed commercial electricians serving the greater metro area. Built on quality, safety, and reliability.
        </p>
        
        <!-- Contact Info -->
        <div class="space-y-3">
          <a href="tel:5551234567" class="flex items-center gap-3 text-white/80 no-underline hover:text-brand-primary transition-colors duration-300 group">
            <div class="w-8 h-8 bg-brand-primary/20 rounded-full flex items-center justify-center group-hover:bg-brand-primary/30 transition-colors duration-300">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="text-brand-primary">
                <path d="M2 3.5C2 2.67 2.67 2 3.5 2h1.2c.33 0 .62.21.73.52l.7 1.95a.8.8 0 0 1-.18.84L5.3 6.06a6.5 6.5 0 0 0 2.64 2.64l.75-.65a.8.8 0 0 1 .84-.18l1.95.7c.31.11.52.4.52.73V10.5c0 .83-.67 1.5-1.5 1.5A8.5 8.5 0 0 1 2 3.5Z"
                  stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
              </svg>
            </div>
            <span class="font-helvetica">(555) 123-4567</span>
          </a>
          
          <a href="mailto:hello@voltbully.com" class="flex items-center gap-3 text-white/80 no-underline hover:text-brand-primary transition-colors duration-300 group">
            <div class="w-8 h-8 bg-brand-primary/20 rounded-full flex items-center justify-center group-hover:bg-brand-primary/30 transition-colors duration-300">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="text-brand-primary">
                <rect x="1.5" y="3" width="11" height="8" rx="1.5" stroke="currentColor" stroke-width="1.2"/>
                <path d="M1.5 4.5l5.5 3.5 5.5-3.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
              </svg>
            </div>
            <span class="font-helvetica">hello@voltbully.com</span>
          </a>
        </div>

        <!-- Social Media -->
        <div class="flex gap-3 mt-6">
          <!-- Facebook -->
          <a href="#" aria-label="Facebook" class="w-10 h-10 bg-white/10 rounded-full flex items-center justify-center text-white/70 hover:bg-brand-primary hover:text-white transition-all duration-300">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          
          <!-- X (Twitter) -->
          <a href="#" aria-label="X (Twitter)" class="w-10 h-10 bg-white/10 rounded-full flex items-center justify-center text-white/70 hover:bg-brand-primary hover:text-white transition-all duration-300">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          
          <!-- Instagram -->
          <a href="#" aria-label="Instagram" class="w-10 h-10 bg-white/10 rounded-full flex items-center justify-center text-white/70 hover:bg-brand-primary hover:text-white transition-all duration-300">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          
          <!-- LinkedIn -->
          <a href="#" aria-label="LinkedIn" class="w-10 h-10 bg-white/10 rounded-full flex items-center justify-center text-white/70 hover:bg-brand-primary hover:text-white transition-all duration-300">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          
          <!-- YouTube -->
          <a href="#" aria-label="YouTube" class="w-10 h-10 bg-white/10 rounded-full flex items-center justify-center text-white/70 hover:bg-brand-primary hover:text-white transition-all duration-300">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Company Links -->
      <div>
        <h4 class="text-sm font-asap-condensed uppercase tracking-wider font-bold mb-4 text-white">Company</h4>
        <ul class="list-none p-0 space-y-3">
          {companyLinks.map((link) => (
            <li>
              <a href={link.href} class="text-white/70 font-helvetica no-underline hover:text-brand-primary transition-colors duration-300">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services Links -->
      <div>
        <h4 class="text-sm font-asap-condensed uppercase tracking-wider font-bold mb-4 text-white">Services</h4>
        <ul class="list-none p-0 space-y-3">
          {serviceLinks.map((link) => (
            <li>
              <a href={link.href} class="text-white/70 font-helvetica no-underline hover:text-brand-primary transition-colors duration-300">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Work With Us Links -->
      <div>
        <h4 class="text-sm font-asap-condensed uppercase tracking-wider font-bold mb-4 text-white">Work with us</h4>
        <ul class="list-none p-0 space-y-3">
          {workLinks.map((link) => (
            <li>
              <a href={link.href} class="text-white/70 font-helvetica no-underline hover:text-brand-primary transition-colors duration-300">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-white/20 bg-black/50 backdrop-blur-sm">
      <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-between px-8 py-6 text-sm text-white/60 gap-4 sm:gap-0">
        <p class="font-helvetica">&copy; {currentYear} VoltBully Electrical. All rights reserved.</p>
        <div class="flex gap-6">
          <a href="/privacy" class="text-white/60 font-helvetica no-underline hover:text-brand-primary transition-colors duration-300">
            Privacy policy
          </a>
          <a href="/terms" class="text-white/60 font-helvetica no-underline hover:text-brand-primary transition-colors duration-300">
            Terms of service
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  /* Remove cursor pointer for custom cursor consistency */
  footer a,
  footer button {
    cursor: none;
  }
</style>