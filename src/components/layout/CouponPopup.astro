---
import Button from "../ui/Button.astro";
---

<!-- Popup Modal Overlay -->
<div id="coupon-popup-overlay" class="coupon-popup-overlay">
  <div id="coupon-popup-modal" class="coupon-popup-modal">
    <!-- Close Button -->
    <button id="coupon-close-btn" class="coupon-close-btn" aria-label="Close popup">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    <!-- Coupon Content -->
    <div class="coupon-content">
      <!-- Header -->
      <div class="coupon-header">
        <div class="coupon-badge">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
        </div>
        <h2 class="coupon-title">Special Offer!</h2>
        <p class="coupon-subtitle">Limited Time Only</p>
      </div>

      <!-- Coupon Card -->
      <div class="coupon-card">
        <!-- Decorative corner cuts -->
        <div class="corner-cut corner-tl"></div>
        <div class="corner-cut corner-tr"></div>
        <div class="corner-cut corner-bl"></div>
        <div class="corner-cut corner-br"></div>
        
        <!-- Perforated edges -->
        <div class="perforation perforation-left"></div>
        <div class="perforation perforation-right"></div>
        
        <div class="coupon-inner">
          <div class="discount-badge">
            $100 OFF
          </div>
          <h3 class="coupon-service">Your First Electrical Service</h3>
          <p class="coupon-description">
            Professional electrical services for your home or business. Quality work guaranteed.
          </p>
          <div class="coupon-terms">
            <p>✓ New customers only</p>
            <p>✓ Minimum $500 service</p>
            <p>✓ Code: VOLTBULLY100</p>
          </div>
        </div>
      </div>

      <!-- CTA Button -->
      <div class="coupon-cta">
        <Button variant="primary" size="lg" href="/contact" class="w-full">
          Claim Your Discount
        </Button>
        <p class="coupon-expires">Offer expires soon - Don't miss out!</p>
      </div>
    </div>
  </div>
</div>

<script>
  // Show popup after 3 seconds
  const showPopupDelay = 3000;
  
  // Check if user has already seen the popup in this session
  const hasSeenPopup = sessionStorage.getItem('couponPopupSeen');
  
  if (!hasSeenPopup) {
    setTimeout(() => {
      const overlay = document.getElementById('coupon-popup-overlay');
      if (overlay) {
        overlay.classList.add('show');
        document.body.style.overflow = 'hidden'; // Prevent scrolling
      }
    }, showPopupDelay);
  }
  
  // Close popup function
  function closePopup() {
    const overlay = document.getElementById('coupon-popup-overlay');
    if (overlay) {
      overlay.classList.remove('show');
      document.body.style.overflow = ''; // Restore scrolling
      sessionStorage.setItem('couponPopupSeen', 'true');
    }
  }
  
  // Close button click
  const closeBtn = document.getElementById('coupon-close-btn');
  if (closeBtn) {
    closeBtn.addEventListener('click', closePopup);
  }
  
  // Close on overlay click (outside modal)
  const overlay = document.getElementById('coupon-popup-overlay');
  if (overlay) {
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) {
        closePopup();
      }
    });
  }
  
  // Close on ESC key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closePopup();
    }
  });
</script>

<style>
  .coupon-popup-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
    padding: 1rem;
  }

  .coupon-popup-overlay.show {
    opacity: 1;
    visibility: visible;
  }

  .coupon-popup-modal {
    background: white;
    border-radius: 1.5rem;
    max-width: 500px;
    width: 100%;
    position: relative;
    transform: scale(0.9);
    transition: transform 0.3s ease;
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.3);
    max-height: 90vh;
    overflow-y: auto;
  }

  .coupon-popup-overlay.show .coupon-popup-modal {
    transform: scale(1);
  }

  .coupon-close-btn {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: rgba(0, 0, 0, 0.1);
    border: none;
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
    z-index: 10;
  }

  .coupon-close-btn:hover {
    background: rgba(0, 0, 0, 0.2);
    transform: rotate(90deg);
  }

  .coupon-close-btn svg {
    color: #333;
  }

  .coupon-content {
    padding: 2.5rem 2rem 2rem;
  }

  .coupon-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .coupon-badge {
    width: 64px;
    height: 64px;
    background: linear-gradient(135deg, #61c4c5 0%, #2d7c6f 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
    box-shadow: 0 8px 16px rgba(97, 196, 197, 0.3);
  }

  .coupon-badge svg {
    color: white;
  }

  .coupon-title {
    font-family: "Asap Condensed", sans-serif;
    font-size: 2rem;
    font-weight: bold;
    color: #1a1a1a;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .coupon-subtitle {
    font-family: "Helvetica", sans-serif;
    color: #666;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .coupon-card {
    background: linear-gradient(135deg, #61c4c5 0%, #4db5b6 100%);
    border-radius: 1rem;
    padding: 2rem;
    position: relative;
    border: 3px dashed rgba(255, 255, 255, 0.4);
    margin-bottom: 1.5rem;
  }

  /* Corner cuts */
  .corner-cut {
    position: absolute;
    width: 16px;
    height: 16px;
    background: white;
  }

  .corner-tl {
    top: -2px;
    left: -2px;
    border-bottom-right-radius: 100%;
  }

  .corner-tr {
    top: -2px;
    right: -2px;
    border-bottom-left-radius: 100%;
  }

  .corner-bl {
    bottom: -2px;
    left: -2px;
    border-top-right-radius: 100%;
  }

  .corner-br {
    bottom: -2px;
    right: -2px;
    border-top-left-radius: 100%;
  }

  /* Perforated edges */
  .perforation {
    position: absolute;
    width: 24px;
    height: 24px;
    background: white;
    border-radius: 50%;
    top: 50%;
    transform: translateY(-50%);
  }

  .perforation-left {
    left: -12px;
  }

  .perforation-right {
    right: -12px;
  }

  .coupon-inner {
    text-align: center;
    color: white;
  }

  .discount-badge {
    background: white;
    color: #61c4c5;
    font-family: "Asap Condensed", sans-serif;
    font-size: 2.5rem;
    font-weight: bold;
    padding: 0.75rem 1.5rem;
    border-radius: 0.75rem;
    display: inline-block;
    transform: rotate(-2deg);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
    margin-bottom: 1rem;
  }

  .coupon-service {
    font-family: "Helvetica", sans-serif;
    font-size: 1.25rem;
    font-weight: bold;
    margin-bottom: 0.75rem;
  }

  .coupon-description {
    font-family: "Helvetica", sans-serif;
    font-size: 0.875rem;
    opacity: 0.95;
    margin-bottom: 1rem;
    line-height: 1.5;
  }

  .coupon-terms {
    font-family: "Helvetica", sans-serif;
    font-size: 0.875rem;
    opacity: 0.9;
    text-align: left;
    display: inline-block;
  }

  .coupon-terms p {
    margin-bottom: 0.25rem;
  }

  .coupon-cta {
    text-align: center;
  }

  .coupon-expires {
    font-family: "Helvetica", sans-serif;
    font-size: 0.75rem;
    color: #666;
    margin-top: 0.75rem;
    font-style: italic;
  }

  /* Mobile responsive */
  @media (max-width: 640px) {
    .coupon-content {
      padding: 2rem 1.5rem 1.5rem;
    }

    .coupon-title {
      font-size: 1.5rem;
    }

    .coupon-card {
      padding: 1.5rem;
    }

    .discount-badge {
      font-size: 2rem;
      padding: 0.5rem 1rem;
    }

    .coupon-service {
      font-size: 1.125rem;
    }
  }
</style>
