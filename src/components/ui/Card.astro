---
export interface Props {
  title: string;
  description: string;
  icon: string;
  href?: string;
  variant?: 'default' | 'hover' | 'bordered' | 'service';
  size?: 'sm' | 'md' | 'lg';
  category?: string;
}

const { 
  title, 
  description, 
  icon, 
  href, 
  variant = 'default',
  size = 'md',
  category
} = Astro.props;

const sizeClasses = {
  sm: 'p-4',
  md: 'p-6', 
  lg: 'p-8'
};

const variantClasses = {
  default: 'border-2 border-opacity-20 text-gray-900 clipped-element',
  hover: 'border-2 border-opacity-20 hover:shadow-lg transition-all duration-300 hover:-translate-y-1 text-gray-900 clipped-element',
  bordered: 'border-4 border-opacity-30 text-gray-900 clipped-element',
  service: 'border-2 border-opacity-20 hover:shadow-xl transition-all duration-300 hover:-translate-y-2 relative overflow-hidden text-gray-900 clipped-element'
};

const CardTag = href ? 'a' : 'div';
---

<CardTag 
  href={href}
  class={`${variantClasses[variant]} ${sizeClasses[size]} group block`}
  style="background-color: #f8f9fa; border-color: rgba(45, 124, 111, 0.4);"
>
  
  <!-- Service icon -->
  <div class={`w-16 h-16 bg-brand-accent/20 border border-brand-accent/30 rounded-full flex items-center justify-center mb-4 text-2xl transition-colors duration-300 relative z-10 ${variant === 'service' ? 'group-hover:scale-110' : ''}`} style="background-color: rgba(97, 196, 197, 0.2); border: 1px solid rgba(97, 196, 197, 0.3);">
    <span set:html={icon}></span>
  </div>
  
  <!-- Service name -->
  <h3 class="text-lg font-cervo font-bold mb-2 relative z-10 transition-colors duration-300 text-black group-hover:text-brand-accent">
    {title}
  </h3>
  
  <!-- Category badge (for service variant) -->
  {variant === 'service' && category && (
    <div class="inline-block px-2 py-1 bg-brand-accent/20 text-brand-accent border border-brand-accent/30 text-xs font-helvetica font-medium rounded-full mb-2 relative z-10">
      {category}
    </div>
  )}
  
  <!-- Service description -->
  <p class="font-helvetica text-sm leading-relaxed relative z-10 text-gray-600">
    {description}
  </p>
  
  <!-- Learn more link (only if href is provided) -->
  {href && (
    <div class="mt-4 relative z-10">
      <span class={`font-helvetica text-sm font-medium inline-flex items-center gap-1 transition-colors duration-300 text-brand-accent hover:text-brand-primary ${variant === 'service' ? 'group-hover:gap-2' : ''}`}>
        Learn More
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class={variant === 'service' ? 'group-hover:translate-x-1 transition-transform duration-300' : ''}>
          <path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </div>
  )}
</CardTag>

<!-- SVG Clip Path Definition -->
<svg width="0" height="0" style="position: absolute;">
  <defs>
    <clipPath id="customClip" clipPathUnits="objectBoundingBox">
      <path d="M 0.000, 0.060 L 0.000, 0.060 Q 0.000, 0.000 0.060, 0.000 L 0.943, 0.000 Q 1.000, 0.000 0.960, 0.040 L 0.940, 0.060 Q 0.900, 0.100 0.940, 0.140 L 0.960, 0.160 Q 1.000, 0.200 1.000, 0.257 L 1.000, 0.940 Q 1.000, 1.000 0.940, 1.000 L 0.060, 1.000 Q 0.000, 1.000 0.000, 0.940 Z" />
    </clipPath>
  </defs>
</svg>

<style>
  .clipped-element {
    clip-path: url(#customClip);
    position: relative;
  }
  
</style>