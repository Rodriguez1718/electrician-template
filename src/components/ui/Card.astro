---
export interface Props {
  title: string;
  description: string;
  icon: string;
  href?: string;
  variant?: 'default' | 'hover' | 'bordered' | 'service' | 'image';
  size?: 'sm' | 'md' | 'lg';
  category?: string;
  backgroundImage?: string;
}

const { 
  title, 
  description, 
  icon, 
  href, 
  variant = 'default',
  size = 'md',
  category,
  backgroundImage
} = Astro.props;

// Generate unique ID for this card's clip path
const uniqueId = `cardClip-${Math.random().toString(36).substr(2, 9)}`;

const sizeClasses = {
  sm: 'p-4',
  md: 'p-6', 
  lg: 'p-8'
};

const variantClasses = {
  default: ' text-gray-900',
  hover: ' text-gray-900',
  bordered: ' text-gray-900',
  service: ' relative overflow-hidden text-gray-900',
  image: ' relative overflow-hidden text-white'
};

const CardTag = href ? 'a' : 'div';
---

<!-- Card Container with Background -->
<div class="relative group h-full">
  <!-- Background overlay (visual only) -->
  <div class="absolute top-2 right-2 w-39 h-16 bg-emerald-500 rounded -z-10 transition-transform duration-300 ease-out group-hover:scale-105 group-hover:-translate-y-1">
    <!-- Arrow SVG positioned in top right corner of overlay -->
    <div class="absolute top-0 right-0 w-8 h-8 flex items-center justify-center z-20">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="text-white opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-opacity duration-300 transform rotate-1">
        <path d="M7 17L17 7M17 7H7M17 7V17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  </div>
  
  <!-- Clickable area that matches just the corner of the overlay -->
  {href && (
    <a 
      href={href}
      class="absolute top-2 right-2 w-16 h-8 z-20 cursor-none overlay-hover-trigger group"
      aria-label={`Learn more about ${title}`}
    ></a>
  )}
  
  <div 
    class={`${variantClasses[variant]} ${sizeClasses[size]} block relative z-0 h-full flex flex-col ${variant === 'image' ? 'rounded-2xl overflow-hidden' : 'clipped-card'}`}
    style={variant === 'image' ? 
      `background-image: url('${backgroundImage}'); background-size: cover; background-position: center; background-repeat: no-repeat;` : 
      `background-color: #f8f9fa; border-color: rgba(45, 124, 111, 0.4); clip-path: url(#${uniqueId});`
    }
  >
    
    {/* Blur layer for image on hover */}
    {variant === 'image' && (
      <div class="absolute inset-0 backdrop-blur-0 group-hover:backdrop-blur-md transition-all duration-300 z-[1]"></div>
    )}
    
    {/* Instagram-style gradient overlay for image variant */}
    {variant === 'image' && (
      <div class="absolute inset-0 bg-gradient-to-br from-purple-600/60 via-pink-500/50 to-orange-400/60 opacity-80 group-hover:opacity-90 transition-all duration-300 z-[2]"></div>
    )}
    
    {/* Content container for image variant */}
    {variant === 'image' ? (
      <div class="relative z-[3] flex flex-col h-full justify-center items-center text-center p-6">
        {title || description || icon ? (
          <div class="opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <!-- Service icon -->
            {icon && (
              <div class="mb-4 bg-white/20 backdrop-blur-sm rounded-full p-4 shadow-lg">
                <span set:html={icon} class="text-white text-4xl drop-shadow-lg"></span>
              </div>
            )}
            
            <!-- Service name -->
            {title && (
              <h3 class="text-2xl font-asap-condensed uppercase tracking-wide font-bold mb-3 text-white drop-shadow-lg">
                {title}
              </h3>
            )}
            
            <!-- Category badge -->
            {category && (
              <div class="flex mb-3">
                <div class="px-4 py-1.5 bg-white/90 text-purple-600 text-xs font-asap-condensed font-bold rounded-full w-fit shadow-md">
                  {category}
                </div>
              </div>
            )}
            
            <!-- Service description -->
            {description && (
              <p class="font-helvetica text-base leading-relaxed text-white drop-shadow-md max-w-xs font-medium">
                {description}
              </p>
            )}
          </div>
        ) : null}
        
        <!-- Slot for custom content (like Instagram button) -->
        <slot />
      </div>
    ) : (
      <div class="relative z-10 flex flex-col h-full">
        <!-- Service icon -->
        <div class="relative z-10">
          <span set:html={icon}></span>
        </div>
        
        <!-- Service name -->
        <h3 class="text-lg font-asap-condensed uppercase tracking-wide font-bold mb-2 relative z-10 transition-colors duration-300 text-black group-hover:text-brand-accent">
          {title}
        </h3>
        
        <!-- Category badge (for service variant) -->
        {variant === 'service' && category && (
          <div class="flex">
            <div class="px-2 py-1 bg-brand-accent text-brand-background text-xs font-asap-condensed font-medium rounded-full mb-2 relative z-10 w-fit">
              {category}
            </div>
          </div>
        )}
        
        <!-- Service description -->
        <p class="font-helvetica text-sm leading-relaxed relative z-10 text-gray-600 flex-grow">
          {description}
        </p>
      </div>
    )}
  </div>
  
  <!-- SVG Clip Path Definition with unique ID -->
  <svg width="0" height="0" style="position: absolute;">
    <defs>
      <clipPath id={uniqueId} clipPathUnits="objectBoundingBox">
        <path d="M 0.000, 0.050 L 0.000, 0.050 Q 0.000, 0.000 0.050, 0.000 L 0.780, 0.000 Q 0.800, 0.000 0.806, 0.019 L 0.850, 0.150 L 0.972, 0.191 Q 1.000, 0.200 1.000, 0.230 L 1.000, 0.955 Q 1.000, 1.000 0.955, 1.000 L 0.045, 1.000 Q 0.000, 1.000 0.000, 0.955 Z" />
      </clipPath>
    </defs>
  </svg>
</div>

<style>
  .clipped-card {
    position: relative;
  }
</style>