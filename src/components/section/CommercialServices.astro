---
import Button from "../ui/Button.astro";

---

<section class="py-20 bg-black text-white relative overflow-hidden">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute top-10 left-10 w-32 h-32 border border-brand-primary rounded-full"></div>
    <div class="absolute top-40 right-20 w-24 h-24 border border-brand-accent rounded-full"></div>
    <div class="absolute bottom-20 left-1/4 w-16 h-16 border border-brand-secondary rounded-full"></div>
  </div>

  <!-- Top blur gradient for seamless transition from Hero2 -->
  <div class="absolute top-0 left-0 right-0 h-40 bg-gradient-to-b from-transparent via-black/60 to-black z-20"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-30">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      
      <!-- Left side - Image -->
      <div class="relative">
        <!-- SVG Clip Path Definition -->
        <svg width="0" height="0">
          <defs>
            <clipPath id="commercialClip" clipPathUnits="objectBoundingBox">
              <path d="M 0.000, 0.125 L 0.000, 0.125 Q 0.000, 0.000 0.125, 0.000 L 0.700, 0.000 Q 0.750, 0.000 0.750, 0.050 L 0.750, 0.205 Q 0.750, 0.250 0.795, 0.250 L 0.955, 0.250 Q 1.000, 0.250 1.000, 0.295 L 1.000, 0.855 Q 1.000, 0.950 0.905, 0.950 L 0.180, 0.950 Q 0.100, 0.950 0.100, 0.870 L 0.100, 0.770 Q 0.100, 0.750 0.080, 0.750 L 0.070, 0.750 Q 0.050, 0.750 0.050, 0.770 L 0.050, 0.980 Q 0.050, 1.000 0.030, 1.000 L 0.020, 1.000 Q 0.000, 1.000 0.000, 0.980 Z" />
            </clipPath>
          </defs>
        </svg>
        
        <!-- Clipped Image -->
        <img 
          src="/images/cutting.png" 
          alt="Electrical wiring work" 
          class="clipped-element w-full h-[500px] object-cover"
        />
        
        <!-- Experience Badge -->
        <div class="absolute top-1 right-3 border-2 border-brand-primary text-brand-primary p-3 rounded-lg shadow-lg">
          <div class="text-center">
            <div class="text-3xl font-bold font-asap-condensed">15+</div>
            <div class="text-m font-asap-condensed uppercase tracking-wide">Years of</div>
            <div class="text-m font-asap-condensed uppercase tracking-wide">Experience</div>
          </div>
        </div>
        
      </div>

      <!-- Right side - Content -->
      <div>
        <!-- Section Header -->
        <div class="mb-12">
          <p class="text-brand-accent font-helvetica text-sm uppercase tracking-wider mb-4">
            COMMERCIAL ELECTRICAL
          </p>
          <h2 class="text-4xl lg:text-5xl font-asap-condensed uppercase tracking-wide font-bold text-white mb-6">
            Expert <span class="text-brand-secondary">Commercial Electrical</span> Services
          </h2>
          <p class="text-lg text-white/80 font-helvetica leading-relaxed mb-8">
            At <strong class="text-brand-primary">VoltBully Electrical</strong>, we specialize in providing top-notch commercial electrical services 
            to ensure the safety, efficiency, and reliability of your business's electrical system. With 
            years of experience and a commitment to excellence, our licensed electricians are 
            ready to tackle any project, big or small, to keep your business running smoothly.
          </p>
        </div>

        <!-- Features Grid -->
        <div class="grid md:grid-cols-2 gap-8 mb-10">
          <!-- Experienced Professionals -->
          <div class="flex items-start gap-4 group">
            <div class="flex-shrink-0 w-12 h-12 bg-brand-secondary/20 rounded-full flex items-center justify-center group-hover:bg-brand-secondary/30 transition-colors duration-300">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-brand-secondary">
                <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-asap-condensed uppercase tracking-wide font-bold text-white mb-2 group-hover:text-brand-secondary transition-colors duration-300">
                Experienced Professionals
              </h3>
              <p class="text-white/70 font-helvetica text-sm leading-relaxed">
                Our licensed and insured electricians bring years of expertise to every job.
              </p>
            </div>
          </div>

          <!-- Business-Centered Approach -->
          <div class="flex items-start gap-4 group">
            <div class="flex-shrink-0 w-12 h-12 bg-brand-primary/20 rounded-full flex items-center justify-center group-hover:bg-brand-primary/30 transition-colors duration-300">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-brand-primary">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2" stroke="currentColor" stroke-width="2"/>
                <circle cx="9" cy="9" r="2" stroke="currentColor" stroke-width="2"/>
                <path d="M21 15.5c-1.5-1.5-4-1.5-5.5 0" stroke="currentColor" stroke-width="2"/>
                <path d="M12 12l9 9" stroke="currentColor" stroke-width="2"/>
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-asap-condensed uppercase tracking-wide font-bold text-white mb-2 group-hover:text-brand-primary transition-colors duration-300">
                Business-Centered Approach
              </h3>
              <p class="text-white/70 font-helvetica text-sm leading-relaxed">
                Your business continuity is our priority. We work with minimal disruption and maximum efficiency.
              </p>
            </div>
          </div>

          <!-- Transparent Pricing -->
          <div class="flex items-start gap-4 group">
            <div class="flex-shrink-0 w-12 h-12 bg-brand-accent/20 rounded-full flex items-center justify-center group-hover:bg-brand-accent/30 transition-colors duration-300">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-brand-accent">
                <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-asap-condensed uppercase tracking-wide font-bold text-white mb-2 group-hover:text-brand-accent transition-colors duration-300">
                Transparent Pricing
              </h3>
              <p class="text-white/70 font-helvetica text-sm leading-relaxed">
                No hidden fees—just honest, upfront quotes for all commercial electrical work.
              </p>
            </div>
          </div>

          <!-- Advanced Solutions -->
          <div class="flex items-start gap-4 group">
            <div class="flex-shrink-0 w-12 h-12 bg-red-500/20 rounded-full flex items-center justify-center group-hover:bg-red-500/30 transition-colors duration-300">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-red-600">
                <path d="M12 2L13.09 8.26L20 9L13.09 9.74L12 16L10.91 9.74L4 9L10.91 8.26L12 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-asap-condensed uppercase tracking-wide font-bold text-white mb-2 group-hover:text-red-600 transition-colors duration-300">
                Advanced Solutions
              </h3>
              <p class="text-white/70 font-helvetica text-sm leading-relaxed">
                We use the latest tools and techniques to deliver efficient and effective results.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Custom clip path for image */
  .clipped-element {
    clip-path: url(#commercialClip);
  }
</style>