---
import Button from "../ui/Button.astro";

export interface Props {
  sectionTag?: string;
  title?: string;
  highlightedText?: string;
  description?: string;
  companyName?: string;
  image?: {
    src: string;
    alt: string;
  };
  badge?: {
    number: string;
    text: string[];
  };
  features?: Array<{
    title: string;
    description: string;
    icon: string;
    color: 'primary' | 'secondary' | 'accent' | 'red';
  }>;
}

const {
  sectionTag = "COMMERCIAL ELECTRICAL",
  title = "Expert Commercial Electrical Services",
  highlightedText = "Commercial Electrical",
  description = "we specialize in providing top-notch commercial electrical services to ensure the safety, efficiency, and reliability of your business's electrical system.",
  companyName = "VoltBully Electrical",
  image = {
    src: "/images/cutting.png",
    alt: "Electrical wiring work"
  },
  badge = {
    number: "15+",
    text: ["Years of", "Experience"]
  },
  features = [
    {
      title: "Experienced Professionals",
      description: "Our licensed and insured electricians bring years of expertise to every job.",
      icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>',
      color: 'secondary'
    },
    {
      title: "Business-Centered Approach",
      description: "Your business continuity is our priority. We work with minimal disruption and maximum efficiency.",
      icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="2" ry="2" stroke="currentColor" stroke-width="2"/><circle cx="9" cy="9" r="2" stroke="currentColor" stroke-width="2"/><path d="M21 15.5c-1.5-1.5-4-1.5-5.5 0" stroke="currentColor" stroke-width="2"/><path d="M12 12l9 9" stroke="currentColor" stroke-width="2"/></svg>',
      color: 'primary'
    },
    {
      title: "Transparent Pricing",
      description: "No hidden fees—just honest, upfront quotes for all commercial electrical work.",
      icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>',
      color: 'accent'
    },
    {
      title: "Advanced Solutions",
      description: "We use the latest tools and techniques to deliver efficient and effective results.",
      icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2L13.09 8.26L20 9L13.09 9.74L12 16L10.91 9.74L4 9L10.91 8.26L12 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>',
      color: 'red'
    }
  ]
} = Astro.props;

const getColorClasses = (color: 'primary' | 'secondary' | 'accent' | 'red') => {
  const colors = {
    primary: {
      bg: 'bg-brand-primary/20',
      hoverBg: 'group-hover:bg-brand-primary/30',
      text: 'text-brand-primary',
      hoverText: 'group-hover:text-brand-primary'
    },
    secondary: {
      bg: 'bg-brand-secondary/20',
      hoverBg: 'group-hover:bg-brand-secondary/30',
      text: 'text-brand-secondary',
      hoverText: 'group-hover:text-brand-secondary'
    },
    accent: {
      bg: 'bg-brand-accent/20',
      hoverBg: 'group-hover:bg-brand-accent/30',
      text: 'text-brand-accent',
      hoverText: 'group-hover:text-brand-accent'
    },
    red: {
      bg: 'bg-red-500/20',
      hoverBg: 'group-hover:bg-red-500/30',
      text: 'text-red-600',
      hoverText: 'group-hover:text-red-600'
    }
  };
  return colors[color] || colors.primary;
};
---

<section class="py-20 bg-black text-white relative overflow-hidden">
  <!-- Top blur gradient for seamless transition from Hero2 -->
  <div class="absolute top-0 left-0 right-0 h-40 bg-gradient-to-b from-transparent via-black/60 to-black z-20"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-30">
    <div id="commercial-services-grid" class="grid lg:grid-cols-2 gap-16 items-center">
      
      <!-- Left side - Image -->
      <div id="commercial-services-image-container" class="relative">
        <!-- SVG Clip Path Definition -->
        <svg width="0" height="0">
          <defs>
            <clipPath id="commercialClip" clipPathUnits="objectBoundingBox">
              <path d="M 0.000, 0.125 L 0.000, 0.125 Q 0.000, 0.000 0.125, 0.000 L 0.700, 0.000 Q 0.750, 0.000 0.750, 0.050 L 0.750, 0.205 Q 0.750, 0.250 0.795, 0.250 L 0.955, 0.250 Q 1.000, 0.250 1.000, 0.295 L 1.000, 0.855 Q 1.000, 0.950 0.905, 0.950 L 0.180, 0.950 Q 0.100, 0.950 0.100, 0.870 L 0.100, 0.770 Q 0.100, 0.750 0.080, 0.750 L 0.070, 0.750 Q 0.050, 0.750 0.050, 0.770 L 0.050, 0.980 Q 0.050, 1.000 0.030, 1.000 L 0.020, 1.000 Q 0.000, 1.000 0.000, 0.980 Z" />
            </clipPath>
          </defs>
        </svg>
        
        <!-- Clipped Image -->
        <img 
          id="commercial-services-image"
          src={image.src} 
          alt={image.alt} 
          class="clipped-element w-full h-[500px] object-cover"
        />
        
        <!-- Experience Badge -->
        {badge && (
          <div id="commercial-services-badge" class="absolute top-1 right-3 border-2 border-brand-primary text-brand-primary p-3 rounded-lg shadow-lg">
            <div class="text-center">
              <div class="text-3xl font-bold font-asap-condensed">{badge.number}</div>
              {badge.text.map((line) => (
                <div class="text-m font-asap-condensed uppercase tracking-wide">{line}</div>
              ))}
            </div>
          </div>
        )}
        
      </div>

      <!-- Right side - Content -->
      <div id="commercial-services-content">
        <!-- Section Header -->
        <div id="commercial-services-header" class="mb-12">
          <p id="commercial-services-tag" class="text-brand-accent font-helvetica text-sm uppercase tracking-wider mb-4">
            {sectionTag}
          </p>
          <h2 id="commercial-services-title" class="text-4xl lg:text-5xl font-asap-condensed uppercase tracking-wide font-bold text-white mb-6">
            {highlightedText ? (
              <Fragment>
                {title.split(highlightedText)[0]}
                <span class="text-brand-secondary">{highlightedText}</span>
                {title.split(highlightedText)[1]}
              </Fragment>
            ) : title}
          </h2>
          <p id="commercial-services-description" class="text-lg text-white/80 font-helvetica leading-relaxed mb-8">
            At <strong class="text-brand-primary">{companyName}</strong>, {description}
          </p>
        </div>

        <!-- Features Grid -->
        <div id="commercial-services-features" class="grid md:grid-cols-2 gap-8 mb-10">
          {features.map((feature, index) => {
            const colorClasses = getColorClasses(feature.color);
            return (
              <div id={`commercial-feature-${index + 1}`} class="flex items-start gap-4 group">
                <div class={`flex-shrink-0 w-12 h-12 ${colorClasses.bg} rounded-full flex items-center justify-center ${colorClasses.hoverBg} transition-colors duration-300`}>
                  <div class={colorClasses.text} set:html={feature.icon}></div>
                </div>
                <div>
                  <h3 class={`text-lg font-asap-condensed uppercase tracking-wide font-bold text-white mb-2 ${colorClasses.hoverText} transition-colors duration-300`}>
                    {feature.title}
                  </h3>
                  <p class="text-white/70 font-helvetica text-sm leading-relaxed">
                    {feature.description}
                  </p>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Custom clip path for image */
  .clipped-element {
    clip-path: url(#commercialClip);
  }
</style>