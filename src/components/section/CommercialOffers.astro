---
import Button from "../ui/Button.astro";

export interface Props {
  showGradient?: boolean;
}

const { showGradient = true } = Astro.props;

const offers = [
  {
    title: "New Customer Special",
    discount: "FREE",
    service: "Electrical Safety Inspection",
    description: "Complete electrical system evaluation for your home or business with detailed safety report and recommendations.",
    terms: "Valid for first-time customers only. Includes comprehensive inspection report. Service call fees waived.",
    expires: "March 2025",
    bgColor: "bg-gray-900",
    textColor: "text-white",
    accentColor: "bg-brand-secondary",
    accentText: "text-white"
  },
  {
    title: "Emergency Response",
    discount: "24/7",
    service: "Emergency Electrical Service",
    description: "Round-the-clock emergency electrical repairs and troubleshooting for urgent electrical issues and power outages.",
    terms: "Available 24 hours a day, 7 days a week. Emergency service rates apply after hours and weekends.",
    expires: "Always Available",
    bgColor: "bg-white",
    textColor: "text-gray-800",
    accentColor: "bg-brand-primary",
    accentText: "text-black"
  },
  {
    title: "Project Bundle",
    discount: "15% OFF",
    service: "Multi-Service Package",
    description: "Combine multiple electrical services like panel upgrades, rewiring, and installations for maximum savings.",
    terms: "Minimum 3 services required. Cannot be combined with other offers. Valid for residential and commercial.",
    expires: "March 2025",
    bgColor: "bg-brand-accent",
    textColor: "text-white",
    accentColor: "bg-white",
    accentText: "text-brand-accent"
  }
];
---

<section class="py-16 bg-white relative overflow-hidden">

  <!-- Gradient overlay at bottom for seamless transition -->
  {showGradient && (
    <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-b from-transparent to-gray-50 z-10"></div>
  )}

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <!-- Section header -->
    <div id="commercial-offers-header" class="text-center mb-12">
      <p id="commercial-offers-tag" class="text-brand-secondary font-helvetica text-sm uppercase tracking-wider mb-4">
        Special Offers
      </p>
      <h2 id="commercial-offers-title" class="text-4xl lg:text-5xl font-asap-condensed font-bold text-gray-900 mb-4 uppercase">
        What We Can <span class="text-brand-secondary">Offer You</span>
      </h2>
      <p id="commercial-offers-description" class="text-lg text-gray-600 font-helvetica max-w-2xl mx-auto">
        Discover our comprehensive electrical services and special offers designed for both residential and commercial clients. Quality work, competitive pricing, guaranteed satisfaction.
      </p>
    </div>

    <!-- Offers grid -->
    <div id="commercial-offers-grid" class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
      {offers.map((offer, index) => (
        <div id={`commercial-offer-${index + 1}`} class="offer-card group">
          <div class={`${offer.bgColor} ${offer.textColor} p-8 h-full flex flex-col relative overflow-hidden`}>
            <!-- Decorative corner cuts -->
            <div class="absolute top-0 left-0 w-4 h-4 bg-white rounded-br-full"></div>
            <div class="absolute top-0 right-0 w-4 h-4 bg-white rounded-bl-full"></div>
            <div class="absolute bottom-0 left-0 w-4 h-4 bg-white rounded-tr-full"></div>
            <div class="absolute bottom-0 right-0 w-4 h-4 bg-white rounded-tl-full"></div>
            
            <!-- Offer header -->
            <div class="text-center mb-6">
              <p class="text-base font-helvetica font-medium opacity-80 mb-2">
                {offer.title}
              </p>
              <h3 class="text-3xl font-asap-condensed font-bold text-brand-primary mb-2">
                Special Offer
              </h3>
              <p class="text-sm font-helvetica opacity-70">
                Limited Time Only
              </p>
            </div>

            <!-- Discount badge -->
            <div class="flex justify-center mb-6">
              <div class={`${offer.accentColor} ${offer.accentText} px-6 py-3 font-bold text-2xl font-helvetica transform -rotate-2 shadow-lg rounded-lg`}>
                {offer.discount}
              </div>
            </div>

            <!-- Service details -->
            <div class="flex-1 text-center mb-6">
              <h4 class="font-helvetica font-semibold text-xl mb-3">
                {offer.service}
              </h4>
              <p class="text-base opacity-80 leading-relaxed mb-4">
                {offer.description}
              </p>
            </div>

            <!-- Terms and expiration -->
            <div class="pt-4 mt-auto">
              <p class="text-sm opacity-70 mb-2 leading-relaxed">
                {offer.terms}
              </p>
              <p class="text-sm font-medium opacity-80">
                * Offer Expires: {offer.expires}
              </p>
            </div>

            <!-- CTA Button -->
            <div class="text-center mt-4">
              <Button 
                variant="primary" 
                size="md" 
                href="/contact"
                class="w-full"
              >
                Claim Offer
              </Button>
            </div>

            <!-- Perforated edge effect -->
            <div class="absolute left-0 top-1/2 -translate-y-1/2 w-6 h-6 bg-white rounded-full -ml-3"></div>
            <div class="absolute right-0 top-1/2 -translate-y-1/2 w-6 h-6 bg-white rounded-full -mr-3"></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .offer-card {
    /* Dashed border effect */
    background: 
      linear-gradient(90deg, currentColor 50%, transparent 50%),
      linear-gradient(90deg, currentColor 50%, transparent 50%),
      linear-gradient(0deg, currentColor 50%, transparent 50%),
      linear-gradient(0deg, currentColor 50%, transparent 50%);
    background-repeat: repeat-x, repeat-x, repeat-y, repeat-y;
    background-size: 15px 2px, 15px 2px, 2px 15px, 2px 15px;
    background-position: 0 0, 0 100%, 0 0, 100% 0;
    color: rgba(0, 0, 0, 0.2);
    padding: 3px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .offer-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
  }

  /* Perforated dots along the sides */
  .offer-card::before,
  .offer-card::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 2px;
    background: 
      radial-gradient(circle, transparent 40%, currentColor 40%, currentColor 60%, transparent 60%);
    background-size: 2px 20px;
    background-repeat: repeat-y;
    opacity: 0.2;
  }

  .offer-card::before {
    left: -1px;
  }

  .offer-card::after {
    right: -1px;
  }
</style>