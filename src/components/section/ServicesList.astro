---
import Card from "../ui/Card.astro";

export interface Props {
  sectionLabel?: string;
  title?: string;
  titleHighlight?: string;
  description?: string;
  category?: string;
}

const {
  sectionLabel = "Commercial Services",
  title = "Our",
  titleHighlight = "Commercial Electrical",
  description = "Comprehensive electrical solutions designed specifically for commercial properties. From office buildings to industrial facilities, we provide reliable, code-compliant electrical services that keep your business running smoothly.",
  category = "commercial"
} = Astro.props;

interface Service {
  name: string;
  icon: string;
  description: string;
  slug: string;
}

// Load services from markdown files based on category
async function loadServices(categoryName: string): Promise<Service[]> {
  const services: Service[] = [];
  
  try {
    // Import all markdown files from the specified category
    const categoryFiles = import.meta.glob('/src/content/**/*.md', { eager: true });
    
    // Filter files for this category
    const serviceFiles = Object.entries(categoryFiles).filter(([path]) => 
      path.includes(`/src/content/${categoryName}/`) && !path.endsWith('/index.md')
    );
    
    // Custom slug mappings for specific services
    const slugMappings: Record<string, string> = {
      'ground-up-electrical-construction': 'ground-up-construction'
    };
    
    for (const [path, module] of serviceFiles) {
      const frontmatter = (module as any).frontmatter || {};
      const fileName = path.split('/').pop()?.replace('.md', '') || '';
      
      // Use custom slug mapping if available, otherwise use filename
      const slug = slugMappings[fileName] || fileName;
      
      services.push({
        name: frontmatter.title || fileName,
        icon: frontmatter.icon || '⚡',
        description: frontmatter.description || '',
        slug: slug
      });
    }
    
  } catch (error: any) {
    console.error(`Error loading ${categoryName} services:`, error?.message || 'Unknown error');
  }
  
  return services;
}

const services = await loadServices(category);
---

<section class="py-20 bg-black text-white relative overflow-hidden rounded-bottom">

  <div class="max-w-7xl mx-auto px-6 relative z-20">
    <!-- Section header -->
    <div id="services-list-header" class="text-center mb-16">
      <p id="services-list-label" class="text-brand-accent font-helvetica text-sm uppercase tracking-wider mb-4">
        {sectionLabel}
      </p>
      <h2 id="services-list-title" class="text-4xl lg:text-5xl font-asap-condensed font-bold text-white mb-6 leading-tight tracking-wide uppercase">
        {title} <span class="text-brand-secondary">{titleHighlight}</span> Services
      </h2>
      <p id="services-list-description" class="text-lg text-white/80 font-helvetica leading-relaxed max-w-3xl mx-auto">
        {description}
      </p>
    </div>

    <!-- Services grid -->
    <div id="services-list-grid" class="grid md:grid-cols-2 lg:grid-cols-2 gap-6">
      {services.map((service: Service, index) => (
        <div id={`services-list-card-${index + 1}`} class={index === services.length - 1 ? 'hidden' : ''}>
          <Card
            title={service.name}
            description={service.description}
            icon={service.icon}
            href={`/services/${service.slug}`}
            variant="service"
            size="md"
            category={category.charAt(0).toUpperCase() + category.slice(1)}
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Rounded bottom section */
  .rounded-bottom {
    border-bottom-left-radius: 50px;
    border-bottom-right-radius: 50px;
  }

  /* Responsive border radius */
  @media (min-width: 640px) {
    .rounded-bottom {
      border-bottom-left-radius: 100px;
      border-bottom-right-radius: 100px;
    }
  }

  @media (min-width: 768px) {
    .rounded-bottom {
      border-bottom-left-radius: 150px;
      border-bottom-right-radius: 150px;
    }
  }

  @media (min-width: 1024px) {
    .rounded-bottom {
      border-bottom-left-radius: 200px;
      border-bottom-right-radius: 200px;
    }
  }

  /* Alternative curved bottom using clip-path for more dramatic curve */
  .rounded-bottom::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 50px;
    background: inherit;
    clip-path: ellipse(100% 100% at 50% 0%);
  }
</style>