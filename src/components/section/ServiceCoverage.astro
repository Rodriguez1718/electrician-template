---
export interface Props {
  sectionLabel?: string;
  title?: string;
  titleHighlight?: string;
  description?: string;
  buttonText?: string;
  buttonHref?: string;
  serviceAreas?: string[];
  mainCity?: string;
  mapEmbedUrl?: string;
}

const {
  sectionLabel = "Service Coverage",
  title = "Proudly Serving",
  titleHighlight = "Your Local Area",
  description = "We provide reliable electrical services throughout the metropolitan area and surrounding communities. Our licensed electricians are ready to help with residential, commercial, and emergency electrical needs.",
  buttonText = "VIEW ALL AREAS",
  buttonHref = "/service-areas",
  serviceAreas = [
    "Downtown District",
    "Residential Heights", 
    "Business Park",
    "Industrial Zone",
    "Suburban Communities",
    "Historic District"
  ],
  mainCity = "Metropolitan Area",
  mapEmbedUrl = "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d423286.27405770525!2d-118.69192113701158!3d34.02016130653294!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x80c2c75ddc27da13%3A0xe22fdf6f254608f4!2sLos%20Angeles%2C%20CA!5e0!3m2!1sen!2sus!4v1703123456789!5m2!1sen!2sus"
} = Astro.props;
---

<section class="py-20 bg-black text-white relative overflow-hidden rounded-top">
  <!-- Decorative background image -->
  <div class="absolute top-1/2 right-0 transform  opacity-40 pointer-events-none">
    <img 
      src="/images/fullvolt.png" 
      alt="VoltBully Background" 
      class="w-96 h-96 object-contain"
    />
  </div>
  
  <!-- Dark overlay to ensure text readability -->
  <div class="absolute inset-0 bg-black/60"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div id="service-coverage-grid" class="grid lg:grid-cols-2 gap-16 items-center">
      
      <!-- Left side - Google Maps -->
      <div id="service-coverage-map-container" class="relative">
        <!-- Google Maps Container -->
        <div id="service-coverage-map-wrapper" class="relative bg-white/10 backdrop-blur-sm border border-white/20 rounded-2xl shadow-xl overflow-hidden">
          <!-- Map iframe -->
          <div id="service-coverage-map" class="relative h-96 w-full">
            <iframe
              src={mapEmbedUrl}
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="VoltBully Electrical Service Coverage Map"
              class="rounded-t-2xl"
            ></iframe>
          </div>
          
          <!-- Service areas overlay -->
          <div id="service-coverage-areas" class="p-6 bg-white/10 backdrop-blur-sm">
            <h4 id="service-coverage-areas-title" class="text-lg font-asap-condensed font-bold text-white mb-4 uppercase">
              Service Areas Include:
            </h4>
            <div id="service-coverage-areas-grid" class="grid grid-cols-2 gap-3">
              {serviceAreas.map((area, index) => (
                <div id={`service-area-item-${index + 1}`} class="flex items-center gap-2 text-sm">
                  <div class="w-2 h-2 bg-brand-primary rounded-full flex-shrink-0"></div>
                  <span class="font-helvetica text-white/90">{area}</span>
                </div>
              ))}
            </div>
            
            <!-- Coverage radius indicator -->
            <div id="service-coverage-radius" class="mt-4 pt-4 border-t border-white/20">
              <div class="flex items-center justify-center gap-2 text-sm">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="text-brand-accent">
                  <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
                  <path d="M8 12h8" stroke="currentColor" stroke-width="2"/>
                </svg>
                <span class="font-helvetica font-medium text-brand-accent">50+ Mile Service Radius</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right side - Content -->
      <div id="service-coverage-content">
        <!-- Section header -->
        <div id="service-coverage-header" class="mb-8">
          <p id="service-coverage-label" class="text-brand-accent font-helvetica text-sm uppercase tracking-wider mb-4">
            {sectionLabel}
          </p>
          <h2 id="service-coverage-title" class="text-4xl lg:text-5xl font-asap-condensed font-bold text-white mb-6 leading-tight tracking-wide uppercase">
            {title} <span class="text-brand-primary">{titleHighlight}</span>
          </h2>
          <p id="service-coverage-description" class="text-lg text-white/80 font-helvetica leading-relaxed mb-8">
            {description}
          </p>
        </div>

        <!-- Service highlights -->
        <div id="service-coverage-highlights" class="space-y-4 mb-8">
          <div id="service-coverage-highlight-1" class="flex items-start gap-4 group">
            <div class="w-12 h-12 bg-brand-secondary/20 rounded-full flex items-center justify-center flex-shrink-0">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="text-brand-secondary">
                <path d="M12 2L2 7l10 5 10-5-10-5z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M2 17l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M2 12l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-helvetica font-semibold text-white mb-2 group-hover:text-brand-secondary transition-colors duration-300">
                Comprehensive Coverage
              </h3>
              <p class="text-white/70 font-helvetica text-sm leading-relaxed">
                From residential neighborhoods to commercial districts, we serve all areas within our coverage zone with the same high-quality electrical services.
              </p>
            </div>
          </div>

          <div id="service-coverage-highlight-2" class="flex items-start gap-4 group">
            <div class="w-12 h-12 bg-brand-primary/20 rounded-full flex items-center justify-center flex-shrink-0 group-hover:bg-brand-primary/30 transition-colors duration-300">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="text-brand-primary">
                <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/>
                <path d="M12 1v6M12 17v6M4.22 4.22l4.24 4.24M15.54 15.54l4.24 4.24M1 12h6M17 12h6M4.22 19.78l4.24-4.24M15.54 8.46l4.24-4.24" stroke="currentColor" stroke-width="2"/>
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-helvetica font-semibold text-white mb-2 group-hover:text-brand-primary transition-colors duration-300">
                Fast Response Times
              </h3>
              <p class="text-white/70 font-helvetica text-sm leading-relaxed">
                Our strategically located service teams ensure quick response times throughout our entire service area, especially for emergency calls.
              </p>
            </div>
          </div>

          <div id="service-coverage-highlight-3" class="flex items-start gap-4 group">
            <div class="w-12 h-12 bg-brand-accent/20 rounded-full flex items-center justify-center flex-shrink-0 group-hover:bg-brand-accent/30 transition-colors duration-300">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="text-brand-accent">
                <path d="M9 11H5a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h4l3 3V8l-3 3z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M15.54 8.46a5 5 0 0 1 0 7.07" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-helvetica font-semibold text-white mb-2 group-hover:text-brand-accent transition-colors duration-300">
                Local Expertise
              </h3>
              <p class="text-white/70 font-helvetica text-sm leading-relaxed">
                We understand local electrical codes, building requirements, and community needs, ensuring compliant and effective electrical solutions.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes ping {
    75%, 100% {
      transform: scale(2);
      opacity: 0;
    }
  }
  
  @keyframes pulse {
    50% {
      opacity: .5;
    }
  }
  
  .animate-ping {
    animation: ping 1s cubic-bezier(0, 0, 0.2, 1) infinite;
  }
  
  .animate-pulse {
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  /* Rounded top section */
  /* Rounded bottom section */
  .rounded-top {
    border-top-left-radius: 50px;
    border-top-right-radius: 50px;
  }

  /* Responsive border radius */
  @media (min-width: 640px) {
    .rounded-top {
      border-top-left-radius: 100px;
      border-top-right-radius: 100px;
    }
  }

  @media (min-width: 768px) {
    .rounded-top {
      border-top-left-radius: 150px;
      border-top-right-radius: 150px;
    }
  }

  @media (min-width: 1024px) {
    .rounded-top {
      border-top-left-radius: 200px;
      border-top-right-radius: 200px;
    }
  }

  /* Alternative curved top using clip-path for more dramatic curve */
  .rounded-top::before {
    content: '';
    position: absolute;
    top: -1px;
    left: 0;
    right: 0;
    height: 50px;
    background: inherit;
    clip-path: ellipse(100% 100% at 50% 100%);
  }
</style>