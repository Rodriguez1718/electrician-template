---
import Button from "../ui/Button.astro";

export interface Props {
  roundedBottom?: boolean;
  showGradient?: boolean;
}
const { showGradient = true } = Astro.props;
const { roundedBottom = false } = Astro.props;

const offers = [
  {
    title: "Maintenance Plan",
    discount: "$99",
    period: "/year",
    service: "Annual Electrical Care",
    description: "Comprehensive electrical maintenance with priority emergency service and 15% discount on all repairs.",
    features: [
      "Annual comprehensive inspection",
      "Panel cleaning & maintenance",
      "Outlet & switch testing",
      "Priority emergency scheduling",
      "15% discount on repairs",
      "24/7 emergency support"
    ],
    terms: "Annual subscription. Auto-renewal available. Cancel anytime.",
    expires: "Limited Time Offer",
    bgColor: "bg-gradient-to-br from-gray-50 to-white",
    textColor: "text-gray-800",
    borderColor: "border-brand-primary",
    accentColor: "bg-brand-primary",
    accentText: "text-black",
    ctaText: "Enroll Now",
    ctaHref: "/maintenance"
  },
  {
    title: "Flexible Financing",
    discount: "0%",
    period: "APR",
    service: "Payment Plans Available",
    description: "Spread the cost of major electrical upgrades over time with low-interest and no-interest financing options.",
    features: [
      "Low & no-interest plans",
      "Flexible payment schedules",
      "Quick approval process",
      "Panel upgrades & rewiring",
      "Generator installations",
      "Commercial projects"
    ],
    terms: "Subject to credit approval. Terms and conditions apply.",
    expires: "Apply Today",
    bgColor: "bg-gradient-to-br from-brand-accent to-brand-accent/90",
    textColor: "text-gray-900",
    borderColor: "border-brand-accent",
    accentColor: "bg-gray-900",
    accentText: "text-white",
    ctaText: "Apply Now",
    ctaHref: "/contact"
  },
  {
    title: "Special Offer",
    discount: "$100 OFF",
    period: "",
    service: "Panel Upgrade Service",
    description: "Upgrade your electrical panel to modern standards. Includes full inspection, installation, and warranty.",
    features: [
      "200A panel upgrade",
      "Full system inspection",
      "Code compliance check",
      "Professional installation",
      "5-year warranty",
      "Same-day service available"
    ],
    terms: "Minimum project value $1500. New customers only. Cannot combine with other offers.",
    expires: "December 2024",
    bgColor: "bg-gradient-to-br from-gray-50 to-white",
    textColor: "text-gray-800",
    borderColor: "border-brand-secondary",
    accentColor: "bg-brand-secondary",
    accentText: "text-white",
    ctaText: "Claim Offer",
    ctaHref: "/contact"
  }
];
---

<section class={`py-16 bg-white relative overflow-hidden ${roundedBottom ? 'rounded-bottom' : ''}`}>

  <!-- Gradient overlay at bottom for seamless transition -->
  {showGradient && (
    <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-b from-transparent to-gray-50 z-10"></div>
  )}
  
  <div class="max-w-7xl mx-auto px-6 pt-6 relative z-20">
    <!-- Offers grid -->
    <div id="offers-grid" class="grid md:grid-cols-3 gap-10 max-w-6xl mx-auto items-stretch">
      {offers.map((offer, index) => (
        <div id={`offer-${index + 1}`} class={`offer-card-wrapper ${index === 1 ? 'featured-offer-wrapper' : ''}`} data-animate="scale" data-delay={index + 3}>
          <div class={`offer-card ${index === 1 ? 'featured-offer' : ''} border-2 ${offer.borderColor}`}>
            <div class={`${offer.bgColor} ${offer.textColor} p-8 h-full flex flex-col relative overflow-hidden rounded-xl`}>
            
            <!-- Top ribbon -->
            <div class="absolute top-0 left-0 right-0 h-2 bg-gradient-to-r from-transparent via-current to-transparent opacity-20"></div>
            
            <!-- Offer header -->
            <div class="text-center mb-6 relative">
              <div class="inline-block px-4 py-1 bg-black/5 rounded-full mb-3">
                <p class="text-sm font-helvetica font-medium uppercase tracking-wide">
                  {offer.title}
                </p>
              </div>
              <h3 class="text-2xl font-asap-condensed font-bold mb-2">
                {offer.service}
              </h3>
              <p class="text-xs font-helvetica opacity-70 uppercase tracking-wider">
                {offer.expires}
              </p>
            </div>

            <!-- Discount badge -->
            <div class="flex justify-center mb-6">
              <div class={`${offer.accentColor} ${offer.accentText} px-8 py-4 font-bold text-3xl font-helvetica rounded-lg shadow-xl relative`}>
                <div class="absolute inset-0 bg-gradient-to-br from-white/20 to-transparent rounded-lg"></div>
                <span class="relative">{offer.discount}<span class="text-xl">{offer.period}</span></span>
              </div>
            </div>

            <!-- Description -->
            <div class="text-center mb-6">
              <p class="text-sm leading-relaxed opacity-90">
                {offer.description}
              </p>
            </div>

            <!-- Features list -->
            <div class="flex-1 mb-6">
              <div class="space-y-2.5">
                {offer.features.map((feature) => (
                  <div class="flex items-start gap-3 group">
                    <div class={`${offer.accentColor} ${offer.accentText} w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5`}>
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none">
                        <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </div>
                    <span class="text-sm font-helvetica">{feature}</span>
                  </div>
                ))}
              </div>
            </div>

            <!-- Terms and CTA -->
            <div class="pt-4 mt-auto">
              <p class="text-xs opacity-60 mb-4 leading-relaxed text-center">
                {offer.terms}
              </p>
              
              <!-- CTA Button -->
              <div class="text-center">
                <Button 
                  variant="primary" 
                  size="md" 
                  href={offer.ctaHref}
                  class="w-full"
                >
                  {offer.ctaText}
                </Button>
              </div>
            </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Wrapper for animation */
  .offer-card-wrapper {
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  /* Inner card with solid border + rounded corners */
  .offer-card {
    flex: 1;
    display: flex;
    flex-direction: column;
    border-radius: 0.75rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.07);
    background: white;
  }

  .offer-card-wrapper:hover .offer-card {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.12);
  }

  /* Middle card larger on tablet+ */
  @media (min-width: 768px) {
    .offer-card.featured-offer {
      transform: scale(1.08);
      z-index: 10;
    }

    .offer-card-wrapper:hover .offer-card.featured-offer {
      transform: scale(1.08) translateY(-8px);
    }
  }

  /* Rounded bottom */
  .rounded-bottom {
    border-bottom-left-radius: 50px;
    border-bottom-right-radius: 50px;
  }

  @media (min-width: 640px) {
    .rounded-bottom {
      border-bottom-left-radius: 100px;
      border-bottom-right-radius: 100px;
    }
  }

  @media (min-width: 768px) {
    .rounded-bottom {
      border-bottom-left-radius: 150px;
      border-bottom-right-radius: 150px;
    }
  }

  @media (min-width: 1024px) {
    .rounded-bottom {
      border-bottom-left-radius: 200px;
      border-bottom-right-radius: 200px;
    }
  }
</style>
