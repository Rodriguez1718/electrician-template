---
import Button from "../ui/Button.astro";
import Card from "../ui/Card.astro";

export interface Props {
  showTopGradient?: boolean;
}

const { showTopGradient = true } = Astro.props;
---

<section class="py-20 bg-white relative overflow-hidden">
  <!-- Gradient overlay at top for seamless transition from Financing -->
  {showTopGradient && (
    <div class="absolute top-0 left-0 right-0 h-32 bg-gradient-to-b from-gray-50 to-transparent z-10"></div>
  )}
  
  <div class="max-w-7xl mx-auto px-6 relative z-20">
    
    <!-- Section Header -->
    <div id="featured-works-header" class="text-center mb-16">
      <p id="featured-works-label" class="text-brand-accent font-helvetica text-sm uppercase tracking-wider mb-4">
        FOLLOW US ON INSTAGRAM
      </p>
      <h2 id="featured-works-title" class="text-4xl lg:text-5xl font-asap-condensed uppercase tracking-wide font-bold text-gray-900 mb-6">
        See Our Work <span class="text-brand-primary">In Action</span>
      </h2>
      <p id="featured-works-description" class="text-lg text-gray-600 font-helvetica leading-relaxed max-w-4xl mx-auto">
        Follow @VoltBullyElectrical on Instagram to see our latest projects, behind-the-scenes work, and real-time updates. 
        From panel upgrades to complete installations, watch our expert team deliver quality electrical solutions across Los Angeles.
      </p>
    </div>

    <!-- Featured Works Grid -->
    <div id="featured-works-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      
      <!-- Instagram Post 1 -->
      <div id="featured-work-1">
        <Card
          variant="image"
          backgroundImage="/images/panel.webp"
          title=""
          description=""
          icon=""
        >
          <div class="flex items-center justify-center h-full opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <Button 
              variant="instagram" 
              size="sm"
              href="https://instagram.com"
            />
          </div>
        </Card>
      </div>

      <!-- Instagram Post 2 -->
      <div id="featured-work-2">
        <Card
          variant="image"
          backgroundImage="/images/smartHome.webp"
          title=""
          description=""
          icon=""
        >
          <div class="flex items-center justify-center h-full opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <Button 
              variant="instagram" 
              size="sm"
              href="https://instagram.com"
            />
          </div>
        </Card>
      </div>

      <!-- Instagram Post 3 -->
      <div id="featured-work-3">
        <Card
          variant="image"
          backgroundImage="/images/generator.webp"
          title=""
          description=""
          icon=""
        >
          <div class="flex items-center justify-center h-full opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <Button 
              variant="instagram" 
              size="sm"
              href="https://instagram.com"
            />
          </div>
        </Card>
      </div>

      <!-- Instagram Post 4 -->
      <div id="featured-work-4">
        <Card
          variant="image"
          backgroundImage="/images/rewiring.webp"
          title=""
          description=""
          icon=""
        >
          <div class="flex items-center justify-center h-full opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <Button 
              variant="instagram" 
              size="sm"
              href="https://instagram.com"
            />
          </div>
        </Card>
      </div>

      <!-- Instagram Post 5 -->
      <div id="featured-work-5">
        <Card
          variant="image"
          backgroundImage="/images/charging.webp"
          title=""
          description=""
          icon=""
        >
          <div class="flex items-center justify-center h-full opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <Button 
              variant="instagram" 
              size="sm"
              href="https://instagram.com"
            />
          </div>
        </Card>
      </div>

      <!-- Instagram Post 6 -->
      <div id="featured-work-6">
        <Card
          variant="image"
          backgroundImage="/images/lighting.webp"
          title=""
          description=""
          icon=""
        >
          <div class="flex items-center justify-center h-full opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <Button 
              variant="instagram" 
              size="sm"
              href="https://instagram.com"
            />
          </div>
        </Card>
      </div>
    </div>
    <div class="flex justify-center mt-8">
      <Button variant="instagram-pill">
        View All Projects
      </Button>
    </div>
  </div>
</section>
