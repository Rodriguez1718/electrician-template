---
import Button from "../ui/Button.astro";
import Card from "../ui/Card.astro";
---

<section class="py-20 bg-white relative overflow-hidden">
  <!-- Gradient overlay at top for seamless transition from Financing -->
  <div class="absolute top-0 left-0 right-0 h-32 bg-gradient-to-b from-gray-50 to-transparent z-10"></div>
  
  <div class="max-w-7xl mx-auto px-6 relative z-20">
    
    <!-- Section Header -->
    <div id="featured-works-header" class="text-center mb-16">
      <p id="featured-works-label" class="text-brand-accent font-helvetica text-sm uppercase tracking-wider mb-4">
        OUR WORKS
      </p>
      <h2 id="featured-works-title" class="text-4xl lg:text-5xl font-asap-condensed uppercase tracking-wide font-bold text-gray-900 mb-6">
        Our <span class="text-brand-primary">Featured</span> Works
      </h2>
      <p id="featured-works-description" class="text-lg text-gray-600 font-helvetica leading-relaxed max-w-4xl mx-auto">
        Quality electrical work is key to preventing costly repairs and ensuring the safety of your electrical system. 
        At VoltBully Electrical, our Featured Works showcase our commitment to excellence and professional craftsmanship in every project.
      </p>
    </div>

    <!-- Featured Works Grid -->
    <div id="featured-works-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      
      <!-- Commercial Panel Upgrade -->
      <div id="featured-work-1">
        <Card
          variant="service"
          title="Commercial Panel Upgrade"
          description="Complete electrical panel modernization for a 50,000 sq ft office building, including new 400-amp service and code compliance updates."
          icon='<div class="w-12 h-12 bg-brand-primary/20 rounded-lg flex items-center justify-center mb-4"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-brand-primary"><rect x="3" y="3" width="18" height="18" rx="2" ry="2" stroke="currentColor" stroke-width="2"/><circle cx="9" cy="9" r="2" stroke="currentColor" stroke-width="2"/><path d="M21 15.5c-1.5-1.5-4-1.5-5.5 0" stroke="currentColor" stroke-width="2"/><path d="M12 12l9 9" stroke="currentColor" stroke-width="2"/></svg></div>'
          category="Commercial"
          href="/projects/commercial-panel-upgrade"
        />
      </div>

      <!-- Residential Smart Home -->
      <div id="featured-work-2">
        <Card
          variant="default"
          title="Smart Home Integration"
          description="Full home automation system installation including smart switches, outlets, lighting controls, and integrated security systems."
          icon='<div class="w-12 h-12 bg-brand-primary/20 rounded-lg flex items-center justify-center mb-4"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-brand-primary"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" stroke="currentColor" stroke-width="2"/><polyline points="9,22 9,12 15,12 15,22" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="8" r="1" fill="currentColor"/></svg></div>'
          category="Residential"
          href="/projects/smart-home-integration"
        />
      </div>

      <!-- Emergency Generator -->
      <div id="featured-work-3">
        <Card
          variant="default"
          title="Backup Generator Installation"
          description="Whole-house 22kW standby generator with automatic transfer switch, providing seamless power during outages for critical systems."
          icon='<div class="w-12 h-12 bg-brand-primary/20 rounded-lg flex items-center justify-center mb-4"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-brand-primary"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>'
          category="Emergency"
          href="/projects/backup-generator"
        />
      </div>

      <!-- Industrial Rewiring -->
      <div id="featured-work-4">
        <Card
          variant="default"
          title="Industrial Facility Rewiring"
          description="Complete electrical infrastructure overhaul for manufacturing facility, including high-voltage distribution and machinery connections."
          icon='<div class="w-12 h-12 bg-brand-primary/20 rounded-lg flex items-center justify-center mb-4"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-brand-primary"><rect x="2" y="3" width="20" height="14" rx="2" ry="2" stroke="currentColor" stroke-width="2"/><line x1="8" y1="21" x2="16" y2="21" stroke="currentColor" stroke-width="2"/><line x1="12" y1="17" x2="12" y2="21" stroke="currentColor" stroke-width="2"/></svg></div>'
          category="Industrial"
          href="/projects/industrial-rewiring"
        />
      </div>

      <!-- EV Charging Station -->
      <div id="featured-work-5">
        <Card
          variant="default"
          title="EV Charging Station Network"
          description="Installation of Level 2 charging stations for apartment complex, including electrical upgrades and smart charging management system."
          icon='<div class="w-12 h-12 bg-brand-primary/20 rounded-lg flex items-center justify-center mb-4"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-brand-primary"><path d="M7 4a4.5 4.5 0 0 0 0 9v7a2 2 0 0 0 4 0v-7a4.5 4.5 0 0 0 0-9Z" stroke="currentColor" stroke-width="2"/><path d="M15 12v5a2 2 0 0 0 4 0v-5" stroke="currentColor" stroke-width="2"/></svg></div>'
          category="Specialty"
          href="/projects/ev-charging-network"
        />
      </div>

      <!-- Lighting Design -->
      <div id="featured-work-6">
        <Card
          variant="default"
          title="Architectural Lighting Design"
          description="Custom LED lighting installation for luxury hotel lobby, featuring programmable color-changing systems and energy-efficient controls."
          icon='<div class="w-12 h-12 bg-brand-primary/20 rounded-lg flex items-center justify-center mb-4"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-brand-primary"><circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="2"/><line x1="12" y1="1" x2="12" y2="3" stroke="currentColor" stroke-width="2"/><line x1="12" y1="21" x2="12" y2="23" stroke="currentColor" stroke-width="2"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64" stroke="currentColor" stroke-width="2"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78" stroke="currentColor" stroke-width="2"/><line x1="1" y1="12" x2="3" y2="12" stroke="currentColor" stroke-width="2"/><line x1="21" y1="12" x2="23" y2="12" stroke="currentColor" stroke-width="2"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36" stroke="currentColor" stroke-width="2"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22" stroke="currentColor" stroke-width="2"/></svg></div>'
          category="Commercial"
          href="/projects/architectural-lighting"
        />
      </div>
    </div>

    <div id="featured-works-cta" class="flex justify-center mt-8">
      <Button size="lg">
      View All Projects
    </Button>
    </div>
  </div>
</section>