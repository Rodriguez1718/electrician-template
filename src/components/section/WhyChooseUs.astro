---
import Button from "../ui/Button.astro";

export interface Props {
  roundedBottom?: boolean;
}

const { roundedBottom = true } = Astro.props;
const features: Array<{
  icon: string;
  title: string;
  description: string;
  color: 'primary' | 'secondary' | 'accent' | 'red';
}> = [
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>',
    title: "Licensed & Certified Electricians",
    description: "All our electricians are fully licensed, bonded, and insured with ongoing training in the latest electrical codes and safety standards.",
    color: "primary"
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>',
    title: "Transparent Pricing with No Surprises",
    description: "Upfront pricing with detailed estimates. No hidden fees, no surprise charges - just honest, competitive rates for quality work.",
    color: "accent"
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>',
    title: "Safety-First Approach Guaranteed",
    description: "We prioritize safety in every project with comprehensive inspections, code compliance, and industry-leading safety protocols.",
    color: "secondary"
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><polyline points="12,6 12,12 16,14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>',
    title: "24/7 Emergency Response",
    description: "Electrical emergencies don't wait. Our emergency response team is available around the clock for urgent electrical issues.",
    color: "red"
  }
];
---

<section class={`py-20 bg-black relative overflow-hidden ${roundedBottom ? 'rounded-bottom' : ''}`}>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      
      <!-- Left side - Content -->
      <div id="why-choose-content">
        <!-- Section header -->
        <div id="why-choose-header" class="mb-12" data-animate="slide-left">
          <p id="why-choose-label" class="text-brand-accent font-helvetica text-sm uppercase tracking-wider mb-4" data-animate="fade-only" data-delay="1">
            Welcome to VoltBully Electrical
          </p>
          <h2 id="why-choose-title" class="text-4xl lg:text-5xl font-asap-condensed uppercase font-bold text-white mb-6 leading-tight tracking-wide" data-animate="slide-left" data-delay="2">
            Expert <span class="text-brand-primary">Electrical Services</span> You Can Trust
          </h2>
          <p id="why-choose-description" class="text-lg text-white/80 font-helvetica leading-relaxed" data-animate="fade-only" data-delay="3">
            With over 18 years of experience, VoltBully has been the trusted choice for electrical services 
            throughout the region.
          </p>
        </div>

        <!-- Features list -->
        <div id="why-choose-features" class="space-y-6">
          {features.map((feature, index) => {
            const getColorClasses = (color: 'primary' | 'secondary' | 'accent' | 'red') => {
              const colors = {
                primary: { bg: 'bg-brand-primary/20', hoverBg: 'group-hover:bg-brand-primary/30', text: 'text-brand-primary', hoverText: 'group-hover:text-brand-primary' },
                secondary: { bg: 'bg-brand-secondary/20', hoverBg: 'group-hover:bg-brand-secondary/30', text: 'text-brand-secondary', hoverText: 'group-hover:text-brand-secondary' },
                accent: { bg: 'bg-brand-accent/20', hoverBg: 'group-hover:bg-brand-accent/30', text: 'text-brand-accent', hoverText: 'group-hover:text-brand-accent' },
                red: { bg: 'bg-red-500/20', hoverBg: 'group-hover:bg-red-500/30', text: 'text-red-600', hoverText: 'group-hover:text-red-600' }
              };
              return colors[color] || colors.primary;
            };
            const colorClasses = getColorClasses(feature.color);
            
            return (
              <div id={`feature-${index + 1}`} class="flex items-start gap-4 group" data-animate="slide-left" data-delay={index + 4}>
                <div class={`flex-shrink-0 w-12 h-12 ${colorClasses.bg} rounded-full flex items-center justify-center ${colorClasses.text} ${colorClasses.hoverBg} transition-colors duration-300`}>
                  <div set:html={feature.icon}></div>
                </div>
                <div>
                  <h3 class={`text-xl font-helvetica font-semibold text-white mb-2 ${colorClasses.hoverText} transition-colors duration-300`}>
                    {feature.title}
                  </h3>
                  <p class="text-white/70 font-helvetica leading-relaxed">
                    {feature.description}
                  </p>
                </div>
              </div>
            );
          })}
        </div>
      </div>

      <!-- Right side - Visual element -->
      <div id="why-choose-visual" class="relative" data-animate="slide-right" data-delay="1">
        <!-- SVG Clip Path Definition -->
        <svg width="0" height="0">
          <defs>
            <clipPath id="customClip" clipPathUnits="objectBoundingBox">
              <path d="M 0.000, 0.125 L 0.000, 0.125 Q 0.000, 0.000 0.125, 0.000 L 0.700, 0.000 Q 0.750, 0.000 0.750, 0.050 L 0.750, 0.205 Q 0.750, 0.250 0.795, 0.250 L 0.955, 0.250 Q 1.000, 0.250 1.000, 0.295 L 1.000, 0.855 Q 1.000, 0.950 0.905, 0.950 L 0.180, 0.950 Q 0.100, 0.950 0.100, 0.870 L 0.100, 0.770 Q 0.100, 0.750 0.080, 0.750 L 0.070, 0.750 Q 0.050, 0.750 0.050, 0.770 L 0.050, 0.980 Q 0.050, 1.000 0.030, 1.000 L 0.020, 1.000 Q 0.000, 1.000 0.000, 0.980 Z" />
            </clipPath>
          </defs>
        </svg>
        
        <!-- Clipped Image -->
        <img 
          id="why-choose-image"
          src="/images/wire.webp" 
          alt="Electrical wiring work" 
          class="clipped-element w-full h-[500px] object-cover"
          data-animate="scale"
          data-delay="2"
        />
        
        <!-- Experience Badge -->
        <div id="experience-badge" class="absolute top-1 right-3 border-2 border-brand-primary text-brand-primary p-3 rounded-lg shadow-lg" data-animate="scale" data-delay="3">
          <div class="text-center">
            <div class="text-3xl font-bold font-asap-condensed">15+</div>
            <div class="text-m font-asap-condensed uppercase tracking-wide">Years of</div>
            <div class="text-m font-asap-condensed uppercase tracking-wide">Experience</div>
          </div>
        </div>
        
        <!-- Main card -->
        
        <!-- CTA Button -->
        <div id="why-choose-cta" class="mt-10" data-animate="scale" data-delay="4">
          <Button variant="secondary" size="lg" href="/about">
            Learn More About Us
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Rounded bottom section */
  .rounded-bottom {
    border-bottom-left-radius: 50px;
    border-bottom-right-radius: 50px;
  }

  /* Responsive border radius */
  @media (min-width: 640px) {
    .rounded-bottom {
      border-bottom-left-radius: 100px;
      border-bottom-right-radius: 100px;
    }
  }

  @media (min-width: 768px) {
    .rounded-bottom {
      border-bottom-left-radius: 150px;
      border-bottom-right-radius: 150px;
    }
  }

  @media (min-width: 1024px) {
    .rounded-bottom {
      border-bottom-left-radius: 200px;
      border-bottom-right-radius: 200px;
    }
  }

  /* Alternative curved bottom using clip-path for more dramatic curve */
  .rounded-bottom::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 50px;
    background: inherit;
    clip-path: ellipse(100% 100% at 50% 0%);
  }


  /* Custom clip path for image */
  .clipped-element {
    clip-path: url(#customClip);
  }
</style>