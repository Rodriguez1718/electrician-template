---
import Button from "../ui/Button.astro";

export interface Props {
  backgroundColor?: 'white' | 'gray' | 'black';
}

const { backgroundColor = 'white' } = Astro.props;

const bgClasses = {
  white: 'bg-white',
  gray: 'bg-gray-50',
  black: 'bg-black'
};

const textClasses = {
  white: { primary: 'text-gray-900', secondary: 'text-gray-600', accent: 'text-brand-accent' },
  gray: { primary: 'text-gray-900', secondary: 'text-gray-600', accent: 'text-brand-accent' },
  black: { primary: 'text-white', secondary: 'text-white/80', accent: 'text-brand-accent' }
};

const inputClasses = {
  white: 'bg-white border-gray-300 text-gray-900 focus:border-brand-primary',
  gray: 'bg-white border-gray-300 text-gray-900 focus:border-brand-primary',
  black: 'bg-white/10 border-white/20 text-white placeholder-white/60 focus:border-brand-primary focus:bg-white/15'
};
---

<section class={`py-20 ${bgClasses[backgroundColor]}`}>
  <div class="max-w-7xl mx-auto px-6">
    
    <!-- Header -->
    <div class="text-center mb-16">
      <p class={`${textClasses[backgroundColor].accent} font-helvetica text-sm uppercase tracking-wider mb-4`}>
        GET IN TOUCH
      </p>
      <h2 class={`text-4xl lg:text-5xl font-asap-condensed uppercase font-bold ${textClasses[backgroundColor].primary} mb-6 leading-tight tracking-wide`}>
        Send Us a <span class="text-brand-primary">Message</span>
      </h2>
      <p class={`text-lg ${textClasses[backgroundColor].secondary} font-helvetica leading-relaxed max-w-3xl mx-auto`}>
        Ready to get started? Fill out the form below and our team will get back to you within 24 hours to discuss your electrical needs.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-16 items-start">
      
      <!-- Contact Form -->
      <div class="bg-black rounded-2xl p-8 border border-white/10">
        <form class="space-y-6" action="#" method="POST">
          
          <!-- Name Fields -->
          <div class="grid md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-helvetica font-medium text-white mb-2">
                First Name *
              </label>
              <input 
                type="text" 
                name="firstName"
                required
                class="w-full px-4 py-3 rounded-lg border bg-gray-700 border-gray-600 text-white placeholder-gray-400 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 transition-colors"
                placeholder="John"
              />
            </div>
            <div>
              <label class="block text-sm font-helvetica font-medium text-white mb-2">
                Last Name *
              </label>
              <input 
                type="text" 
                name="lastName"
                required
                class="w-full px-4 py-3 rounded-lg border bg-gray-700 border-gray-600 text-white placeholder-gray-400 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 transition-colors"
                placeholder="Doe"
              />
            </div>
          </div>

          <!-- Contact Fields -->
          <div class="grid md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-helvetica font-medium text-white mb-2">
                Email Address *
              </label>
              <input 
                type="email" 
                name="email"
                required
                class="w-full px-4 py-3 rounded-lg border bg-gray-700 border-gray-600 text-white placeholder-gray-400 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 transition-colors"
                placeholder="john@example.com"
              />
            </div>
            <div>
              <label class="block text-sm font-helvetica font-medium text-white mb-2">
                Phone Number
              </label>
              <input 
                type="tel"
                name="phone"
                class="w-full px-4 py-3 rounded-lg border bg-gray-700 border-gray-600 text-white placeholder-gray-400 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 transition-colors"
                placeholder="(303) 555-0123"
              />
            </div>
          </div>

          <!-- Service Type -->
          <div>
            <label class="block text-sm font-helvetica font-medium text-white mb-2">
              Service Needed *
            </label>
            <select 
              name="serviceType"
              required
              class="w-full px-4 py-3 rounded-lg border bg-gray-700 border-gray-600 text-white focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 transition-colors"
            >
              <option value="">Select a service...</option>
              <option value="residential">Residential Electrical</option>
              <option value="commercial">Commercial Electrical</option>
              <option value="emergency">Emergency Repair</option>
              <option value="ev-charging">EV Charging Station</option>
              <option value="panel-upgrade">Panel Upgrade</option>
              <option value="rewiring">Home Rewiring</option>
              <option value="lighting">Lighting Installation</option>
              <option value="generator">Backup Generator</option>
              <option value="other">Other</option>
            </select>
          </div>

          <!-- Project Timeline -->
          <div>
            <label class="block text-sm font-helvetica font-medium text-white mb-2">
              Project Timeline
            </label>
            <select 
              name="timeline"
              class="w-full px-4 py-3 rounded-lg border bg-gray-700 border-gray-600 text-white focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 transition-colors"
            >
              <option value="">When do you need this completed?</option>
              <option value="asap">As soon as possible</option>
              <option value="1-week">Within 1 week</option>
              <option value="1-month">Within 1 month</option>
              <option value="3-months">Within 3 months</option>
              <option value="planning">Just planning ahead</option>
            </select>
          </div>

          <!-- Message -->
          <div>
            <label class="block text-sm font-helvetica font-medium text-white mb-2">
              Project Details *
            </label>
            <textarea 
              name="message"
              required
              rows="5"
              class="w-full px-4 py-3 rounded-lg border bg-gray-700 border-gray-600 text-white placeholder-gray-400 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 transition-colors resize-none"
              placeholder="Please describe your electrical project or issue in detail. Include any specific requirements, locations, or concerns you may have..."
            ></textarea>
          </div>

          <!-- Submit Button -->
          <div class="pt-4">
            <Button variant="secondary" size="lg" type="submit" class="w-full">
              Send Message
            </Button>
            <p class="text-sm text-white/80 font-helvetica mt-3 text-center">
              We'll respond within 24 hours with a free estimate
            </p>
          </div>
        </form>
      </div>

      <!-- Contact Information & Benefits -->
      <div class="space-y-8 flex flex-col gap-6">
        
        <!-- Contact Details -->
        <div class={`${backgroundColor === 'black' ? 'bg-white/5' : 'bg-white'} rounded-2xl p-8 border border-white/10 shadow-2xl`}>
          <h3 class={`text-2xl font-asap-condensed font-bold ${textClasses[backgroundColor].primary} mb-6`}>
            Contact Information
          </h3>
          
          <div class="space-y-4">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-brand-primary/10 rounded-full flex items-center justify-center text-brand-primary">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div>
                <p class={`text-sm font-helvetica uppercase tracking-wider ${textClasses[backgroundColor].secondary}`}>
                  PHONE
                </p>
                <p class={`text-lg font-helvetica font-semibold ${textClasses[backgroundColor].primary}`}>
                  (303) 555-VOLT
                </p>
              </div>
            </div>

            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-brand-secondary/10 rounded-full flex items-center justify-center text-brand-secondary">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <polyline points="22,6 12,13 2,6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div>
                <p class={`text-sm font-helvetica uppercase tracking-wider ${textClasses[backgroundColor].secondary}`}>
                  EMAIL
                </p>
                <p class={`text-lg font-helvetica font-semibold ${textClasses[backgroundColor].primary}`}>
                  info@voltbully.com
                </p>
              </div>
            </div>

            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-brand-accent/10 rounded-full flex items-center justify-center text-brand-accent">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
                  <polyline points="12,6 12,12 16,14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div>
                <p class={`text-sm font-helvetica uppercase tracking-wider ${textClasses[backgroundColor].secondary}`}>
                  RESPONSE TIME
                </p>
                <p class={`text-lg font-helvetica font-semibold ${textClasses[backgroundColor].primary}`}>
                  Within 24 Hours
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Why Choose Us -->
        <div class={`${backgroundColor === 'black' ? 'bg-white/5' : 'bg-white'} rounded-2xl p-8 border border-white/10 shadow-2xl`}>
          <h3 class={`text-2xl font-asap-condensed font-bold ${textClasses[backgroundColor].primary} mb-6`}>
            Why Choose VoltBully?
          </h3>
          
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <div class="w-6 h-6 bg-brand-primary/20 rounded-full flex items-center justify-center text-brand-primary mt-0.5">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none">
                  <polyline points="20,6 9,17 4,12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div>
                <h4 class={`text-lg font-helvetica font-semibold ${textClasses[backgroundColor].primary} mb-1`}>
                  Licensed & Insured
                </h4>
                <p class={`text-sm ${textClasses[backgroundColor].secondary} font-helvetica`}>
                  Fully licensed electricians with comprehensive insurance coverage
                </p>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <div class="w-6 h-6 bg-brand-secondary/20 rounded-full flex items-center justify-center text-brand-secondary mt-0.5">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none">
                  <polyline points="20,6 9,17 4,12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div>
                <h4 class={`text-lg font-helvetica font-semibold ${textClasses[backgroundColor].primary} mb-1`}>
                  Free Estimates
                </h4>
                <p class={`text-sm ${textClasses[backgroundColor].secondary} font-helvetica`}>
                  No-obligation quotes with transparent, upfront pricing
                </p>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <div class="w-6 h-6 bg-brand-accent/20 rounded-full flex items-center justify-center text-brand-accent mt-0.5">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none">
                  <polyline points="20,6 9,17 4,12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div>
                <h4 class={`text-lg font-helvetica font-semibold ${textClasses[backgroundColor].primary} mb-1`}>
                  24/7 Emergency Service
                </h4>
                <p class={`text-sm ${textClasses[backgroundColor].secondary} font-helvetica`}>
                  Round-the-clock availability for urgent electrical issues
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>