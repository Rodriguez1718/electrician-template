<section class="py-20 bg-black text-white relative overflow-hidden">

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    
    <!-- Section Header -->
    <div class="text-center mb-16">
      <p class="text-brand-accent font-helvetica text-sm uppercase tracking-wider mb-4">
        SERVICE AREAS
      </p>
      <h2 class="text-4xl lg:text-5xl font-asap-condensed uppercase tracking-wide font-bold text-white mb-6">
        Expert Electrical Services in <span class="text-brand-primary">Your Area and Surrounding Areas</span>
      </h2>
      <p class="text-lg text-white/80 font-helvetica leading-relaxed max-w-4xl mx-auto">
        Looking for reliable electrical services in your area? We provide expert residential and commercial solutions 
        across the city, from panel upgrades to emergency repairs. Whether you need outlet installation, circuit repairs, 
        or advanced electrical system upgrades, our team is here to help. We also offer routine maintenance and 24/7 
        emergency services to keep your electrical system in top shape. Serving neighborhoods throughout the region, 
        we're committed to quality, efficiency, and customer satisfaction. Call us today to schedule your service!
      </p>
    </div>

    <!-- Service Areas Tags -->
    <div class="mb-12">
