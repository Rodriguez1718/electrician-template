---
import { getCollection } from 'astro:content';

export interface Props {
  title?: string;
  titleHighlight?: string;
  description?: string;
  primaryAreas?: string[];
  secondaryAreas?: string[];
  tertiaryAreas?: string[];
  mapTitle?: string;
}

const {
  title = "Expert Electrical Services in",
  titleHighlight = "Your Area and Surrounding Areas",
  description = "Expert electrical services across the region. From panel upgrades to emergency repairs, we provide reliable residential and commercial solutions with 24/7 availability.",
  primaryAreas = ["Denver", "Santa Monica", "Pasadena", "Glendale", "Eastside", "Northside", "Southside"],
  secondaryAreas = ["Oak Valley", "Pine Hills", "River Park", "Cedar Grove", "Maple Heights", "Willow Creek", "Sunset Ridge"],
  tertiaryAreas = ["Elmwood", "Brookside", "Silver Lake", "Golden Hills", "Fairview", "Highland Park"],
  mapTitle = "VoltBully Electrical Service Areas Map"
} = Astro.props;

// Fetch service areas from content collection with error handling
let serviceAreasCollection: any[] = [];
try {
  serviceAreasCollection = await getCollection('service-areas');
} catch (error) {
  console.error('Error loading service areas collection:', error);
}

// Create a map of area names to slugs and coordinates
const areaData: Record<string, { slug: string; lat: number; lng: number; zoom: number }> = {};
serviceAreasCollection.forEach(area => {
  areaData[area.data.city] = {
    slug: area.id.replace('.md', ''),
    lat: area.data.latitude,
    lng: area.data.longitude,
    zoom: area.data.zoom
  };
});

// Fallback coordinates for areas not in collection
const fallbackCoordinates: Record<string, { lat: number; lng: number; zoom: number }> = {
  "Santa Monica": { lat: 34.0195, lng: -118.4912, zoom: 13 },
  "Pasadena": { lat: 34.1478, lng: -118.1445, zoom: 13 },
  "Glendale": { lat: 34.1425, lng: -118.2551, zoom: 13 },
  "Eastside": { lat: 34.0522, lng: -118.1437, zoom: 12 },
  "Northside": { lat: 34.2522, lng: -118.2437, zoom: 12 },
  "Southside": { lat: 33.9522, lng: -118.2437, zoom: 12 },
  "Oak Valley": { lat: 34.0722, lng: -118.3437, zoom: 13 },
  "Pine Hills": { lat: 34.1122, lng: -118.2937, zoom: 13 },
  "River Park": { lat: 34.0322, lng: -118.3937, zoom: 13 },
  "Cedar Grove": { lat: 34.0922, lng: -118.4437, zoom: 13 },
  "Maple Heights": { lat: 34.1322, lng: -118.3437, zoom: 13 },
  "Willow Creek": { lat: 34.0122, lng: -118.4937, zoom: 13 },
  "Sunset Ridge": { lat: 34.0822, lng: -118.3937, zoom: 13 },
  "Elmwood": { lat: 34.0622, lng: -118.2937, zoom: 13 },
  "Brookside": { lat: 34.1022, lng: -118.3437, zoom: 13 },
  "Silver Lake": { lat: 34.0868, lng: -118.2705, zoom: 14 },
  "Golden Hills": { lat: 34.1222, lng: -118.2437, zoom: 13 },
  "Fairview": { lat: 34.0422, lng: -118.3437, zoom: 13 },
  "Highland Park": { lat: 34.1139, lng: -118.1887, zoom: 14 }
};

// Merge collection data with fallback coordinates
const areaCoordinates: Record<string, { lat: number; lng: number; zoom: number }> = {};
[...primaryAreas, ...secondaryAreas, ...tertiaryAreas].forEach(area => {
  if (areaData[area]) {
    areaCoordinates[area] = {
      lat: areaData[area].lat,
      lng: areaData[area].lng,
      zoom: areaData[area].zoom
    };
  } else if (fallbackCoordinates[area]) {
    areaCoordinates[area] = fallbackCoordinates[area];
  }
});

// Helper function to convert area name to slug
function toSlug(name: string): string {
  return name.toLowerCase().replace(/\s+/g, '-');
}
---

<section class="py-20 bg-black text-white relative overflow-hidden">

  <!-- Background decoration - VoltBully logo -->
  <div class="absolute left-0 top-1/3 transform -translate-y-1/2 translate-x-1/4 opacity-20 pointer-events-none z-0">
    <img 
      src="/images/voltbull.webp" 
      alt="VoltBully Background Decoration" 
      class="w-96 h-96 object-contain"
    />
  </div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    
    <!-- Section Header -->
    <div id="service-areas-header" class="text-center mb-16">
      <p id="service-areas-label" class="text-brand-accent font-helvetica text-sm uppercase tracking-wider mb-4">
        SERVICE AREAS
      </p>
      <h2 id="service-areas-title" class="text-4xl lg:text-5xl font-asap-condensed uppercase tracking-wide font-bold text-white mb-6">
        {title} <span class="text-brand-primary">{titleHighlight}</span>
      </h2>
      <p id="service-areas-description" class="text-lg text-white/80 font-helvetica leading-relaxed max-w-4xl mx-auto">
        {description}
      </p>
    </div>

    <!-- Service Areas Tags -->
    <div id="service-areas-tags" class="mb-12">
      <!-- First Row - Primary Areas -->
      <div id="service-areas-row-1" class="flex flex-wrap justify-center gap-4 mb-8">
        {primaryAreas.map((area, index) => {
          const hasPage = areaData[area];
          const slug = hasPage ? areaData[area].slug : toSlug(area);
          
          return hasPage ? (
            <a 
              id={`service-area-tag-${index + 1}`}
              data-area={area}
              class="area-tag flex items-center gap-2 px-4 py-2 bg-brand-primary/20 text-brand-primary rounded-full border border-brand-primary/30 hover:bg-brand-primary/30 transition-all duration-300 hover:scale-105 active:scale-95"
              aria-label={`View ${area} service area page`}
            >
              <div class="w-2 h-2 bg-brand-primary rounded-full"></div>
              <span class="font-helvetica text-sm font-medium">{area}</span>
            </a>
          ) : (
            <button 
              id={`service-area-tag-${index + 1}`}
              data-area={area}
              class="area-tag flex items-center gap-2 px-4 py-2 bg-brand-primary/20 text-brand-primary rounded-full border border-brand-primary/30 hover:bg-brand-primary/30 transition-all duration-300 hover:scale-105 active:scale-95"
              aria-label={`View ${area} on map`}
            >
              <div class="w-2 h-2 bg-brand-primary rounded-full"></div>
              <span class="font-helvetica text-sm font-medium">{area}</span>
            </button>
          );
        })}
      </div>
      
      <!-- Second Row - Secondary Areas -->
      <div id="service-areas-row-2" class="flex flex-wrap justify-center gap-4">
        {secondaryAreas.map((area, index) => {
          const hasPage = areaData[area];
          const slug = hasPage ? areaData[area].slug : toSlug(area);
          
          return hasPage ? (
            <a 
              href={`/service-areas/${slug}`}
              id={`service-area-tag-${primaryAreas.length + index + 1}`}
              data-area={area}
              class="area-tag flex items-center gap-2 px-4 py-2 bg-brand-accent/20 text-brand-accent rounded-full border border-brand-accent/30 hover:bg-brand-accent/30 transition-all duration-300 hover:scale-105 active:scale-95"
              aria-label={`View ${area} service area page`}
            >
              <div class="w-2 h-2 bg-brand-accent rounded-full"></div>
              <span class="font-helvetica text-sm font-medium">{area}</span>
            </a>
          ) : (
            <button 
              id={`service-area-tag-${primaryAreas.length + index + 1}`}
              data-area={area}
              class="area-tag flex items-center gap-2 px-4 py-2 bg-brand-accent/20 text-brand-accent rounded-full border border-brand-accent/30 hover:bg-brand-accent/30 transition-all duration-300 hover:scale-105 active:scale-95"
              aria-label={`View ${area} on map`}
            >
              <div class="w-2 h-2 bg-brand-accent rounded-full"></div>
              <span class="font-helvetica text-sm font-medium">{area}</span>
            </button>
          );
        })}
      </div>
      
      <!-- Third Row - Tertiary Areas -->
      <div id="service-areas-row-3" class="flex flex-wrap justify-center gap-4 mt-4">
        {tertiaryAreas.map((area, index) => {
          const hasPage = areaData[area];
          const slug = hasPage ? areaData[area].slug : toSlug(area);
          
          return hasPage ? (
            <a 
              href={`/service-areas/${slug}`}
              id={`service-area-tag-${primaryAreas.length + secondaryAreas.length + index + 1}`}
              data-area={area}
              class="area-tag flex items-center gap-2 px-4 py-2 bg-white/10 text-white/80 rounded-full border border-white/20 hover:bg-white/20 transition-all duration-300 hover:scale-105 active:scale-95"
              aria-label={`View ${area} service area page`}
            >
              <div class="w-2 h-2 bg-white/60 rounded-full"></div>
              <span class="font-helvetica text-sm font-medium">{area}</span>
            </a>
          ) : (
            <button 
              id={`service-area-tag-${primaryAreas.length + secondaryAreas.length + index + 1}`}
              data-area={area}
              class="area-tag flex items-center gap-2 px-4 py-2 bg-white/10 text-white/80 rounded-full border border-white/20 hover:bg-white/20 transition-all duration-300 hover:scale-105 active:scale-95"
              aria-label={`View ${area} on map`}
            >
              <div class="w-2 h-2 bg-white/60 rounded-full"></div>
              <span class="font-helvetica text-sm font-medium">{area}</span>
            </button>
          );
        })}
      </div>
    </div>

    <!-- Interactive Map -->
    <div id="service-areas-map" class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-2xl overflow-hidden h-96 shadow-2xl">
      <div id="map" class="w-full h-full"></div>
    </div>
  </div>
</section>

<!-- Leaflet CSS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<!-- Leaflet JS -->
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script define:vars={{ areaCoordinates }}>
  // Wait for Leaflet to load
  function initMap() {
    if (typeof L === 'undefined') {
      setTimeout(initMap, 100);
      return;
    }

    // Initialize map with default view (Los Angeles area)
    const map = L.map('map', {
      zoomControl: true,
      scrollWheelZoom: true,
      dragging: true,
      doubleClickZoom: true
    }).setView([34.0522, -118.2437], 10);

    // Add OpenStreetMap tiles
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      maxZoom: 19
    }).addTo(map);

    // Store markers for each area
    const markers = {};

    // Add markers for all areas
    Object.keys(areaCoordinates).forEach(areaName => {
      const coords = areaCoordinates[areaName];
      
      // Check if this area has a dedicated page (Denver, Santa Monica, Pasadena, Glendale)
      const areasWithPages = ['Denver', 'Santa Monica', 'Pasadena', 'Glendale'];
      const hasPage = areasWithPages.includes(areaName);
      const slug = areaName.toLowerCase().replace(/\s+/g, '-');
      
      // Create popup content with optional button
      let popupContent = `<div style="text-align: center; padding: 8px;">
        <strong style="font-size: 16px; color: #1f2937;">${areaName}</strong>
        <p style="margin: 4px 0; color: #6b7280; font-size: 14px;">VoltBully Service Area</p>`;
      
      if (hasPage) {
        popupContent += `
        <a href="/service-areas/${slug}" 
           style="display: inline-block; margin-top: 8px; padding: 8px 16px; background-color: #FF6B35; color: white; text-decoration: none; border-radius: 6px; font-size: 14px; font-weight: 600; transition: background-color 0.2s;"
           onmouseover="this.style.backgroundColor='#e55a2b'" 
           onmouseout="this.style.backgroundColor='#FF6B35'">
          View Details
        </a>`;
      }
      
      popupContent += `</div>`;
      
      const marker = L.marker([coords.lat, coords.lng])
        .bindPopup(popupContent)
        .addTo(map);
      markers[areaName] = marker;
    });

    // Get all area tag buttons
    const areaTags = document.querySelectorAll('.area-tag');

    // Add click event listeners to all area tags
    areaTags.forEach(tag => {
      tag.addEventListener('click', function() {
        const areaName = this.getAttribute('data-area');
        const coordinates = areaCoordinates[areaName];

        if (coordinates) {
          // Remove active state from all tags
          areaTags.forEach(t => {
            t.classList.remove('ring-2', 'ring-white', 'ring-offset-2', 'ring-offset-black');
          });

          // Add active state to clicked tag
          this.classList.add('ring-2', 'ring-white', 'ring-offset-2', 'ring-offset-black');

          // Smooth fly to the location with zoom animation
          map.flyTo([coordinates.lat, coordinates.lng], coordinates.zoom, {
            duration: 2, // 2 seconds animation
            easeLinearity: 0.25
          });

          // Open the marker popup after animation
          setTimeout(() => {
            if (markers[areaName]) {
              markers[areaName].openPopup();
            }
          }, 2000);
        }
      });
    });
  }

  // Initialize map when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMap);
  } else {
    initMap();
  }
</script>