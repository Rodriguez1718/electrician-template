---
export interface Props {
  title?: string;
  titleHighlight?: string;
  description?: string;
  primaryAreas?: string[];
  secondaryAreas?: string[];
  tertiaryAreas?: string[];
  mapEmbedUrl?: string;
  mapTitle?: string;
}

const {
  title = "Expert Electrical Services in",
  titleHighlight = "Your Area and Surrounding Areas",
  description = "Expert electrical services across the region. From panel upgrades to emergency repairs, we provide reliable residential and commercial solutions with 24/7 availability.",
  primaryAreas = ["Downtown", "Midtown", "Uptown", "Westside", "Eastside", "Northside", "Southside"],
  secondaryAreas = ["Oak Valley", "Pine Hills", "River Park", "Cedar Grove", "Maple Heights", "Willow Creek", "Sunset Ridge"],
  tertiaryAreas = ["Elmwood", "Brookside", "Silver Lake", "Golden Hills", "Fairview", "Highland Park"],
  mapEmbedUrl = "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d423286.27405770525!2d-118.69192113701158!3d34.02016130653294!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x80c2c75ddc27da13%3A0xe22fdf6f254608f4!2sLos%20Angeles%2C%20CA!5e0!3m2!1sen!2sus!4v1703123456789!5m2!1sen!2sus",
  mapTitle = "VoltBully Electrical Service Areas Map"
} = Astro.props;
---

<section class="py-20 bg-black text-white relative overflow-hidden">

  <!-- Background decoration - VoltBully logo -->
  <div class="absolute left-0 top-1/3 transform -translate-y-1/2 translate-x-1/4 opacity-20 pointer-events-none z-0">
    <img 
      src="/images/voltbull.webp" 
      alt="VoltBully Background Decoration" 
      class="w-96 h-96 object-contain"
    />
  </div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    
    <!-- Section Header -->
    <div id="service-areas-header" class="text-center mb-16">
      <p id="service-areas-label" class="text-brand-accent font-helvetica text-sm uppercase tracking-wider mb-4">
        SERVICE AREAS
      </p>
      <h2 id="service-areas-title" class="text-4xl lg:text-5xl font-asap-condensed uppercase tracking-wide font-bold text-white mb-6">
        {title} <span class="text-brand-primary">{titleHighlight}</span>
      </h2>
      <p id="service-areas-description" class="text-lg text-white/80 font-helvetica leading-relaxed max-w-4xl mx-auto">
        {description}
      </p>
    </div>

    <!-- Service Areas Tags -->
    <div id="service-areas-tags" class="mb-12">
      <!-- First Row - Primary Areas -->
      <div id="service-areas-row-1" class="flex flex-wrap justify-center gap-4 mb-8">
        {primaryAreas.map((area, index) => (
          <div id={`service-area-tag-${index + 1}`} class="flex items-center gap-2 px-4 py-2 bg-brand-primary/20 text-brand-primary rounded-full border border-brand-primary/30 hover:bg-brand-primary/30 transition-colors duration-300">
            <div class="w-2 h-2 bg-brand-primary rounded-full"></div>
            <span class="font-helvetica text-sm font-medium">{area}</span>
          </div>
        ))}
      </div>
      
      <!-- Second Row - Secondary Areas -->
      <div id="service-areas-row-2" class="flex flex-wrap justify-center gap-4">
        {secondaryAreas.map((area, index) => (
          <div id={`service-area-tag-${primaryAreas.length + index + 1}`} class="flex items-center gap-2 px-4 py-2 bg-brand-accent/20 text-brand-accent rounded-full border border-brand-accent/30 hover:bg-brand-accent/30 transition-colors duration-300">
            <div class="w-2 h-2 bg-brand-accent rounded-full"></div>
            <span class="font-helvetica text-sm font-medium">{area}</span>
          </div>
        ))}
      </div>
      
      <!-- Third Row - Tertiary Areas -->
      <div id="service-areas-row-3" class="flex flex-wrap justify-center gap-4 mt-4">
        {tertiaryAreas.map((area, index) => (
          <div id={`service-area-tag-${primaryAreas.length + secondaryAreas.length + index + 1}`} class="flex items-center gap-2 px-4 py-2 bg-white/10 text-white/80 rounded-full border border-white/20 hover:bg-white/20 transition-colors duration-300">
            <div class="w-2 h-2 bg-white/60 rounded-full"></div>
            <span class="font-helvetica text-sm font-medium">{area}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Interactive Map -->
    <div id="service-areas-map" class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-2xl overflow-hidden h-96 shadow-2xl">
      <iframe 
        src={mapEmbedUrl}
        width="100%" 
        height="100%" 
        style="border:0;" 
        allowfullscreen="" 
        loading="lazy" 
        referrerpolicy="no-referrer-when-downgrade"
        title={mapTitle}>
      </iframe>
    </div>
  </div>
</section>