---
// Company logos data - electrical industry partners and suppliers
// Using Simple Icons CDN for brand logos
const companies = [
  { name: "Tesla", logo: "https://cdn.simpleicons.org/tesla/white", alt: "Tesla Logo" },
  { name: "General Electric", logo: "https://cdn.simpleicons.org/generalelectric/white", alt: "General Electric Logo" },
  { name: "Schneider Electric", logo: "https://cdn.simpleicons.org/schneiderelectric/white", alt: "Schneider Electric Logo" },
  { name: "Siemens", logo: "https://cdn.simpleicons.org/siemens/white", alt: "Siemens Logo" },
  { name: "Mitsubishi", logo: "https://cdn.simpleicons.org/mitsubishi/white", alt: "Mitsubishi Logo" },
  { name: "ABB", logo: "https://cdn.simpleicons.org/abb/white", alt: "ABB Logo" },
];
---

<section id="company-logos" class="py-12 -mb-px relative logos-section">
  <div class="max-w-7xl mx-auto">
    
    <!-- Scrolling Logo Carousel with mask -->
    <div class="logos-carousel-container">
      <div class="logos-carousel-row">
        <div class="logos-carousel-track">
          {/* First set of logos */}
          {companies.map((company) => (
            <div class="logo-item group">
              <img
                src={company.logo}
                alt={company.alt}
                class="h-16 md:h-20 lg:h-24 w-auto object-contain opacity-100 group-hover:scale-105 transition-all duration-300"
                loading="lazy"
              />
            </div>
          ))}
          {/* Duplicate set for seamless loop */}
          {companies.map((company) => (
            <div class="logo-item group">
              <img
                src={company.logo}
                alt={company.alt}
                class="h-16 md:h-20 lg:h-24 w-auto object-contain opacity-100 group-hover:scale-105 transition-all duration-300"
                loading="lazy"
              />
            </div>
          ))}
          {/* Third set for extra smoothness */}
          {companies.map((company) => (
            <div class="logo-item group">
              <img
                src={company.logo}
                alt={company.alt}
                class="h-16 md:h-20 lg:h-24 w-auto object-contain opacity-100 group-hover:scale-105 transition-all duration-300"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .logos-section {
    overflow: hidden;
  }

  .logos-carousel-container {
    position: relative;
    overflow: hidden;
    /* CSS mask for smooth fade edges */
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 15%,
      black 85%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 15%,
      black 85%,
      transparent 100%
    );
  }

  .logos-carousel-row {
    overflow: visible;
    white-space: nowrap;
    position: relative;
  }

  .logos-carousel-track {
    display: inline-flex;
    gap: 2rem;
    align-items: center;
    will-change: transform;
    animation: logoScrollRight 30s linear infinite;
  }

  @media (min-width: 768px) {
    .logos-carousel-track {
      gap: 4rem;
    }
  }

  /* Pause animation on hover */
  .logos-carousel-container:hover .logos-carousel-track {
    animation-play-state: paused;
  }

  .logo-item {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 2rem;
    min-width: 180px;
    opacity: 1;
    transition: opacity 0.3s ease;
  }

  .logo-item img {
    display: block;
    max-width: 180px;
    /* Ensure bright white logos with high contrast */
    filter: brightness(2) contrast(1.3);
  }

  /* Infinite scroll animation */
  @keyframes logoScrollRight {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-33.333%);
    }
  }

  /* Logos are already white from CDN, no filter needed */
</style>