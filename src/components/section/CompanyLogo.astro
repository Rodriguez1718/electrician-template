---
// Company logos data - electrical industry partners and suppliers
const companies = [
  { name: "Tesla", logo: "/logos/tesla.svg", alt: "Tesla Logo" },
  { name: "General Electric", logo: "/logos/ge.svg", alt: "General Electric Logo" },
  { name: "Schneider Electric", logo: "/logos/schneider.svg", alt: "Schneider Electric Logo" },
  { name: "Siemens", logo: "/logos/siemens.svg", alt: "Siemens Logo" },
  { name: "Eaton", logo: "/logos/eaton.svg", alt: "Eaton Logo" },
  { name: "ABB", logo: "/logos/abb.svg", alt: "ABB Logo" },
];
---

<section id="company-logos" class="py-12 -mb-px relative logos-section">
  <div class="max-w-7xl mx-auto">
    
    <!-- Scrolling Logo Carousel with mask -->
    <div class="logos-carousel-container">
      <div class="logos-carousel-row">
        <div class="logos-carousel-track">
          {/* First set of logos */}
          {companies.map((company, index) => (
            <div class="logo-item group">
              <img
                src={company.logo}
                alt={company.alt}
                class="h-16 md:h-20 lg:h-24 w-auto object-contain opacity-70 group-hover:opacity-100 transition-opacity duration-300"
                loading="lazy"
              />
            </div>
          ))}
          {/* Duplicate set for seamless loop */}
          {companies.map((company, index) => (
            <div class="logo-item group">
              <img
                src={company.logo}
                alt={company.alt}
                class="h-16 md:h-20 lg:h-24 w-auto object-contain opacity-70 group-hover:opacity-100 transition-opacity duration-300"
                loading="lazy"
              />
            </div>
          ))}
          {/* Third set for extra smoothness */}
          {companies.map((company, index) => (
            <div class="logo-item group">
              <img
                src={company.logo}
                alt={company.alt}
                class="h-16 md:h-20 lg:h-24 w-auto object-contain opacity-70 group-hover:opacity-100 transition-opacity duration-300"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .logos-section {
    overflow: hidden;
  }

  .logos-carousel-container {
    position: relative;
    overflow: hidden;
    /* CSS mask for smooth fade edges */
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 15%,
      black 85%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 15%,
      black 85%,
      transparent 100%
    );
  }

  .logos-carousel-row {
    overflow: visible;
    white-space: nowrap;
    position: relative;
  }

  .logos-carousel-track {
    display: inline-flex;
    gap: 4rem;
    align-items: center;
    will-change: transform;
    animation: logoScrollRight 30s linear infinite;
  }

  /* Pause animation on hover */
  .logos-carousel-container:hover .logos-carousel-track {
    animation-play-state: paused;
  }

  .logo-item {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 2rem;
    min-width: 180px;
    opacity: 1;
    transition: opacity 0.3s ease;
  }

  .logo-item img {
    display: block;
    max-width: 180px;
  }

  /* Infinite scroll animation */
  @keyframes logoScrollRight {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-33.333%);
    }
  }

  /* Force SVG logos to be white */
  .logo-item img[src*="/logos/"] {
    filter: brightness(0) invert(1);
  }

  /* Maintain white color on hover */
  .logo-item:hover img[src*="/logos/"] {
    filter: brightness(0) invert(1);
  }
</style>