---
export interface Props {
  roundedBottom?: boolean;
  whyTrustUs?: {
    title?: string;
    titleHighlight?: string;
    reasons?: Array<{
      title: string;
      description: string;
      icon: string;
    }>;
  };
}


const { roundedBottom = false } = Astro.props;
const { whyTrustUs } = Astro.props;

const title = whyTrustUs?.title || "Why";
const titleHighlight = whyTrustUs?.titleHighlight || "Residents Trust Us";
const reasons = whyTrustUs?.reasons || [
  {
    title: "Local Knowledge",
    description: "With years of experience serving the area, we understand the specific electrical needs of your community.",
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="2"/></svg>'
  },
  {
    title: "Prompt Response",
    description: "We prioritize fast and reliable service, ensuring issues are resolved quickly and efficiently.",
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><path d="M12 6v6l4 2" stroke="currentColor" stroke-width="2"/></svg>'
  },
  {
    title: "Comprehensive Services",
    description: "From minor repairs to major installations, we handle it all with precision and care.",
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" stroke="currentColor" stroke-width="2"/></svg>'
  }
];
---

<section class=`py-20 bg-black relative overflow-hidden ${roundedBottom ? 'rounded-bottom' : ''}`>
  <div class="max-w-7xl mx-auto px-6">
    
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-4xl lg:text-5xl font-asap-condensed font-bold text-white mb-6 uppercase">
        {title} <span class="text-brand-primary">{titleHighlight}</span>
      </h2>
    </div>

    <!-- Reasons Grid -->
    <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      {reasons.map((reason) => (
        <div class="reason-card bg-white border border-gray-200 rounded-xl p-8 hover:border-brand-primary hover:shadow-xl hover:-translate-y-2 transition-all duration-300 group">
          <div class="flex justify-center mb-6">
            <div class="w-14 h-14 bg-gray-900 rounded-lg flex items-center justify-center group-hover:bg-brand-primary transition-colors duration-300">
              <div class="text-white" set:html={reason.icon} />
            </div>
          </div>
          <h3 class="text-xl font-asap-condensed font-bold text-gray-900 mb-3 text-center group-hover:text-brand-primary transition-colors duration-300">
            {reason.title}
          </h3>
          <p class="text-gray-600 font-helvetica leading-relaxed text-center">
            {reason.description}
          </p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* Rounded bottom section */
  .rounded-bottom {
    border-bottom-left-radius: 50px;
    border-bottom-right-radius: 50px;
  }

  /* Responsive border radius */
  @media (min-width: 640px) {
    .rounded-bottom {
      border-bottom-left-radius: 100px;
      border-bottom-right-radius: 100px;
    }
  }

  @media (min-width: 768px) {
    .rounded-bottom {
      border-bottom-left-radius: 150px;
      border-bottom-right-radius: 150px;
    }
  }

  @media (min-width: 1024px) {
    .rounded-bottom {
      border-bottom-left-radius: 200px;
      border-bottom-right-radius: 200px;
    }
  }
</style>
