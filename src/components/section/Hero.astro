---
import Button from "../ui/Button.astro"

---

<section class="relative w-full min-h-screen overflow-hidden">
    <!-- Removed background div since it's now global -->

    <div class="flex flex-col min-[1180px]:block h-full">
        <h1
            id="hero-headline"
            class="relative min-[1180px]:absolute left-3 font-playfair font-black text-white pointer-events-none select-none flex flex-col leading-[0.88] tracking-tight hero-headline"
            aria-label="VoltBully Electrical Services"
            style="top: clamp(120px, 15vh, 200px);"
            data-animate="fade-only"
        >
            <span id="hero-word-1" class="relative offset-left-0" data-animate="slide-left" data-delay="1">WIRING</span>
            <span id="hero-word-2" class="relative" style="left: clamp(0rem, 15vw, 18rem);" data-animate="slide-left" data-delay="2">YOUR</span>
            <span id="hero-word-3" class="relative text-emerald-500" style="left: clamp(0rem, 16vw, 19rem);" data-animate="slide-left" data-delay="3">SUCCESS</span>
        </h1>

        <div
            id="hero-content"
            class="content-container relative min-[1180px]:absolute max-w-[590px] flex flex-col gap-7 z-10 px-8 mt-8 min-[1180px]:mt-0 mx-auto min-[1180px]:mx-0"
            data-animate="slide-right"
            data-delay="4"
        >
            <p id="hero-description" class="text-[22px] text-white/80 leading-[1.75] font-helvetica" data-animate="fade-only" data-delay="5">
                We don't just wire buildings — we build the backbone of your
                operation. From ground up construction to full panel fit-outs, every
                job is permitted, on-time, and built to last decades.
            </p>

            <div id="hero-actions" class="flex flex-row items-center gap-16 mt-0 2xl:mt-20" data-animate="scale" data-delay="6">
                <Button variant="sketchy" size="md" href="/"/>
                <span class="text-white font-helvetica text-xl">CALL NOW</span>
            </div>
        </div>
    </div>


</section>

<style>

    .font-playfair {
        font-family: "Playfair Display", Georgia, serif;
    }

    .hero-headline {
        font-size: clamp(172px, 13vw, 272px);
    }

    .content-container {
        top: clamp(120px, 18vh, 200px);
    }

    @media (min-width: 1180px) {
        .content-container {
            top: clamp(120px, 18vh, 200px);
            left: calc(12px + clamp(400px, 55vw, 1000px));
        }
    }

    @media (max-width: 1179px) {
        .hero-headline {
            font-size: clamp(80px, 10vw, 140px);
        }
    }

    @media (max-width: 768px) {
        .hero-headline {
            font-size: clamp(60px, 12vw, 100px);
        }
    }

    @media (max-width: 480px) {
        .hero-headline {
            font-size: clamp(40px, 15vw, 80px);
        }
    }
</style>
