---
import Button from "../ui/Button.astro"
---

<section class="relative w-full min-h-[83vh] md:min-h-[80vh] overflow-hidden">

    <div class="flex flex-col min-[1180px]:block h-full">
        <h1
            id="hero-headline"
            class="relative min-[1180px]:absolute left-3 font-playfair font-black text-white pointer-events-none select-none flex flex-col leading-[0.88] tracking-tight hero-headline"
            aria-label="VoltBully Electrical Services"
            style="top: clamp(120px, 15vh, 200px);"
            data-animate="fade-only"
        >
            <span id="hero-word-1" class="relative offset-left-0" data-animate="slide-left" data-delay="1">LICENSED.</span>
            <span id="hero-word-2" class="relative" style="left: clamp(0rem, 15vw, 18rem);" data-animate="slide-left" data-delay="2">LOCAL.</span>
            <span id="hero-word-3" class="relative text-emerald-500" style="left: clamp(0rem, 8vw, 12rem);" data-animate="slide-left" data-delay="3">RELIABLE.</span>
        </h1>

        <!-- Right side content container -->
        <div
            id="hero-right-content"
            class="right-content-container relative min-[1180px]:absolute z-10 px-8 min-[1180px]:mt-0 mx-auto min-[1180px]:mx-0"
            data-animate="fade-only"
            data-delay="4"
        >
            <!-- Subheading: what you do + where -->
            <p
                id="hero-subheading"
                class="text-white/80 font-helvetica text-sm sm:text-base text-center mb-5 leading-relaxed"
                data-animate="fade-only"
                data-delay="5"
            >
                Residential &amp; commercial electrical services.<br />
                Available 24/7 for emergencies.
            </p>

            <!-- CTA Button -->
            <div id="hero-actions" class="flex justify-center mb-4" data-animate="scale" data-delay="6">
                <Button variant="primary" size="lg" href="/contact">
                    SCHEDULE A SERVICE
                </Button>
            </div>

            <!-- Trust signals — directly under the button -->
            <div
                id="hero-trust"
                class="flex flex-wrap justify-center items-center gap-x-3 gap-y-1 mb-6"
                data-animate="fade-only"
                data-delay="7"
            >
                <span class="trust-badge">
                    <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                    Licensed &amp; Insured
                </span>
                <span class="trust-divider">·</span>
                <span class="trust-badge">
                    <svg class="trust-icon" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                    5★ Rated
                </span>
                <span class="trust-divider">·</span>
                <span class="trust-badge">
                    <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/>
                        <path d="M12 6v6l4 2"/>
                    </svg>
                    Same-Day Available
                </span>
            </div>

            <!-- Special Offer Coupon — subtle supporting element -->
            <div id="hero-coupon" data-animate="fade-only" data-delay="8">
              <div class="hero-coupon-wrapper max-w-[350px] mx-auto">
                <div class="hero-coupon-card">
                  <div class="bg-gray-700/80 text-white p-3 sm:p-4 relative overflow-hidden border border-white/20">
                    <!-- Simplified decorative elements -->
                    <div class="absolute top-0 left-0 w-3 h-3 bg-black/50 rounded-br-full"></div>
                    <div class="absolute top-0 right-0 w-3 h-3 bg-black/50 rounded-bl-full"></div>
                    <div class="absolute bottom-0 left-0 w-3 h-3 bg-black/50 rounded-tr-full"></div>
                    <div class="absolute bottom-0 right-0 w-3 h-3 bg-black/50 rounded-tl-full"></div>

                    <div class="text-center relative z-10">
                      <p class="text-xs font-helvetica font-medium mb-2 uppercase tracking-wide opacity-80">Limited Time</p>
                      <div class="flex items-center justify-center gap-3 mb-2">
                        <div class="bg-white/90 text-gray-800 px-3 sm:px-4 py-1.5 font-bold text-lg sm:text-xl font-asap-condensed shadow-sm">
                          $100 OFF
                        </div>
                      </div>
                      <p class="text-sm sm:text-base font-helvetica font-medium mb-1">Your First Service</p>
                      <p class="text-xs opacity-70 font-helvetica">New customers • Min $500 • Code: VOLTBULLY100</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>

        </div>
    </div>

</section>

<style>
    .font-playfair {
        font-family: "Playfair Display", Georgia, serif;
    }

    .hero-headline {
        font-size: clamp(120px, 10vw, 200px);
    }

    /* Adaptive font sizing based on available space for right content */
    @media (min-width: 1400px) {
        /* Large screens - can use bigger font */
        .hero-headline {
            font-size: clamp(140px, 12vw, 220px);
        }
    }

    @media (max-width: 1399px) and (min-width: 1200px) {
        /* Medium-large screens - moderate size */
        .hero-headline {
            font-size: clamp(110px, 9vw, 180px);
        }
    }

    @media (max-width: 1199px) and (min-width: 1180px) {
        /* Just above tablet - more compact to make room */
      
        #hero-word-3 {
            left: clamp(0rem, 6vw, 10rem) !important;
        }
    }

    /* Right content container positioning */
    .right-content-container {
        top: clamp(180px, 25vh, 280px);
        max-width: 480px;
    }

    @media (min-width: 1180px) {
        .right-content-container {
            right: clamp(20px, 5vw, 80px);
            left: auto;
        }
    }

    /* Trust badges */
    .trust-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        font-size: 0.875rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.85);
        letter-spacing: 0.02em;
        white-space: nowrap;
    }

    .trust-icon {
        width: 15px;
        height: 15px;
        color: #98d9a1;
        flex-shrink: 0;
    }

    .trust-divider {
        color: rgba(255, 255, 255, 0.3);
        font-size: 0.875rem;
    }

    /* Coupon — toned down to support CTA, not compete */
    .hero-coupon-wrapper {
        animation: none; /* Remove pulsing animation */
        opacity: 0.75; /* More subtle */
        transition: opacity 0.3s ease;
    }
    
    .hero-coupon-wrapper:hover {
        opacity: 0.9; /* Slight increase on hover */
    }

    .hero-coupon-card {
        background: none; /* Remove complex dashed border */
        padding: 0;
    }

    @keyframes pulse-glow {
        0%, 100% {
            transform: scale(1);
            filter: drop-shadow(0 0 14px rgba(97, 196, 197, 0.35)) drop-shadow(0 0 28px rgba(97, 196, 197, 0.15));
        }
        50% {
            transform: scale(1.015);
            filter: drop-shadow(0 0 22px rgba(97, 196, 197, 0.5)) drop-shadow(0 0 44px rgba(97, 196, 197, 0.25));
        }
    }

    @media (max-width: 1179px) {
        .hero-headline {
            font-size: clamp(120px, 13vw, 200px);
        }
        
        /* Reduce spacing between words on smaller screens */
        #hero-word-2 {
            left: clamp(0rem, 8vw, 10rem) !important;
        }
        
        #hero-word-3 {
            left: clamp(0rem, 4vw, 6rem) !important;
        }
        
        /* Adjust right content positioning */
        .right-content-container {
            top: clamp(140px, 20vh, 220px);
        }
    }

    @media (max-width: 768px) {
        .hero-headline {
            font-size: clamp(45px, 15vw, 270px);
        }
        
        /* Even more compact on mobile */
        #hero-word-2 {
            left: clamp(0rem, 8vw, 6rem) !important;
        }
        
        #hero-word-3 {
            left: clamp(0rem, 3vw, 4rem) !important;
        }
    }

    @media (max-width: 480px) {
        .hero-headline {
            font-size: clamp(52px, 15vw, 135px);
        }
        
        /* Most compact on small mobile */
        #hero-word-2 {
            left: clamp(0rem, 5vw, 3rem) !important;
        }
        
        #hero-word-3 {
            left: clamp(0rem, 2vw, 2rem) !important;
        }
    }
</style>