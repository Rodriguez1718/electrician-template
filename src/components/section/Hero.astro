---
import Button from "../ui/Button.astro"

---

<section class="relative w-full min-h-screen overflow-hidden">
    <!-- Removed background div since it's now global -->

    <div class="flex flex-col min-[1180px]:block h-full">
        <h1
            id="hero-headline"
            class="relative min-[1180px]:absolute left-3 font-playfair font-black text-white pointer-events-none select-none flex flex-col leading-[0.88] tracking-tight hero-headline"
            aria-label="VoltBully Electrical Services"
            style="top: clamp(120px, 15vh, 200px);"
            data-animate="fade-only"
        >
            <span id="hero-word-1" class="relative offset-left-0" data-animate="slide-left" data-delay="1">WIRING</span>
            <span id="hero-word-2" class="relative" style="left: clamp(0rem, 15vw, 18rem);" data-animate="slide-left" data-delay="2">YOUR</span>
            <span id="hero-word-3" class="relative text-emerald-500" style="left: clamp(0rem, 16vw, 19rem);" data-animate="slide-left" data-delay="3">SUCCESS</span>
        </h1>

        <div
            id="hero-content"
            class="content-container relative min-[1180px]:absolute max-w-[590px] flex flex-col gap-7 z-10 px-8 mt-8 min-[1180px]:mt-0 mx-auto min-[1180px]:mx-0"
            data-animate="slide-right"
            data-delay="4"
        >
            <!-- Special Offer Coupon -->
            <div id="hero-coupon" class="max-w-2xl mx-auto" data-animate="fade-only" data-delay="5">
              <div class="coupon-pulse rounded-2xl">
                <div class="bg-brand-accent text-white p-6 rounded-2xl border-4 border-dashed border-white/30 relative overflow-hidden">
                  <!-- Decorative corner cuts -->
                  <div class="absolute top-0 left-0 w-6 h-6 bg-black rounded-br-full"></div>
                  <div class="absolute top-0 right-0 w-6 h-6 bg-black rounded-bl-full"></div>
                  <div class="absolute bottom-0 left-0 w-6 h-6 bg-black rounded-tr-full"></div>
                  <div class="absolute bottom-0 right-0 w-6 h-6 bg-black rounded-tl-full"></div>
                  
                  <!-- Perforated edge effect -->
                  <div class="absolute left-0 top-1/2 -translate-y-1/2 w-8 h-8 bg-black rounded-full -ml-4"></div>
                  <div class="absolute right-0 top-1/2 -translate-y-1/2 w-8 h-8 bg-black rounded-full -mr-4"></div>
                  
                  <div class="text-center relative z-10">
                    <p class="text-sm font-helvetica font-semibold mb-2 uppercase tracking-wide">Limited Time Offer</p>
                    <div class="flex items-center justify-center gap-4 mb-3">
                      <div class="bg-white text-brand-accent px-6 py-2 rounded-lg font-bold text-3xl font-asap-condensed transform -rotate-2 shadow-lg">
                        $100 OFF
                      </div>
                    </div>
                    <p class="text-lg font-helvetica font-semibold mb-2">Your First Electrical Service</p>
                    <p class="text-sm opacity-90 font-helvetica">New customers only • Minimum $500 service • Mention code: VOLTBULLY100</p>
                  </div>
                </div>
              </div>
            </div>

            <div id="hero-actions" class="flex flex-row justify-center items-center gap-16 mt-0 2xl" data-animate="scale" data-delay="6">
                <Button variant="primary" size="lg" href="/">
                    CALL NOW
                </Button>
            </div>
        </div>
    </div>


</section>

<style>

    .font-playfair {
        font-family: "Playfair Display", Georgia, serif;
    }

    .hero-headline {
        font-size: clamp(172px, 13vw, 272px);
    }

    .content-container {
        top: clamp(120px, 18vh, 200px);
    }

    /* Pulsating coupon animation */
    @keyframes pulse-glow {
        0%, 100% {
            transform: scale(1);
            filter: drop-shadow(0 0 20px rgba(97, 196, 197, 0.4)) drop-shadow(0 0 40px rgba(97, 196, 197, 0.2));
        }
        50% {
            transform: scale(1.02);
            filter: drop-shadow(0 0 30px rgba(97, 196, 197, 0.6)) drop-shadow(0 0 60px rgba(97, 196, 197, 0.3));
        }
    }

    .coupon-pulse {
        animation: pulse-glow 2s ease-in-out infinite;
    }

    @media (min-width: 1180px) {
        .content-container {
            top: clamp(120px, 18vh, 200px);
            left: calc(12px + clamp(400px, 55vw, 1000px));
        }
    }

    @media (max-width: 1179px) {
        .hero-headline {
            font-size: clamp(80px, 10vw, 140px);
        }
    }

    @media (max-width: 768px) {
        .hero-headline {
            font-size: clamp(60px, 12vw, 100px);
        }
    }

    @media (max-width: 480px) {
        .hero-headline {
            font-size: clamp(40px, 15vw, 80px);
        }
    }
</style>
