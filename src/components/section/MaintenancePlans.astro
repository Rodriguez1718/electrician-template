---
import Button from "../ui/Button.astro";
---

<section class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-6">
    
    <!-- Section Header -->
    <div class="text-center mb-16">
      <p class="text-brand-accent font-helvetica text-sm uppercase tracking-wider mb-4">
        MAINTENANCE PLANS
      </p>
      <h2 class="text-4xl lg:text-5xl font-asap-condensed uppercase tracking-wide font-bold text-gray-900 mb-6">
        Protect Your <span class="text-brand-primary">Electrical System</span> for the Long Term
      </h2>
      <p class="text-lg text-gray-600 font-helvetica leading-relaxed max-w-4xl mx-auto">
        Regular maintenance is key to preventing costly repairs and ensuring the safety and efficiency of your electrical system. 
        At VoltBully Electrical, our Electrical Maintenance Plans are designed to keep your home or business running safely year-round.
      </p>
    </div>

    <!-- Two Column Layout -->
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
      
      <!-- Left Column - What's Included -->
      <div class="bg-white rounded-2xl p-8 shadow-lg">
        <h3 class="text-2xl font-asap-condensed uppercase tracking-wide font-bold text-gray-900 mb-8">
          What's Included in Our Maintenance Plans?
        </h3>
        
        <div class="space-y-6">
          <!-- Annual Inspections -->
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-6 h-6 bg-brand-primary rounded-full flex items-center justify-center mt-1">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="text-white">
                <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div>
              <h4 class="font-helvetica font-semibold text-gray-900 mb-2">Annual Inspections</h4>
              <p class="text-gray-600 text-sm font-helvetica">Comprehensive checkups to detect wear, code violations, or potential safety hazards.</p>
            </div>
          </div>

          <!-- Panel Maintenance -->
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-6 h-6 bg-brand-primary rounded-full flex items-center justify-center mt-1">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="text-white">
                <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div>
              <h4 class="font-helvetica font-semibold text-gray-900 mb-2">Electrical Panel Cleaning</h4>
              <p class="text-gray-600 text-sm font-helvetica">Keep your electrical panels clean and connections tight to maintain optimal performance.</p>
            </div>
          </div>

          <!-- Outlet & Switch Testing -->
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-6 h-6 bg-brand-primary rounded-full flex items-center justify-center mt-1">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="text-white">
                <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div>
              <h4 class="font-helvetica font-semibold text-gray-900 mb-2">Outlet & Switch Testing</h4>
              <p class="text-gray-600 text-sm font-helvetica">Test GFCI outlets, switches, and circuits to ensure proper operation and safety.</p>
            </div>
          </div>

          <!-- Priority Scheduling -->
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-6 h-6 bg-brand-primary rounded-full flex items-center justify-center mt-1">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="text-white">
                <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div>
              <h4 class="font-helvetica font-semibold text-gray-900 mb-2">Priority Scheduling</h4>
              <p class="text-gray-600 text-sm font-helvetica">Get fast-track service when you need it most.</p>
            </div>
          </div>

          <!-- Discounted Repairs -->
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-6 h-6 bg-brand-primary rounded-full flex items-center justify-center mt-1">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="text-white">
                <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div>
              <h4 class="font-helvetica font-semibold text-gray-900 mb-2">Discounted Repairs</h4>
              <p class="text-gray-600 text-sm font-helvetica">Enjoy exclusive discounts on parts and labor for any required repairs.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column - Why Invest -->
      <div class="bg-white rounded-2xl p-8 shadow-lg">
        <h3 class="text-2xl font-asap-condensed uppercase tracking-wide font-bold text-gray-900 mb-8">
          Why Invest in a Maintenance Plan?
        </h3>
        
        <div class="space-y-6 mb-8">
          <!-- Prevent Issues -->
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-6 h-6 bg-brand-accent rounded-full flex items-center justify-center mt-1">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="text-white">
                <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div>
              <p class="text-gray-600 text-sm font-helvetica">Prevent unexpected electrical failures and safety hazards.</p>
            </div>
          </div>

          <!-- Lower Bills -->
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-6 h-6 bg-brand-accent rounded-full flex items-center justify-center mt-1">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="text-white">
                <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div>
              <p class="text-gray-600 text-sm font-helvetica">Improve efficiency and lower utility bills through optimized performance.</p>
            </div>
          </div>

          <!-- Extend Lifespan -->
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-6 h-6 bg-brand-accent rounded-full flex items-center justify-center mt-1">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="text-white">
                <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div>
              <p class="text-gray-600 text-sm font-helvetica">Extend the lifespan of your electrical system and components.</p>
            </div>
          </div>

          <!-- Peace of Mind -->
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-6 h-6 bg-brand-accent rounded-full flex items-center justify-center mt-1">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="text-white">
                <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div>
              <p class="text-gray-600 text-sm font-helvetica">Gain peace of mind knowing your electrical system is in expert hands.</p>
            </div>
          </div>
        </div>

        <!-- CTA Button -->
        <div class="pt-4">
          <Button variant="primary" size="lg" href="/contact">
            Learn More
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>