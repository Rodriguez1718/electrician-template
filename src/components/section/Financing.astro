---
import Button from "../ui/Button.astro";
---

<section class="py-20 bg-gradient-to-br from-blue-900 via-blue-800 to-blue-900 text-white relative overflow-hidden">
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-20 left-10 w-32 h-32 border border-brand-primary rounded-full"></div>
    <div class="absolute bottom-20 right-20 w-24 h-24 border border-brand-accent rounded-full"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    
    <!-- Section Header -->
    <div class="text-center mb-16">
      <p class="text-brand-accent font-helvetica text-sm uppercase tracking-wider mb-4">
        FINANCING
      </p>
      <h2 class="text-4xl lg:text-5xl font-asap-condensed uppercase tracking-wide font-bold mb-6">
        Electrical Solutions <span class="text-brand-primary">Made Affordable</span>
      </h2>
      <p class="text-lg text-white/90 font-helvetica leading-relaxed max-w-4xl mx-auto">
        At VoltBully Electrical, we believe that every home and business deserves access to reliable electrical services, 
        no matter the budget. That's why we offer flexible financing options to make your electrical projects manageable and stress-free.
      </p>
    </div>

    <!-- Two Column Layout -->
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 mb-16">
      
      <!-- Left Column - Flexible Payment Plans -->
      <div>
        <h3 class="text-2xl font-asap-condensed uppercase tracking-wide font-bold mb-8">
          Flexible Payment Plans
        </h3>
        
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-6 h-6 bg-brand-primary rounded-full flex items-center justify-center mt-1">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="text-white">
                <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <p class="text-white/90 font-helvetica">Spread the cost of major electrical upgrades or installations over time.</p>
          </div>

          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-6 h-6 bg-brand-primary rounded-full flex items-center justify-center mt-1">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="text-white">
                <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <p class="text-white/90 font-helvetica">Low-interest and no-interest plans available for qualified applicants.</p>
          </div>

          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-6 h-6 bg-brand-primary rounded-full flex items-center justify-center mt-1">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="text-white">
                <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <p class="text-white/90 font-helvetica">Choose a payment schedule that fits your budget.</p>
          </div>
        </div>
      </div>

      <!-- Right Column - What Can You Finance -->
      <div>
        <h3 class="text-2xl font-asap-condensed uppercase tracking-wide font-bold mb-8">
          What Can You Finance?
        </h3>
        
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-6 h-6 bg-brand-accent rounded-full flex items-center justify-center mt-1">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="text-white">
                <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <p class="text-white/90 font-helvetica">Electrical panel upgrades and replacements</p>
          </div>

          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-6 h-6 bg-brand-accent rounded-full flex items-center justify-center mt-1">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="text-white">
                <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <p class="text-white/90 font-helvetica">Whole home rewiring and electrical repairs</p>
          </div>

          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-6 h-6 bg-brand-accent rounded-full flex items-center justify-center mt-1">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="text-white">
                <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <p class="text-white/90 font-helvetica">Generator installations and smart home upgrades</p>
          </div>

          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-6 h-6 bg-brand-accent rounded-full flex items-center justify-center mt-1">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="text-white">
                <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <p class="text-white/90 font-helvetica">Commercial electrical projects and more</p>
          </div>
        </div>
      </div>
    </div>

    <!-- How to Apply Section -->
    <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-8 mb-8">
      <h3 class="text-2xl font-cervo font-bold text-center mb-12">
        How to Apply
      </h3>
      
      <div class="grid md:grid-cols-3 gap-8">
        <!-- Step 1 -->
        <div class="text-center bg-white rounded-xl p-6 text-gray-900 relative">
          <div class="absolute -top-3 left-4 bg-brand-accent text-white px-3 py-1 rounded-full text-sm font-helvetica font-medium">
            Step 1
          </div>
          <div class="w-16 h-16 bg-blue-900 rounded-full flex items-center justify-center mx-auto mb-4 mt-2">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-white">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h4 class="font-helvetica font-bold text-blue-900 mb-2">
            CONTACT OUR TEAM TO DISCUSS YOUR ELECTRICAL NEEDS.
          </h4>
        </div>

        <!-- Step 2 -->
        <div class="text-center bg-white rounded-xl p-6 text-gray-900 relative">
          <div class="absolute -top-3 left-4 bg-brand-accent text-white px-3 py-1 rounded-full text-sm font-helvetica font-medium">
            Step 2
          </div>
          <div class="w-16 h-16 bg-blue-900 rounded-full flex items-center justify-center mx-auto mb-4 mt-2">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-white">
              <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h4 class="font-helvetica font-bold text-blue-900 mb-2">
            CHOOSE A FINANCING PLAN THAT WORKS FOR YOU.
          </h4>
        </div>

        <!-- Step 3 -->
        <div class="text-center bg-white rounded-xl p-6 text-gray-900 relative">
          <div class="absolute -top-3 left-4 bg-brand-accent text-white px-3 py-1 rounded-full text-sm font-helvetica font-medium">
            Step 3
          </div>
          <div class="w-16 h-16 bg-blue-900 rounded-full flex items-center justify-center mx-auto mb-4 mt-2">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-white">
              <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h4 class="font-helvetica font-bold text-blue-900 mb-2">
            ENJOY HIGH-QUALITY ELECTRICAL SERVICES WITHOUT FINANCIAL STRAIN.
          </h4>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center">
      <Button variant="secondary" size="lg" href="/contact">
        Get Started Today
      </Button>
    </div>
  </div>
</section>