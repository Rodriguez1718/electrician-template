---
import CallToAction from "../components/section/CallToAction.astro";
import CommercialServices from "../components/section/CommercialServices.astro";
import Coupons from "../components/section/Coupons.astro";
import FeaturedWorks from "../components/section/FeaturedWorks.astro";
import Hero2 from "../components/section/Hero2.astro";
import ServiceAreas from "../components/section/ServiceAreas.astro";
import Services from "../components/section/Services.astro";
import Testimonials from "../components/section/Testimonials.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

---

<BaseLayout 
	title="Service Areas | VoltBully Electrical Services Coverage Map"
	description="Discover VoltBully's electrical service coverage areas across Colorado. We provide licensed electrical services to residential and commercial customers with local expertise and 24/7 emergency support."
	keywords="electrical service areas, Colorado electrician coverage, electrical contractor service map, local electrician, electrical services near me, VoltBully service areas, Colorado electrical coverage"
>
    <div class="relative">
        <!-- Background image for Hero2 -->
        <div class="absolute inset-0 bg-cover bg-center bg-no-repeat" style="background-image: url('/images/wiring.png');"></div>
        <!-- Dark overlay for better text readability -->
        <div class="absolute inset-0 bg-black/40"></div>
        
        <Hero2 
            line1=""
            line2="SERVICE"
            line3="AREAS"
            description="Comprehensive electrical services across Colorado communities. Licensed electricians serving residential and commercial customers with local expertise."
            buttonText="GET STARTED"
            buttonHref="/contact"
            phoneText="CALL FOR EMERGENCY"
            backgroundImage="/images/denver.jpg"
        />
    </div>
    <CommercialServices 
        sectionTag="SERVICE COVERAGE AREAS"
        title="Professional Electrical Services Where You Need Them"
        highlightedText="Where You Need Them"
        description="we proudly serve multiple communities with comprehensive electrical solutions for homes and businesses. Our extensive service area coverage ensures we understand local electrical codes, regional challenges, and community needs wherever we operate."
        companyName="VoltBully Electrical"
        image={{
            src: "/images/ground-elec.png",
            alt: "Electrical service coverage areas"
        }}
        badge={{
            number: "10+",
            text: ["Service Areas", "Covered"]
        }}
        features={[
            {
                title: "Local Code Expertise",
                description: "Deep knowledge of electrical codes and permit requirements across all our service areas for fast, compliant installations.",
                icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>',
                color: 'primary'
            },
            {
                title: "Wide Area Coverage",
                description: "Electrical systems designed to meet diverse regional requirements and local conditions across our service territories.",
                icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="2"/></svg>',
                color: 'secondary'
            },
            {
                title: "Fast Response Times",
                description: "Quick service throughout all our coverage areas with same-day emergency response available in most locations.",
                icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><polyline points="12,6 12,12 16,14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>',
                color: 'accent'
            },
            {
                title: "Community Focused",
                description: "Committed to serving residents and businesses in every community with personalized service and competitive pricing.",
                icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-width="2"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" stroke="currentColor" stroke-width="2"/></svg>',
                color: 'red'
            }
        ]}
    />
    <Coupons roundedBottom/>
    <FeaturedWorks showTopGradient={false}/>
    <Testimonials />
    <CallToAction />
    <ServiceAreas />

    <!-- Back to Top Button -->
    <button 
        id="backToTop" 
        class="fixed bottom-8 right-8 w-12 h-12 bg-brand-primary text-black rounded-full shadow-lg hover:shadow-xl transition-all duration-300 opacity-0 invisible cursor-none overflow-hidden"
        style="z-index: 9999; position: fixed;"
        aria-label="Back to top"
        type="button"
    >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="mx-auto">
            <path d="M12 19V5M5 12l7-7 7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
    </button>
</BaseLayout>

<style>
    #backToTop::before {
        content: '';
        position: absolute;
        width: 0;
        height: 0;
        background: var(--color-secondary);
        border-radius: 50%;
        transform: translate(-50%, -50%);
        transition: width 0.4s ease, height 0.4s ease;
        z-index: 1;
        pointer-events: none;
        left: var(--mouse-x, 50%);
        top: var(--mouse-y, 50%);
    }
    
    #backToTop:hover::before {
        width: 300%;
        height: 300%;
    }
    
    #backToTop:hover {
        color: white;
    }
    
    #backToTop.btn--shrinking::before {
        width: 0;
        height: 0;
    }
    
    #backToTop.btn--shrinking {
        color: black;
    }
    
    #backToTop svg {
        position: relative;
        z-index: 2;
        pointer-events: none;
    }
</style>

<script>
    // Back to top button functionality
    const backToTopButton = document.getElementById('backToTop');
    
    // Show/hide button based on scroll position
    window.addEventListener('scroll', () => {
        if (window.scrollY > 300) {
            backToTopButton?.classList.remove('opacity-0', 'invisible');
            backToTopButton?.classList.add('opacity-100', 'visible');
        } else {
            backToTopButton?.classList.add('opacity-0', 'invisible');
            backToTopButton?.classList.remove('opacity-100', 'visible');
        }
    });
    
    // Smooth scroll to top when clicked
    backToTopButton?.addEventListener('click', () => {
        window.scrollTo({
            top: 0,
            behavior: 'smooth'
        });
    });
    
    // Mouse tracking for hover effect (same as Button component)
    if (backToTopButton) {
        backToTopButton.addEventListener('mouseenter', (e) => {
            const mouseEvent = e as MouseEvent;
            const rect = backToTopButton.getBoundingClientRect();
            const x = mouseEvent.clientX - rect.left;
            const y = mouseEvent.clientY - rect.top;
            
            // Set CSS custom properties for the circle position
            backToTopButton.style.setProperty('--mouse-x', `${x}px`);
            backToTopButton.style.setProperty('--mouse-y', `${y}px`);
        });
        
        backToTopButton.addEventListener('mouseleave', (e) => {
            const mouseEvent = e as MouseEvent;
            const rect = backToTopButton.getBoundingClientRect();
            const x = mouseEvent.clientX - rect.left;
            const y = mouseEvent.clientY - rect.top;
            
            // Set the exit position for the circle to shrink from
            backToTopButton.style.setProperty('--mouse-x', `${x}px`);
            backToTopButton.style.setProperty('--mouse-y', `${y}px`);
            
            // Add a class to trigger the shrink animation
            backToTopButton.classList.add('btn--shrinking');
            
            // Remove the class and reset after animation completes
            setTimeout(() => {
                backToTopButton.classList.remove('btn--shrinking');
                backToTopButton.style.removeProperty('--mouse-x');
                backToTopButton.style.removeProperty('--mouse-y');
            }, 400); // Match the transition duration
        });
    }
</script>