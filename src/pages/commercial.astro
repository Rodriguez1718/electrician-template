    <!-- Back to Top Button -->
    <button 
        id="backToTop" 
        class="fixed bottom-8 right-8 w-12 h-12 bg-brand-primary text-black rounded-full shadow-lg hover:shadow-xl transition-all duration-300 opacity-0 invisible cursor-none overflow-hidden"
        style="z-index: 9999; position: fixed;"
        aria-label="Back to top"
        type="button"
    >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="mx-auto">
            <path d="M12 19V5M5 12l7-7 7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
    </button>
</BaseLayout>

<style>
    #backToTop::before {
        content: '';
        position: absolute;
        width: 0;
        height: 0;
        background: var(--color-secondary);
        border-radius: 50%;
        transform: translate(-50%, -50%);
        transition: width 0.4s ease, height 0.4s ease;
        z-index: 1;
        pointer-events: none;
        left: var(--mouse-x, 50%);
        top: var(--mouse-y, 50%);
    }
    
    #backToTop:hover::before {
        width: 300%;
        height: 300%;
    }
    
    #backToTop:hover {
        color: white;
    }
    
    #backToTop.btn--shrinking::before {
        width: 0;
        height: 0;
    }
    
    #backToTop.btn--shrinking {
        color: black;
    }
    
    #backToTop svg {
        position: relative;
        z-index: 2;
        pointer-events: none;
    }
</style>

<script>
    // Back to top button functionality
    const backToTopButton = document.getElementById('backToTop');
    
    // Show/hide button based on scroll position
    window.addEventListener('scroll', () => {
        if (window.scrollY > 300) {
            backToTopButton?.classList.remove('opacity-0', 'invisible');
            backToTopButton?.classList.add('opacity-100', 'visible');
        } else {
            backToTopButton?.classList.add('opacity-0', 'invisible');
            backToTopButton?.classList.remove('opacity-100', 'visible');
        }
    });
    
    // Smooth scroll to top when clicked
    backToTopButton?.addEventListener('click', () => {
        window.scrollTo({
            top: 0,
            behavior: 'smooth'
        });
    });
    
    // Mouse tracking for hover effect (same as Button component)
    if (backToTopButton) {
        backToTopButton.addEventListener('mouseenter', (e) => {
            const mouseEvent = e as MouseEvent;
            const rect = backToTopButton.getBoundingClientRect();
            const x = mouseEvent.clientX - rect.left;
            const y = mouseEvent.clientY - rect.top;
            
            // Set CSS custom properties for the circle position
            backToTopButton.style.setProperty('--mouse-x', `${x}px`);
            backToTopButton.style.setProperty('--mouse-y', `${y}px`);
        });
        
        backToTopButton.addEventListener('mouseleave', (e) => {
            const mouseEvent = e as MouseEvent;
            const rect = backToTopButton.getBoundingClientRect();
            const x = mouseEvent.clientX - rect.left;
            const y = mouseEvent.clientY - rect.top;
            
            // Set the exit position for the circle to shrink from
            backToTopButton.style.setProperty('--mouse-x', `${x}px`);
            backToTopButton.style.setProperty('--mouse-y', `${y}px`);
            
            // Add a class to trigger the shrink animation
            backToTopButton.classList.add('btn--shrinking');
            
            // Remove the class and reset after animation completes
            setTimeout(() => {
                backToTopButton.classList.remove('btn--shrinking');
                backToTopButton.style.removeProperty('--mouse-x');
                backToTopButton.style.removeProperty('--mouse-y');
            }, 400); // Match the transition duration
        });
    }
</script>