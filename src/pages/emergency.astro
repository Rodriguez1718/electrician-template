---
import Hero2 from "../components/section/Hero2.astro";
import ServicesList from "../components/section/ServicesList.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import CommercialOffers from "../components/section/CommercialOffers.astro";
import FAQ from "../components/section/FAQ.astro";
import CallToAction from "../components/section/CallToAction.astro";
import ServiceCoverage from "../components/section/ServiceCoverage.astro";
import CommercialServices from "../components/section/CommercialServices.astro";
import Services from "../components/section/Services.astro";

---

<BaseLayout 
	title="Emergency Electrical Services | VoltBully 24/7 Emergency Electricians"
	description="VoltBully provides 24/7 emergency electrical services including power outages, electrical fires, storm damage repair, and HVAC emergency repairs. Fast response emergency electricians available around the clock."
	keywords="emergency electrician, 24/7 electrical service, power outage repair, electrical fire prevention, storm damage electrical, emergency electrical repair, after hours electrician"
>
    <div class="relative">
        <!-- Background image for Hero2 -->
        <div class="absolute inset-0 bg-cover bg-center bg-no-repeat" style="background-image: url('/images/emergency.webp');"></div>
        <!-- Dark overlay for better text readability -->
        <div class="absolute inset-0 bg-black/40"></div>
        
        <Hero2 
            line1=""
            line2="EMERGENCY"
            line3="SERVICES"
            description="Round-the-clock emergency electrical services when you need them most."
            buttonText="CALL NOW"
            buttonHref="tel:+1234567890"
            phoneText="EMERGENCY HOTLINE"
        />
    </div>
    <CommercialServices 
        sectionTag="EMERGENCY SERVICES"
        title="24/7 Emergency Electrical Response"
        highlightedText="Emergency Electrical"
        description="Our certified emergency electricians are available around the clock to handle any electrical crisis. From power outages to electrical fires, we respond quickly to restore safety and power to your property."
        companyName="VoltBully Electrical"
        image={{
            src: "/images/electrical.webp",
            alt: "Emergency electrical services"
        }}
        badge={{
            number: "24/7",
            text: ["Always", "Available"]
        }}
        features={[
            {
            title: "Rapid Response",
            description: "We arrive within 30 minutes of your emergency call, day or night, weekends and holidays.",
            icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><path d="M12 6v6l4 2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>',
            color: 'red'
            },
            {
            title: "Licensed Experts",
            description: "All our emergency technicians are fully licensed, insured, and equipped for any electrical crisis.",
            icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>',
            color: 'primary'
            },
            {
            title: "Safety Priority",
            description: "We prioritize safety first, quickly identifying and eliminating electrical hazards to protect your property.",
            icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M21 12c-1 0-3-1-3-3s2-3 3-3 3 1 3 3-2 3-3 3" stroke="currentColor" stroke-width="2"/><path d="M3 12c1 0 3-1 3-3s-2-3-3-3-3 1-3 3 2 3 3 3" stroke="currentColor" stroke-width="2"/></svg>',
            color: 'secondary'
            },
            {
            title: "Complete Solutions",
            description: "From temporary fixes to permanent repairs, we provide comprehensive emergency electrical solutions.",
            icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>',
            color: 'accent'
            }
        ]}
    />

    <ServicesList 
    category="emergency"
    sectionLabel="Emergency Services"
    title="24/7"
    titleHighlight="Emergency Response"
    description="Round-the-clock electrical emergency services when you need them most. Our certified emergency electricians respond quickly to power outages, electrical fires, storm damage, and other urgent electrical issues to keep you safe."
    />

    <!-- Residential services -->
    <!-- <ServicesList 
    category="residential"
    sectionLabel="Residential Services"
    title="Expert"
    titleHighlight="Home Electrical"
    description="Professional electrical services for your home and family's safety."
    /> -->

    <!-- Emergency services -->
    <!-- <ServicesList 
    category="emergency"
    sectionLabel="Emergency Services"
    title="24/7"
    titleHighlight="Emergency Response"
    description="Round-the-clock electrical emergency services when you need them most."
    /> -->

    <!-- Specialty services -->
    <!-- <ServicesList 
    category="specialty"
    sectionLabel="Specialty Services"
    title="Premium"
    titleHighlight="Specialty Solutions"
    description="Specialized electrical services for unique projects and installations."
    /> -->
    <CommercialOffers />
    <FAQ />
    <Services excludeCategory="emergency" />
    <CallToAction variant="light" />
    <ServiceCoverage />
    
    <!-- Back to Top Button -->
    <button 
        id="backToTop" 
        class="fixed bottom-8 right-8 w-12 h-12 bg-brand-primary text-black rounded-full shadow-lg hover:shadow-xl transition-all duration-300 opacity-0 invisible cursor-none overflow-hidden"
        style="z-index: 9999; position: fixed;"
        aria-label="Back to top"
        type="button"
    >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="mx-auto">
            <path d="M12 19V5M5 12l7-7 7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
    </button>
</BaseLayout>

<style>
    #backToTop::before {
        content: '';
        position: absolute;
        width: 0;
        height: 0;
        background: var(--color-secondary);
        border-radius: 50%;
        transform: translate(-50%, -50%);
        transition: width 0.4s ease, height 0.4s ease;
        z-index: 1;
        pointer-events: none;
        left: var(--mouse-x, 50%);
        top: var(--mouse-y, 50%);
    }
    
    #backToTop:hover::before {
        width: 300%;
        height: 300%;
    }
    
    #backToTop:hover {
        color: white;
    }
    
    #backToTop.btn--shrinking::before {
        width: 0;
        height: 0;
    }
    
    #backToTop.btn--shrinking {
        color: black;
    }
    
    #backToTop svg {
        position: relative;
        z-index: 2;
        pointer-events: none;
    }
</style>

<script>
    // Back to top button functionality
    const backToTopButton = document.getElementById('backToTop');
    
    // Show/hide button based on scroll position
    window.addEventListener('scroll', () => {
        if (window.scrollY > 300) {
            backToTopButton?.classList.remove('opacity-0', 'invisible');
            backToTopButton?.classList.add('opacity-100', 'visible');
        } else {
            backToTopButton?.classList.add('opacity-0', 'invisible');
            backToTopButton?.classList.remove('opacity-100', 'visible');
        }
    });
    
    // Smooth scroll to top when clicked
    backToTopButton?.addEventListener('click', () => {
        window.scrollTo({
            top: 0,
            behavior: 'smooth'
        });
    });
    
    // Mouse tracking for hover effect (same as Button component)
    if (backToTopButton) {
        backToTopButton.addEventListener('mouseenter', (e) => {
            const mouseEvent = e as MouseEvent;
            const rect = backToTopButton.getBoundingClientRect();
            const x = mouseEvent.clientX - rect.left;
            const y = mouseEvent.clientY - rect.top;
            
            // Set CSS custom properties for the circle position
            backToTopButton.style.setProperty('--mouse-x', `${x}px`);
            backToTopButton.style.setProperty('--mouse-y', `${y}px`);
        });
        
        backToTopButton.addEventListener('mouseleave', (e) => {
            const mouseEvent = e as MouseEvent;
            const rect = backToTopButton.getBoundingClientRect();
            const x = mouseEvent.clientX - rect.left;
            const y = mouseEvent.clientY - rect.top;
            
            // Set the exit position for the circle to shrink from
            backToTopButton.style.setProperty('--mouse-x', `${x}px`);
            backToTopButton.style.setProperty('--mouse-y', `${y}px`);
            
            // Add a class to trigger the shrink animation
            backToTopButton.classList.add('btn--shrinking');
            
            // Remove the class and reset after animation completes
            setTimeout(() => {
                backToTopButton.classList.remove('btn--shrinking');
                backToTopButton.style.removeProperty('--mouse-x');
                backToTopButton.style.removeProperty('--mouse-y');
            }, 400); // Match the transition duration
        });
    }
</script>