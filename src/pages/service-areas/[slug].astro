---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero2 from '../../components/section/Hero2.astro';
import CommercialServices from '../../components/section/CommercialServices.astro';
import Services from '../../components/section/Services.astro';
import FAQ from '../../components/section/FAQ.astro';
import FeaturedWorks from '../../components/section/FeaturedWorks.astro';
import Testimonials from '../../components/section/Testimonials.astro';
import CallToAction from '../../components/section/CallToAction.astro';
import ServiceAreas from '../../components/section/ServiceAreas.astro';
import CompanyLogo from '../../components/section/CompanyLogo.astro';
import WhyTheyTrustUs from '../../components/section/WhyTheyTrustUs.astro';
import SpecialOffers from '../../components/section/SpecialOffers.astro';

export async function getStaticPaths() {
  const serviceAreas = await getCollection('service-areas');
  return serviceAreas.map((area) => ({
    params: { slug: area.id },
    props: { area },
  }));
}

type Props = {
  area: Awaited<ReturnType<typeof getCollection<'service-areas'>>>[number];
};

const { area } = Astro.props;
const { data } = area;

// Render markdown content
const { Content } = await render(area);
---

<BaseLayout 
  title={data.title}
  description={data.metaDescription}
  keywords={data.keywords}
>
  <div class="hero-company-wrapper">
    <div class="hero-section relative">
      <!-- Background image for Hero2 -->
      <div class="absolute inset-0 bg-cover bg-center bg-no-repeat" style={`background-image: url('${data.backgroundImage}');`}></div>
      <!-- Dark overlay for better text readability -->
      <div class="absolute inset-0 bg-black/40"></div>
      
      <Hero2 
        line1={data.heroLine1 || ""}
        line2={data.heroLine2}
        line3={data.heroLine3}
        description={data.heroDescription}
        buttonText="GET STARTED"
        buttonHref="/contact"
        phoneText="CALL FOR EMERGENCY"
      />
    </div>
    <CompanyLogo />
  </div>

  <CommercialServices 
    sectionTag={`${data.city.toUpperCase()} ELECTRICAL SERVICES`}
    title={`Professional Electrical Services in ${data.city}`}
    highlightedText={data.city}
    description={data.description}
    companyName="VoltBully Electrical"
    image={{
      src: data.image || data.backgroundImage,
      alt: `${data.city} electrical services`
    }}
    badge={data.yearsServing ? {
      number: `${data.yearsServing}+`,
      text: ["Years Serving", data.city]
    } : undefined}
    features={data.features as Array<{
      title: string;
      description: string;
      icon: string;
      color: "primary" | "secondary" | "accent" | "red";
    }> || []}
  />
  
  {data.whyTrustUs && <WhyTheyTrustUs roundedBottom whyTrustUs={data.whyTrustUs} />}
  
  <SpecialOffers />
  <Services showGradientOverlay={false}/>
  <FeaturedWorks showTopGradient={false}/>
  <Testimonials />
  <CallToAction />
  
  <ServiceAreas 
    title="Expert Electrical Services in"
    titleHighlight={`${data.city} and Surrounding Areas`}
    description={`Proudly serving the ${data.city} area with professional electrical solutions for residential and commercial properties. Our licensed electricians deliver quality workmanship with fast response times. Available 24/7 for emergencies across all neighborhoods.`}
    mapTitle={`VoltBully Electrical ${data.city} Service Areas Map`}
  />

  <!-- Back to Top Button -->
  <button 
    id="backToTop" 
    class="fixed bottom-8 right-8 w-12 h-12 bg-brand-primary text-black rounded-full shadow-lg hover:shadow-xl transition-all duration-300 opacity-0 invisible cursor-none overflow-hidden"
    style="z-index: 9999; position: fixed;"
    aria-label="Back to top"
    type="button"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="mx-auto">
      <path d="M12 19V5M5 12l7-7 7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
</BaseLayout>

<style>
  .hero-company-wrapper {
    position: relative;
    background:

      /* Aggressive gradient to pure black earlier */
      linear-gradient(
        to bottom,
        #000000 100%,
        #0f172a 30%,
        rgba(15, 23, 42, 0.9) 45%,
        rgba(0, 0, 0, 0.95) 60%,
        rgba(0, 0, 0, 0.99) 70%,
        #000000 75%,
        #000000 100%
      );
  }

  #backToTop::before {
    content: '';
    position: absolute;
    width: 0;
    height: 0;
    background: var(--color-secondary);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition: width 0.4s ease, height 0.4s ease;
    z-index: 1;
    pointer-events: none;
    left: var(--mouse-x, 50%);
    top: var(--mouse-y, 50%);
  }
  
  #backToTop:hover::before {
    width: 300%;
    height: 300%;
  }
  
  #backToTop:hover {
    color: white;
  }
  
  #backToTop.btn--shrinking::before {
    width: 0;
    height: 0;
  }
  
  #backToTop.btn--shrinking {
    color: black;
  }
  
  #backToTop svg {
    position: relative;
    z-index: 2;
    pointer-events: none;
  }
</style>

<script>
  // Back to top button functionality
  const backToTopButton = document.getElementById('backToTop');
  
  // Show/hide button based on scroll position
  window.addEventListener('scroll', () => {
    if (window.scrollY > 300) {
      backToTopButton?.classList.remove('opacity-0', 'invisible');
      backToTopButton?.classList.add('opacity-100', 'visible');
    } else {
      backToTopButton?.classList.add('opacity-0', 'invisible');
      backToTopButton?.classList.remove('opacity-100', 'visible');
    }
  });
  
  // Smooth scroll to top when clicked
  backToTopButton?.addEventListener('click', () => {
    window.scrollTo({
      top: 0,
      behavior: 'smooth'
    });
  });
  
  // Mouse tracking for hover effect
  if (backToTopButton) {
    backToTopButton.addEventListener('mouseenter', (e) => {
      const mouseEvent = e as MouseEvent;
      const rect = backToTopButton.getBoundingClientRect();
      const x = mouseEvent.clientX - rect.left;
      const y = mouseEvent.clientY - rect.top;
      
      backToTopButton.style.setProperty('--mouse-x', `${x}px`);
      backToTopButton.style.setProperty('--mouse-y', `${y}px`);
    });
    
    backToTopButton.addEventListener('mouseleave', (e) => {
      const mouseEvent = e as MouseEvent;
      const rect = backToTopButton.getBoundingClientRect();
      const x = mouseEvent.clientX - rect.left;
      const y = mouseEvent.clientY - rect.top;
      
      backToTopButton.style.setProperty('--mouse-x', `${x}px`);
      backToTopButton.style.setProperty('--mouse-y', `${y}px`);
      
      backToTopButton.classList.add('btn--shrinking');
      
      setTimeout(() => {
        backToTopButton.classList.remove('btn--shrinking');
        backToTopButton.style.removeProperty('--mouse-x');
        backToTopButton.style.removeProperty('--mouse-y');
      }, 400);
    });
  }
</script>
