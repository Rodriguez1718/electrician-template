---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero2 from '../../components/section/Hero2.astro';
import CommercialServices from '../../components/section/CommercialServices.astro';
import ProcessTimeline from '../../components/section/ProcessTimeline.astro';
import CommercialOffers from '../../components/section/CommercialOffers.astro';
import FAQ from '../../components/section/FAQ.astro';
import CallToAction from '../../components/section/CallToAction.astro';
import ServiceCoverage from '../../components/section/ServiceCoverage.astro';
import Services from '../../components/section/Services.astro';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((service) => ({
    params: { slug: service.id },
    props: { service },
  }));
}

type Props = {
  service: Awaited<ReturnType<typeof getCollection<'services'>>>[number];
};

const { service } = Astro.props;
const { data } = service;

// Render markdown content
const { Content } = await render(service);
---

<BaseLayout 
  title={data.title}
  description={data.metaDescription}
  keywords={data.keywords}
>
  <div class="relative">
    <!-- Background image for Hero2 -->
    <div class="absolute inset-0 bg-cover bg-center bg-no-repeat" style={`background-image: url('${data.backgroundImage}');`}></div>
    <!-- Dark overlay for better text readability -->
    <div class="absolute inset-0 bg-black/40"></div>
    
    <Hero2 
      line1={data.heroLine1}
      line2={data.heroLine2}
      line3={data.heroLine3}
      description={data.heroDescription}
      buttonText="GET STARTED"
      buttonHref="/contact"
      phoneText="CALL FOR EMERGENCY"
    />
  </div>

  <CommercialServices 
    sectionTag={data.sectionTag}
    title={data.serviceTitle}
    highlightedText={data.highlightedText}
    description={data.serviceDescription}
    companyName={data.companyName}
    image={{
      src: data.image || data.backgroundImage,
      alt: `${data.serviceTitle} services`
    }}
    badge={{
      number: data.badgeNumber,
      text: data.badgeText
    }}
    features={data.features as Array<{
      title: string;
      description: string;
      icon: string;
      color: "primary" | "secondary" | "accent" | "red";
    }>}
  />
  
  {data.showProcessTimeline && data.processTimeline && (
    <ProcessTimeline 
      sectionTag={data.processTimeline.sectionTag}
      title={data.processTimeline.title}
      highlightedText={data.processTimeline.highlightedText}
      description={data.processTimeline.description}
      steps={data.processTimeline.steps}
    />
  )}
  <CommercialOffers showGradient={false}/>
  <Services />
  <FAQ />
  <CallToAction variant="light"/>
  <ServiceCoverage />

  <!-- Back to Top Button -->
  <button 
    id="backToTop" 
    class="fixed bottom-8 right-8 w-12 h-12 bg-brand-primary text-black rounded-full shadow-lg hover:shadow-xl transition-all duration-300 opacity-0 invisible cursor-none overflow-hidden"
    style="z-index: 9999; position: fixed;"
    aria-label="Back to top"
    type="button"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="mx-auto">
      <path d="M12 19V5M5 12l7-7 7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
</BaseLayout>

<style>
  #backToTop::before {
    content: '';
    position: absolute;
    width: 0;
    height: 0;
    background: var(--color-secondary);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition: width 0.4s ease, height 0.4s ease;
    z-index: 1;
    pointer-events: none;
    left: var(--mouse-x, 50%);
    top: var(--mouse-y, 50%);
  }
  
  #backToTop:hover::before {
    width: 300%;
    height: 300%;
  }
  
  #backToTop:hover {
    color: white;
  }
  
  #backToTop.btn--shrinking::before {
    width: 0;
    height: 0;
  }
  
  #backToTop.btn--shrinking {
    color: black;
  }
  
  #backToTop svg {
    position: relative;
    z-index: 2;
    pointer-events: none;
  }

  /* Prose styling for markdown content */
  .prose {
    color: #374151;
  }
  
  .prose h1 {
    color: #1f2937;
    font-size: 2.25rem;
    font-weight: 800;
    margin-bottom: 1rem;
  }
  
  .prose h2 {
    color: #1f2937;
    font-size: 1.875rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  
  .prose h3 {
    color: #1f2937;
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  
  .prose p {
    margin-bottom: 1rem;
    line-height: 1.75;
  }
  
  .prose ul {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }
  
  .prose li {
    margin-bottom: 0.5rem;
  }
  
  .prose strong {
    font-weight: 600;
    color: #1f2937;
  }
</style>

<script>
  // Back to top button functionality
  const backToTopButton = document.getElementById('backToTop');
  
  // Show/hide button based on scroll position
  window.addEventListener('scroll', () => {
    if (window.scrollY > 300) {
      backToTopButton?.classList.remove('opacity-0', 'invisible');
      backToTopButton?.classList.add('opacity-100', 'visible');
    } else {
      backToTopButton?.classList.add('opacity-0', 'invisible');
      backToTopButton?.classList.remove('opacity-100', 'visible');
    }
  });
  
  // Smooth scroll to top when clicked
  backToTopButton?.addEventListener('click', () => {
    window.scrollTo({
      top: 0,
      behavior: 'smooth'
    });
  });
  
  // Mouse tracking for hover effect
  if (backToTopButton) {
    backToTopButton.addEventListener('mouseenter', (e) => {
      const mouseEvent = e as MouseEvent;
      const rect = backToTopButton.getBoundingClientRect();
      const x = mouseEvent.clientX - rect.left;
      const y = mouseEvent.clientY - rect.top;
      
      backToTopButton.style.setProperty('--mouse-x', `${x}px`);
      backToTopButton.style.setProperty('--mouse-y', `${y}px`);
    });
    
    backToTopButton.addEventListener('mouseleave', (e) => {
      const mouseEvent = e as MouseEvent;
      const rect = backToTopButton.getBoundingClientRect();
      const x = mouseEvent.clientX - rect.left;
      const y = mouseEvent.clientY - rect.top;
      
      backToTopButton.style.setProperty('--mouse-x', `${x}px`);
      backToTopButton.style.setProperty('--mouse-y', `${y}px`);
      
      backToTopButton.classList.add('btn--shrinking');
      
      setTimeout(() => {
        backToTopButton.classList.remove('btn--shrinking');
        backToTopButton.style.removeProperty('--mouse-x');
        backToTopButton.style.removeProperty('--mouse-y');
      }, 400);
    });
  }
</script>