---
import Hero2 from "../components/section/Hero2.astro";
import ServicesList from "../components/section/ServicesList.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import CommercialOffers from "../components/section/CommercialOffers.astro";
import FAQ from "../components/section/FAQ.astro";
import CallToAction from "../components/section/CallToAction.astro";
import ServiceCoverage from "../components/section/ServiceCoverage.astro";
import CommercialServices from "../components/section/CommercialServices.astro";

---

<BaseLayout 
	title="Specialty Electrical Services | VoltBully Professional Electricians"
	description="VoltBully offers specialized electrical services including smart home systems, landscape lighting, pool/spa electrical, holiday lighting, and property management electrical solutions. Expert specialty electricians."
	keywords="specialty electrician, smart home systems, landscape lighting, pool electrical, spa electrical, holiday lighting installation, property management electrical, outdoor lighting"
>
    <div class="relative">
        <!-- Background image for Hero2 -->
        <div class="absolute inset-0 bg-cover bg-center bg-no-repeat" style="background-image: url('/images/specialty.webp');"></div>
        <!-- Dark overlay for better text readability -->
        <div class="absolute inset-0 bg-black/40"></div>
        
        <Hero2 
            line1="SPECIALTY"
            line2="ELECTRICAL"
            line3="SERVICES"
            description="Premium specialty electrical solutions for unique projects and installations."
            buttonText="GET STARTED"
            buttonHref="/contact"
            phoneText="CALL FOR EMERGENCY"
        />
    </div>
    <CommercialServices 
        sectionTag="SPECIALTY SERVICES"
        title="Premium Specialty Electrical Solutions"
        highlightedText="Specialty Electrical"
        description="Our expert electricians specialize in unique and advanced electrical installations that go beyond standard services. From smart home automation to outdoor lighting systems, we bring innovative electrical solutions to life."
        companyName="VoltBully Electrical"
        image={{
            src: "/images/smartHome.webp",
            alt: "Specialty electrical services"
        }}
        badge={{
            number: "100+",
            text: ["Specialty", "Projects"]
        }}
        features={[
            {
            title: "Smart Technology",
            description: "Advanced smart home systems, automation, and IoT device integration for modern living.",
            icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>',
            color: 'primary'
            },
            {
            title: "Outdoor Expertise",
            description: "Landscape lighting, pool/spa electrical, and weather-resistant outdoor installations.",
            icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="2"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" stroke="currentColor" stroke-width="2"/></svg>',
            color: 'secondary'
            },
            {
            title: "Custom Design",
            description: "Tailored electrical solutions designed specifically for your unique project requirements.",
            icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke="currentColor" stroke-width="2"/></svg>',
            color: 'accent'
            },
            {
            title: "Premium Quality",
            description: "High-end materials and meticulous craftsmanship for lasting, beautiful results.",
            icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>',
            color: 'red'
            }
        ]}
    />

    <ServicesList 
    category="specialty"
    sectionLabel="Specialty Services"
    title="Premium"
    titleHighlight="Specialty Solutions"
    description="Specialized electrical services for unique projects and installations. From smart home automation to outdoor lighting systems, we provide innovative electrical solutions that enhance your property's functionality and aesthetic appeal."
    />

    <!-- Residential services -->
    <!-- <ServicesList 
    category="residential"
    sectionLabel="Residential Services"
    title="Expert"
    titleHighlight="Home Electrical"
    description="Professional electrical services for your home and family's safety."
    /> -->

    <!-- Emergency services -->
    <!-- <ServicesList 
    category="emergency"
    sectionLabel="Emergency Services"
    title="24/7"
    titleHighlight="Emergency Response"
    description="Round-the-clock electrical emergency services when you need them most."
    /> -->

    <!-- Specialty services -->
    <!-- <ServicesList 
    category="specialty"
    sectionLabel="Specialty Services"
    title="Premium"
    titleHighlight="Specialty Solutions"
    description="Specialized electrical services for unique projects and installations."
    /> -->
    <CommercialOffers />
    <FAQ />
    <CallToAction variant="light" />
    <ServiceCoverage />
    
    <!-- Back to Top Button -->
    <button 
        id="backToTop" 
        class="fixed bottom-8 right-8 w-12 h-12 bg-brand-primary text-black rounded-full shadow-lg hover:shadow-xl transition-all duration-300 opacity-0 invisible cursor-none overflow-hidden"
        style="z-index: 9999; position: fixed;"
        aria-label="Back to top"
        type="button"
    >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="mx-auto">
            <path d="M12 19V5M5 12l7-7 7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
    </button>
</BaseLayout>

<style>
    #backToTop::before {
        content: '';
        position: absolute;
        width: 0;
        height: 0;
        background: var(--color-secondary);
        border-radius: 50%;
        transform: translate(-50%, -50%);
        transition: width 0.4s ease, height 0.4s ease;
        z-index: 1;
        pointer-events: none;
        left: var(--mouse-x, 50%);
        top: var(--mouse-y, 50%);
    }
    
    #backToTop:hover::before {
        width: 300%;
        height: 300%;
    }
    
    #backToTop:hover {
        color: white;
    }
    
    #backToTop.btn--shrinking::before {
        width: 0;
        height: 0;
    }
    
    #backToTop.btn--shrinking {
        color: black;
    }
    
    #backToTop svg {
        position: relative;
        z-index: 2;
        pointer-events: none;
    }
</style>

<script>
    // Back to top button functionality
    const backToTopButton = document.getElementById('backToTop');
    
    // Show/hide button based on scroll position
    window.addEventListener('scroll', () => {
        if (window.scrollY > 300) {
            backToTopButton?.classList.remove('opacity-0', 'invisible');
            backToTopButton?.classList.add('opacity-100', 'visible');
        } else {
            backToTopButton?.classList.add('opacity-0', 'invisible');
            backToTopButton?.classList.remove('opacity-100', 'visible');
        }
    });
    
    // Smooth scroll to top when clicked
    backToTopButton?.addEventListener('click', () => {
        window.scrollTo({
            top: 0,
            behavior: 'smooth'
        });
    });
    
    // Mouse tracking for hover effect (same as Button component)
    if (backToTopButton) {
        backToTopButton.addEventListener('mouseenter', (e) => {
            const mouseEvent = e as MouseEvent;
            const rect = backToTopButton.getBoundingClientRect();
            const x = mouseEvent.clientX - rect.left;
            const y = mouseEvent.clientY - rect.top;
            
            // Set CSS custom properties for the circle position
            backToTopButton.style.setProperty('--mouse-x', `${x}px`);
            backToTopButton.style.setProperty('--mouse-y', `${y}px`);
        });
        
        backToTopButton.addEventListener('mouseleave', (e) => {
            const mouseEvent = e as MouseEvent;
            const rect = backToTopButton.getBoundingClientRect();
            const x = mouseEvent.clientX - rect.left;
            const y = mouseEvent.clientY - rect.top;
            
            // Set the exit position for the circle to shrink from
            backToTopButton.style.setProperty('--mouse-x', `${x}px`);
            backToTopButton.style.setProperty('--mouse-y', `${y}px`);
            
            // Add a class to trigger the shrink animation
            backToTopButton.classList.add('btn--shrinking');
            
            // Remove the class and reset after animation completes
            setTimeout(() => {
                backToTopButton.classList.remove('btn--shrinking');
                backToTopButton.style.removeProperty('--mouse-x');
                backToTopButton.style.removeProperty('--mouse-y');
            }, 400); // Match the transition duration
        });
    }
</script>