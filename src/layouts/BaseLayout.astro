---
import Footer from "../components/layout/Footer.astro";
import Navbar from "../components/layout/Navbar.astro";
import CouponPopup from "../components/layout/CouponPopup.astro";
import "../styles/global.css"

export interface Props {
	title?: string;
	description?: string;
	keywords?: string;
	ogImage?: string;
}

const {
	title = "VoltBully - Professional Electrical Services | Licensed Electricians",
	description = "VoltBully provides professional electrical services including residential, commercial, and emergency electrical work. Licensed electricians serving your area with 24/7 emergency service, free estimates, and quality workmanship.",
	keywords = "electrician, electrical services, residential electrical, commercial electrical, emergency electrical, licensed electrician, electrical repair, electrical installation, electrical contractor",
	ogImage = "/voltbully1.png"
} = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/voltbully1.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Meta Tags -->
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<meta name="author" content="VoltBully" />
		<meta name="robots" content="index, follow" />
		
		<!-- Open Graph Meta Tags -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:site_name" content="VoltBully" />
		
		<!-- Twitter Card Meta Tags -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />
		
		<!-- Additional SEO -->
		<link rel="canonical" href={Astro.url} />
		
		<!-- Resource hints -->
		<link rel="dns-prefetch" href="//fonts.googleapis.com">
		<link rel="dns-prefetch" href="//fonts.gstatic.com">
		
		<!-- Font preconnect -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		
		<!-- Fonts loaded asynchronously -->
		<link rel="preload" href="https://fonts.googleapis.com/css2?family=Asap+Condensed:wght@400;500;600;700;800&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
		<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Asap+Condensed:wght@400;500;600;700;800&display=swap"></noscript>
		
		<link rel="preload" href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
		<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700&display=swap"></noscript>
		
		<link rel="preload" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@900&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
		<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@900&display=swap"></noscript>
		
		<title>{title}</title>
		
		<style>
			html, body { 
				overflow-x: hidden; 
				max-width: 100vw; 
				margin: 0; 
				padding: 0;
			}
			.font-helvetica { 
				font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
			}
			.font-asap-condensed { 
				font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;
			}
			#jelly-cursor { 
				opacity: 0; 
				visibility: hidden;
			}
			.min-h-screen { min-height: 100vh; }
			.flex { display: flex; }
			.flex-col { flex-direction: column; }
			.flex-1 { flex: 1 1 0%; }
		</style>
	</head>
	<body class="min-h-screen flex flex-col overflow-x-hidden max-w-full">
		<!-- Custom Jelly Cursor -->
		<div id="jelly-cursor"></div>

		<!-- Failsafe cursor toggle button -->
		<button
			id="cursor-toggle"
			aria-label="Toggle custom cursor"
			title="Toggle custom cursor"
		>
			<span id="cursor-toggle-icon">🖱️</span>
		</button>
		
		<!-- Page Transition Overlay -->
		<div class="page-transition-wrapper" id="page-transition">
			<svg class="page-transition-svg" viewBox="0 0 100 100" preserveAspectRatio="xMidYMin slice">
				<defs>
					<linearGradient id="voltbully-grad" x1="0" y1="0" x2="99" y2="99" gradientUnits="userSpaceOnUse">
						<stop offset="0.2" stop-color="#98d9a1" />
						<stop offset="0.7" stop-color="#61c4c5" />
					</linearGradient>
				</defs>
				<path class="transition-path" stroke="url(#voltbully-grad)" fill="url(#voltbully-grad)" stroke-width="2px" vector-effect="non-scaling-stroke" d="M 0 100 V 0 Q 50 0 100 0 V 100 z" />
			</svg>
		</div>
		
		<Navbar />
		<main class="flex-1 overflow-x-hidden max-w-full">
			<slot />
		</main>
		<Footer />
		<CouponPopup />

		<style>
			/*
			 * cursor: none is ONLY applied when the custom cursor is active.
			 * When body has .cursor-disabled, none of these rules fire, so the
			 * browser's native cursor is fully restored across every element
			 * without needing to fight inline styles or use !important overrides.
			 *
			 * This is the core fix — previously cursor: none was always applied
			 * on html/body and we tried to undo it with JS inline styles, but
			 * stylesheet rules and inline styles can conflict unpredictably.
			 * Now CSS is the single authority: class present = custom cursor,
			 * class absent = native cursor. JS only adds/removes the class.
			 */
			body:not(.cursor-disabled) html,
			body:not(.cursor-disabled),
			body:not(.cursor-disabled) a,
			body:not(.cursor-disabled) [role=button],
			body:not(.cursor-disabled) button,
			body:not(.cursor-disabled) [type=button]:not(:disabled),
			body:not(.cursor-disabled) [type=submit]:not(:disabled),
			body:not(.cursor-disabled) [type=reset]:not(:disabled),
			body:not(.cursor-disabled) select,
			body:not(.cursor-disabled) label[for],
			body:not(.cursor-disabled) summary,
			body:not(.cursor-disabled) [contenteditable] {
				cursor: none;
			}

			/*
			 * When .cursor-disabled is on body, restore native cursor on
			 * everything explicitly so there's no ambiguity across browsers.
			 * The * selector here is intentionally broad — we want every single
			 * element to show the native cursor, not just the ones listed above.
			 */
			body.cursor-disabled *,
			body.cursor-disabled {
				cursor: auto !important;
			}

			@media (hover: none) and (pointer: coarse) {
				body:not(.cursor-disabled),
				body:not(.cursor-disabled) a,
				body:not(.cursor-disabled) [role=button],
				body:not(.cursor-disabled) button,
				body:not(.cursor-disabled) [type=button]:not(:disabled),
				body:not(.cursor-disabled) [type=submit]:not(:disabled),
				body:not(.cursor-disabled) [type=reset]:not(:disabled),
				body:not(.cursor-disabled) select,
				body:not(.cursor-disabled) label[for],
				body:not(.cursor-disabled) summary,
				body:not(.cursor-disabled) [contenteditable] {
					cursor: auto;
				}
				#jelly-cursor {
					display: none !important;
				}
				#cursor-toggle {
					display: none !important;
				}
			}

			#jelly-cursor {
				position: fixed;
				top: 0;
				left: 0;
				width: 16px;
				height: 16px;
				background-color: #98d9a1;
				border-radius: 50%;
				transform-origin: 50% 50%;
				transform: translate3d(-100px, -100px, 0);
				will-change: width, height, transform, border;
				z-index: 99999;
				pointer-events: none;
				backface-visibility: hidden;
				-webkit-backface-visibility: hidden;
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
				image-rendering: -webkit-optimize-contrast;
				image-rendering: crisp-edges;
			}

			#cursor-toggle {
				position: fixed;
				top: 12px;
				left: 12px;
				z-index: 999999;
				width: 36px;
				height: 36px;
				border-radius: 50%;
				border: 2px solid transparent;
				background: transparent;
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 16px;
				opacity: 0;
				transition: opacity 0.2s ease, background 0.2s ease, border-color 0.2s ease;
				/* Always native cursor on this button so it's always clickable */
				cursor: auto !important;
				padding: 0;
			}

			#cursor-toggle:hover,
			#cursor-toggle:focus-visible {
				opacity: 1;
				background: rgba(0, 0, 0, 0.55);
				border-color: #98d9a1;
				outline: none;
			}

			/* Dim icon when disabled to signal current state at a glance */
			body.cursor-disabled #cursor-toggle-icon {
				filter: grayscale(1) opacity(0.5);
			}

			.page-transition-wrapper {
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				z-index: 100000;
				pointer-events: none;
			}

			.page-transition-svg {
				position: absolute;
				left: 0;
				top: 0;
				bottom: 0;
				right: 0;
				width: 100%;
				height: 100%;
			}
		</style>

		<script>
			import gsap from 'gsap';

			window.addEventListener('DOMContentLoaded', () => {

				const STORAGE_KEY = 'voltbully-custom-cursor';
				const toggleBtn   = document.getElementById('cursor-toggle') as HTMLButtonElement | null;
				const jellyEl     = document.getElementById('jelly-cursor') as HTMLElement | null;

				let customCursorEnabled: boolean =
					localStorage.getItem(STORAGE_KEY) !== 'disabled';

				function applyCustomCursorEnabled(enabled: boolean): void {
					customCursorEnabled = enabled;
					localStorage.setItem(STORAGE_KEY, enabled ? 'enabled' : 'disabled');

					if (enabled) {
						/*
						 * Re-enable: remove the disabled class so the CSS block at the
						 * top of the <style> tag re-applies cursor: none across all
						 * interactive elements. Also restore the jelly cursor element.
						 */
						document.body.classList.remove('cursor-disabled');
						if (jellyEl) {
							jellyEl.style.display = '';
						}
					} else {
						/*
						 * Disable: add the class — CSS takes over from here and sets
						 * cursor: auto !important on body.cursor-disabled * which
						 * overrides cursor: none on every element cleanly.
						 * No inline style fighting needed on our end.
						 */
						document.body.classList.add('cursor-disabled');
						if (jellyEl) {
							jellyEl.style.opacity = '0';
							jellyEl.style.display = 'none';
						}
					}
				}

				// Apply saved preference before any cursor code runs
				applyCustomCursorEnabled(customCursorEnabled);

				if (toggleBtn) {
					toggleBtn.addEventListener('click', () => {
						applyCustomCursorEnabled(!customCursorEnabled);
					});
				}

				// Hybrid device runtime input switching
				let cursorActive: boolean = window.matchMedia('(pointer: fine)').matches;

				window.addEventListener('pointerdown', (e: PointerEvent) => {
					if (e.pointerType === 'touch' && cursorActive) {
						cursorActive = false;
						if (jellyEl) jellyEl.style.opacity = '0';
						// Only touch native cursor if custom cursor is currently on —
						// if user already disabled it, don't interfere with their choice
						if (customCursorEnabled) {
							document.body.classList.add('cursor-disabled');
						}
					} else if (e.pointerType === 'mouse' && !cursorActive) {
						cursorActive = true;
						if (customCursorEnabled) {
							document.body.classList.remove('cursor-disabled');
						}
					}
				}, { passive: true });

				// ─── JELLY CURSOR ─────────────────────────────────────────────────

				if (cursorActive && jellyEl) {
					let hasReceivedMouseMove: boolean = false;

					const pos: { x: number; y: number }     = { x: -100, y: -100 };
					const vel: { x: number; y: number }     = { x: 0, y: 0 };
					let targetPos: { x: number; y: number } = { x: -100, y: -100 };
					let isHoveringClickable: boolean         = false;
					let rafId: number | null                 = null;
					let spinTween: gsap.core.Tween | null    = null;
					let lastTime: number | null              = null;

					const setX        = gsap.quickSetter(jellyEl, "x", "px");
					const setY        = gsap.quickSetter(jellyEl, "y", "px");
					const setRotation = gsap.quickSetter(jellyEl, "rotate", "deg");
					const setScaleX   = gsap.quickSetter(jellyEl, "scaleX");
					const setScaleY   = gsap.quickSetter(jellyEl, "scaleY");

					function getScale(diffX: number, diffY: number): number {
						const distance = Math.sqrt(Math.pow(diffX, 2) + Math.pow(diffY, 2));
						return Math.min(distance / 100, 0.25);
					}

					function getAngle(diffX: number, diffY: number): number {
						return (Math.atan2(diffY, diffX) * 180) / Math.PI;
					}

					function update(): void {
						const rotation = getAngle(vel.x, vel.y);
						const scale    = getScale(vel.x, vel.y);
						setX(pos.x);
						setY(pos.y);
						setRotation(rotation);
						if (!isHoveringClickable) {
							setScaleX(1 + scale);
							setScaleY(1 - scale);
						}
					}

					function animate(timestamp: number): void {
						if (!lastTime) lastTime = timestamp;
						const elapsed = timestamp - lastTime!;
						lastTime = timestamp;

						const delta = Math.min(elapsed / (1000 / 60), 3);
						const speed = 0.35 * delta;

						if (cursorActive && customCursorEnabled) {
							pos.x += (targetPos.x - pos.x) * speed;
							pos.y += (targetPos.y - pos.y) * speed;
							vel.x  = targetPos.x - pos.x;
							vel.y  = targetPos.y - pos.y;
							update();
						}

						rafId = requestAnimationFrame(animate);
					}

					document.addEventListener('visibilitychange', () => {
						if (document.hidden) {
							if (rafId) {
								cancelAnimationFrame(rafId);
								rafId    = null;
								lastTime = null;
							}
						} else {
							if (!rafId) rafId = requestAnimationFrame(animate);
						}
					});

					window.addEventListener("mousemove", (e: MouseEvent) => {
						if (!cursorActive || !customCursorEnabled) return;

						targetPos.x = e.clientX;
						targetPos.y = e.clientY;

						if (!hasReceivedMouseMove) {
							hasReceivedMouseMove = true;
							pos.x    = e.clientX;
							pos.y    = e.clientY;
							lastTime = null;
							jellyEl.style.visibility = 'visible';
							gsap.to(jellyEl, { opacity: 1, duration: 0.3, ease: 'power2.out' });
						}
					});

					function handleCursorHover(isHovering: boolean): void {
						if (!jellyEl || !cursorActive || !customCursorEnabled) return;
						isHoveringClickable = isHovering;

						if (isHovering) {
							gsap.killTweensOf(jellyEl);
							gsap.to(jellyEl, {
								scale: 2.5,
								backgroundColor: '#61c4c5',
								border: '3px solid #000000',
								boxShadow: '0 0 0 1px rgba(97, 196, 197, 0.3)',
								duration: 0.4,
								ease: 'back.out(1.7)',
								force3D: true,
							});
							spinTween = gsap.to(jellyEl, {
								rotation: 360,
								duration: 2,
								ease: 'none',
								repeat: -1,
							});
						} else {
							if (spinTween) { spinTween.kill(); spinTween = null; }
							gsap.set(jellyEl, { rotation: 0 });
							gsap.killTweensOf(jellyEl, "scale,backgroundColor,border,boxShadow");
							gsap.to(jellyEl, {
								scale: 1,
								backgroundColor: '#98d9a1',
								border: 'none',
								boxShadow: 'none',
								duration: 0.5,
								ease: 'back.out(1.2)',
								force3D: true,
							});
						}
					}

					const CLICKABLE_SELECTOR = 'a, button, [role="button"], input[type="button"], input[type="submit"], input[type="reset"], select, label[for], summary';

					function addCursorListeners(): void {
						document.querySelectorAll(CLICKABLE_SELECTOR).forEach((element) => {
							const el = element as Element & { _cursorBound?: boolean };
							if (el._cursorBound) return;
							el._cursorBound = true;

							el.addEventListener('mouseenter', () => {
								setTimeout(() => handleCursorHover(true), 10);
							});

							el.addEventListener('mouseleave', (e: Event) => {
								const mouseEvent = e as MouseEvent;
								const to = mouseEvent.relatedTarget as Element | null;
								const isStillOverClickable = to && (
									to.matches(CLICKABLE_SELECTOR) ||
									to.closest(CLICKABLE_SELECTOR)
								);
								if (!isStillOverClickable) handleCursorHover(false);
							});
						});
					}

					function hideCursor(): void {
						if (!hasReceivedMouseMove) return;
						gsap.killTweensOf(jellyEl, "opacity");
						gsap.to(jellyEl, { opacity: 0, duration: 0.3, ease: 'power2.out' });
					}

					function showCursor(): void {
						if (!hasReceivedMouseMove || !cursorActive || !customCursorEnabled) return;
						gsap.killTweensOf(jellyEl, "opacity");
						gsap.to(jellyEl, { opacity: 1, duration: 0.3, ease: 'power2.out' });
					}

					function handleIframes(): void {
						document.querySelectorAll('iframe').forEach((iframe) => {
							const el = iframe as HTMLIFrameElement & { _cursorBound?: boolean };
							if (el._cursorBound) return;
							el._cursorBound = true;
							el.addEventListener('mouseenter', hideCursor);
							el.addEventListener('mouseleave', showCursor);
						});
					}

					document.addEventListener('mouseleave', hideCursor);
					document.addEventListener('mouseenter', showCursor);

					addCursorListeners();
					handleIframes();
					animate(performance.now());

					const observer = new MutationObserver(() => {
						addCursorListeners();
						handleIframes();
					});
					observer.observe(document.body, {
						childList: true,
						subtree: true,
						attributes: true,
						attributeFilter: ['role'],
					});
				}

				// ─── PAGE TRANSITIONS ─────────────────────────────────────────────

				function initPageTransitions(): void {
					const transitionPath = document.querySelector('.transition-path');
					if (!transitionPath) return;

					const start  = "M 0 100 V 100 Q 50 100 100 100 V 100 z";
					const middle = "M 0 100 V 50 Q 50 0 100 50 V 100 z";
					const end    = "M 0 100 V 0 Q 50 0 100 0 V 100 z";

					function animatePageEntrance(): void {
						gsap.timeline()
							.to(transitionPath, { attr: { d: middle }, duration: 0.3, ease: "power2.in" })
							.to(transitionPath, { attr: { d: start },  duration: 0.3, ease: "power2.out" });
					}

					function animatePageTransition(url: string): void {
						gsap.timeline()
							.set(transitionPath, { attr: { d: start } })
							.to(transitionPath, { attr: { d: middle }, duration: 0.3, ease: "power2.in" })
							.to(transitionPath, { attr: { d: end },    duration: 0.3, ease: "power2.out" })
							.call(() => { window.location.href = url; });
					}

					document.addEventListener('click', (e: MouseEvent) => {
						const target = e.target;
						if (!target || !(target instanceof Element)) return;
						const link = target.closest('a');
						if (link && link.href) {
							const url        = new URL(link.href);
							const currentUrl = new URL(window.location.href);
							if (url.origin === currentUrl.origin && url.pathname !== currentUrl.pathname) {
								e.preventDefault();
								animatePageTransition(link.href);
							}
						}
					});

					animatePageEntrance();
				}

				initPageTransitions();
			});
		</script>

		<!-- VoltBully Animation System -->
		<script src="/script.js" is:inline></script>
	</body>
</html>