---
import Footer from "../components/layout/Footer.astro";
import Navbar from "../components/layout/Navbar.astro";
import CouponPopup from "../components/layout/CouponPopup.astro";
import "../styles/global.css"

export interface Props {
	title?: string;
	description?: string;
	keywords?: string;
	ogImage?: string;
}

const {
	title = "VoltBully - Professional Electrical Services | Licensed Electricians",
	description = "VoltBully provides professional electrical services including residential, commercial, and emergency electrical work. Licensed electricians serving your area with 24/7 emergency service, free estimates, and quality workmanship.",
	keywords = "electrician, electrical services, residential electrical, commercial electrical, emergency electrical, licensed electrician, electrical repair, electrical installation, electrical contractor",
	ogImage = "/voltbully1.png"
} = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/voltbully1.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Meta Tags -->
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<meta name="author" content="VoltBully" />
		<meta name="robots" content="index, follow" />
		
		<!-- Open Graph Meta Tags -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:site_name" content="VoltBully" />
		
		<!-- Twitter Card Meta Tags -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />
		
		<!-- Additional SEO -->
		<link rel="canonical" href={Astro.url} />
		
		<!-- Resource hints -->
		<link rel="dns-prefetch" href="//fonts.googleapis.com">
		<link rel="dns-prefetch" href="//fonts.gstatic.com">
		<!-- NOTE: Removed dns-prefetch for cdnjs.cloudflare.com — GSAP is now bundled locally -->
		
		<!-- Font preconnect -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		
		<!-- Fonts loaded asynchronously -->
		<link rel="preload" href="https://fonts.googleapis.com/css2?family=Asap+Condensed:wght@400;500;600;700;800&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
		<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Asap+Condensed:wght@400;500;600;700;800&display=swap"></noscript>
		
		<link rel="preload" href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
		<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700&display=swap"></noscript>
		
		<link rel="preload" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@900&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
		<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@900&display=swap"></noscript>
		
		<title>{title}</title>
		
		<style>
			html, body { 
				overflow-x: hidden; 
				max-width: 100vw; 
				margin: 0; 
				padding: 0;
			}
			.font-helvetica { 
				font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
			}
			.font-asap-condensed { 
				font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;
			}
			/* Cursor hidden until mouse actually moves — avoids top-left flash */
			#jelly-cursor { 
				opacity: 0; 
				visibility: hidden;
			}
			.min-h-screen { min-height: 100vh; }
			.flex { display: flex; }
			.flex-col { flex-direction: column; }
			.flex-1 { flex: 1 1 0%; }
		</style>
	</head>
	<body class="min-h-screen flex flex-col overflow-x-hidden max-w-full">
		<!-- Custom Jelly Cursor -->
		<div id="jelly-cursor"></div>
		
		<!-- Page Transition Overlay -->
		<div class="page-transition-wrapper" id="page-transition">
			<svg class="page-transition-svg" viewBox="0 0 100 100" preserveAspectRatio="xMidYMin slice">
				<defs>
					<linearGradient id="voltbully-grad" x1="0" y1="0" x2="99" y2="99" gradientUnits="userSpaceOnUse">
						<stop offset="0.2" stop-color="#98d9a1" />
						<stop offset="0.7" stop-color="#61c4c5" />
					</linearGradient>
				</defs>
				<path class="transition-path" stroke="url(#voltbully-grad)" fill="url(#voltbully-grad)" stroke-width="2px" vector-effect="non-scaling-stroke" d="M 0 100 V 0 Q 50 0 100 0 V 100 z" />
			</svg>
		</div>
		
		<Navbar />
		<main class="flex-1 overflow-x-hidden max-w-full">
			<slot />
		</main>
		<Footer />
		<CouponPopup />

		<style>
			html, body, a, [role=button], button,
			[type=button]:not(:disabled),
			[type=submit]:not(:disabled),
			[type=reset]:not(:disabled),
			select,
			label[for],
			summary,
			[contenteditable] {
				cursor: none;
			}

			@media (hover: none) and (pointer: coarse) {
				html, body, a, [role=button], button,
				[type=button]:not(:disabled),
				[type=submit]:not(:disabled),
				[type=reset]:not(:disabled),
				select,
				label[for],
				summary,
				[contenteditable] {
					cursor: auto;
				}
				#jelly-cursor {
					display: none !important;
				}
			}

			#jelly-cursor {
				position: fixed;
				top: 0;
				left: 0;
				width: 16px;
				height: 16px;
				background-color: #98d9a1;
				border-radius: 50%;
				transform-origin: 50% 50%;
				transform: translate3d(-100px, -100px, 0);
				will-change: width, height, transform, border;
				z-index: 99999;
				pointer-events: none;
				backface-visibility: hidden;
				-webkit-backface-visibility: hidden;
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
				image-rendering: -webkit-optimize-contrast;
				image-rendering: crisp-edges;
			}

			.page-transition-wrapper {
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				z-index: 100000;
				pointer-events: none;
			}

			.page-transition-svg {
				position: absolute;
				left: 0;
				top: 0;
				bottom: 0;
				right: 0;
				width: 100%;
				height: 100%;
			}
		</style>

		<!--
			CHANGE: Removed `is:inline` so Astro's bundler processes this script.
			This allows the `import gsap from 'gsap'` statement below to work —
			Astro/Vite will resolve the local npm package and include it in the
			built JS bundle instead of fetching it from an external CDN at runtime.

			Before running your build, make sure you have installed GSAP:
			  npm install gsap
		-->
		<script>
			import gsap from 'gsap';

			window.addEventListener('DOMContentLoaded', () => {

				// Hybrid device runtime input switching.
				// cursorActive is the single source of truth used throughout
				// to gate all cursor-related operations.
				let cursorActive = window.matchMedia('(pointer: fine)').matches;
				const elasticCursor = document.getElementById('jelly-cursor');

				window.addEventListener('pointerdown', (e) => {
					if (e.pointerType === 'touch' && cursorActive) {
						cursorActive = false;
						if (elasticCursor) elasticCursor.style.opacity = '0';
						document.documentElement.style.cursor = 'auto';
					} else if (e.pointerType === 'mouse' && !cursorActive) {
						cursorActive = true;
						document.documentElement.style.cursor = 'none';
					}
				}, { passive: true });

				// No async GSAP loader needed — it's bundled locally now.
				// If gsap fails to import (e.g. package not installed), Astro
				// will throw a build-time error rather than a silent runtime failure,
				// which is far easier to catch and fix.

				if (cursorActive && elasticCursor) {
					let hasReceivedMouseMove = false;

					const pos = { x: -100, y: -100 };
					const vel = { x: 0, y: 0 };
					let targetPos = { x: -100, y: -100 };
					let isHoveringClickable = false;
					let rafId: number | null = null;
					let spinTween: gsap.core.Tween | null = null;

					// Delta-time normalised lerp — keeps elastic feel identical
					// across 60Hz, 120Hz, 144Hz, and 240Hz displays.
					let lastTime: number | null = null;

					const setX        = gsap.quickSetter(elasticCursor, "x", "px");
					const setY        = gsap.quickSetter(elasticCursor, "y", "px");
					const setRotation = gsap.quickSetter(elasticCursor, "rotate", "deg");
					const setScaleX   = gsap.quickSetter(elasticCursor, "scaleX");
					const setScaleY   = gsap.quickSetter(elasticCursor, "scaleY");

					function getScale(diffX: number, diffY: number): number {
						const distance = Math.sqrt(Math.pow(diffX, 2) + Math.pow(diffY, 2));
						return Math.min(distance / 100, 0.25);
					}

					function getAngle(diffX: number, diffY: number): number {
						return (Math.atan2(diffY, diffX) * 180) / Math.PI;
					}

					function update() {
						const rotation = getAngle(vel.x, vel.y);
						const scale    = getScale(vel.x, vel.y);
						setX(pos.x);
						setY(pos.y);
						setRotation(rotation);
						if (!isHoveringClickable) {
							setScaleX(1 + scale);
							setScaleY(1 - scale);
						}
					}

					function animate(timestamp: number): void {
						if (!lastTime) lastTime = timestamp;
						const elapsed = timestamp - lastTime!;
						lastTime = timestamp;

						// Normalise to 60fps baseline; clamp to 3 to absorb tab-hidden spikes
						const delta = Math.min(elapsed / (1000 / 60), 3);
						const speed = 0.35 * delta;

						if (cursorActive) {
							pos.x += (targetPos.x - pos.x) * speed;
							pos.y += (targetPos.y - pos.y) * speed;
							vel.x  = targetPos.x - pos.x;
							vel.y  = targetPos.y - pos.y;
							update();
						}

						rafId = requestAnimationFrame(animate);
					}

					// Pause/resume rAF loop on tab hide — saves CPU and resets
					// lastTime so the first resumed frame doesn't spike delta.
					document.addEventListener('visibilitychange', () => {
						if (document.hidden) {
							if (rafId) {
								cancelAnimationFrame(rafId);
								rafId = null;
								lastTime = null;
							}
						} else {
							if (!rafId) {
								rafId = requestAnimationFrame(animate);
							}
						}
					});

					window.addEventListener("mousemove", (e) => {
						if (!cursorActive) return;

						targetPos.x = e.clientX;
						targetPos.y = e.clientY;

						if (!hasReceivedMouseMove) {
							hasReceivedMouseMove = true;
							pos.x = e.clientX;
							pos.y = e.clientY;
							lastTime = null;
							elasticCursor.style.visibility = 'visible';
							gsap.to(elasticCursor, { opacity: 1, duration: 0.3, ease: 'power2.out' });
						}
					});

					function handleCursorHover(isHovering: boolean): void {
						if (!elasticCursor || !cursorActive) return;
						isHoveringClickable = isHovering;

						if (isHovering) {
							gsap.killTweensOf(elasticCursor);
							gsap.to(elasticCursor, {
								scale: 2.5,
								backgroundColor: '#61c4c5',
								border: '3px solid #000000',
								boxShadow: '0 0 0 1px rgba(97, 196, 197, 0.3)',
								duration: 0.4,
								ease: 'back.out(1.7)',
								force3D: true,
							});
							spinTween = gsap.to(elasticCursor, {
								rotation: 360,
								duration: 2,
								ease: 'none',
								repeat: -1,
							});
						} else {
							if (spinTween) {
								spinTween.kill();
								spinTween = null;
							}
							gsap.set(elasticCursor, { rotation: 0 });
							gsap.killTweensOf(elasticCursor, "scale,backgroundColor,border,boxShadow");
							gsap.to(elasticCursor, {
								scale: 1,
								backgroundColor: '#98d9a1',
								border: 'none',
								boxShadow: 'none',
								duration: 0.5,
								ease: 'back.out(1.2)',
								force3D: true,
							});
						}
					}

					const CLICKABLE_SELECTOR = 'a, button, [role="button"], input[type="button"], input[type="submit"], input[type="reset"], select, label[for], summary';

					function addCursorListeners() {
						document.querySelectorAll(CLICKABLE_SELECTOR).forEach((element) => {
							const el = element as Element & { _cursorBound?: boolean };
							if (el._cursorBound) return;
							el._cursorBound = true;

							el.addEventListener('mouseenter', () => {
								setTimeout(() => handleCursorHover(true), 10);
							});

							el.addEventListener('mouseleave', (e: Event) => {
								const mouseEvent = e as MouseEvent;
								const to = mouseEvent.relatedTarget as Element | null;
								const isStillOverClickable = to && (
									to.matches(CLICKABLE_SELECTOR) ||
									to.closest(CLICKABLE_SELECTOR)
								);
								if (!isStillOverClickable) handleCursorHover(false);
							});
						});
					}

					function hideCursor() {
						if (!hasReceivedMouseMove) return;
						gsap.killTweensOf(elasticCursor, "opacity");
						gsap.to(elasticCursor, { opacity: 0, duration: 0.3, ease: 'power2.out' });
					}

					function showCursor() {
						if (!hasReceivedMouseMove || !cursorActive) return;
						gsap.killTweensOf(elasticCursor, "opacity");
						gsap.to(elasticCursor, { opacity: 1, duration: 0.3, ease: 'power2.out' });
					}

					function handleIframes() {
						document.querySelectorAll('iframe').forEach((iframe) => {
							const el = iframe as HTMLIFrameElement & { _cursorBound?: boolean };
							if (el._cursorBound) return;
							el._cursorBound = true;
							el.addEventListener('mouseenter', hideCursor);
							el.addEventListener('mouseleave', showCursor);
						});
					}

					document.addEventListener('mouseleave', hideCursor);
					document.addEventListener('mouseenter', showCursor);

					addCursorListeners();
					handleIframes();
					animate(performance.now());

					const observer = new MutationObserver(() => {
						addCursorListeners();
						handleIframes();
					});
					observer.observe(document.body, {
						childList: true,
						subtree: true,
						attributes: true,
						attributeFilter: ['role'],
					});
				}

				// --- Page Transitions ---

				function initPageTransitions() {
					const transitionPath = document.querySelector('.transition-path');
					if (!transitionPath) return;

					const start  = "M 0 100 V 100 Q 50 100 100 100 V 100 z";
					const middle = "M 0 100 V 50 Q 50 0 100 50 V 100 z";
					const end    = "M 0 100 V 0 Q 50 0 100 0 V 100 z";

					function animatePageEntrance() {
						gsap.timeline()
							.to(transitionPath, { attr: { d: middle }, duration: 0.3, ease: "power2.in" })
							.to(transitionPath, { attr: { d: start },  duration: 0.3, ease: "power2.out" });
					}

					function animatePageTransition(url: string): void {
						gsap.timeline()
							.set(transitionPath, { attr: { d: start } })
							.to(transitionPath, { attr: { d: middle }, duration: 0.3, ease: "power2.in" })
							.to(transitionPath, { attr: { d: end },    duration: 0.3, ease: "power2.out" })
							.call(() => { window.location.href = url; });
					}

					document.addEventListener('click', (e) => {
						const target = e.target;
						if (!target || !(target instanceof Element)) return;
						const link = target.closest('a');
						if (link && link.href) {
							const url = new URL(link.href);
							const currentUrl = new URL(window.location.href);
							if (url.origin === currentUrl.origin && url.pathname !== currentUrl.pathname) {
								e.preventDefault();
								animatePageTransition(link.href);
							}
						}
					});

					animatePageEntrance();
				}

				initPageTransitions();
			});
		</script>

		<!-- VoltBully Animation System -->
		<script src="/script.js" is:inline></script>
	</body>
</html>